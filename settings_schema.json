  {
    "name": "Brand Colors",
    "settings": [
      {
        "type": "header",
        "content": "Burnlab Primary Palette"
      },
      {
        "type": "paragraph",
        "content": "These colors are used by BurnLab sections as CSS variables. Changing them here updates your brand accent colours site-wide."
      },
      {
        "type": "color",
        "id": "brand_green",
        "label": "Accent green",
        "default": "#07d16e",
        "info": "Primary brand color. Used for CTAs, highlights, and interactive elements."
      },
      {
        "type": "color",
        "id": "brand_navy",
        "label": "Deep navy",
        "default": "#001a2e",
        "info": "Primary dark background. Used in dark sections, hero, footer."
      },
      {
        "type": "color",
        "id": "brand_teal",
        "label": "Teal",
        "default": "#336870",
        "info": "Secondary brand color. Used for borders, accents, and supporting elements."
      },
      {
        "type": "color",
        "id": "brand_pale",
        "label": "Pale blue-white",
        "default": "#eaf4f5",
        "info": "Primary light color. Used for text on dark backgrounds."
      },
      {
        "type": "header",
        "content": "Burnlab Secondary Palette"
      },
      {
        "type": "color",
        "id": "brand_mint",
        "label": "Fresh mint",
        "default": "#cfede1",
        "info": "Used for soft backgrounds and secondary highlights."
      },
      {
        "type": "color",
        "id": "brand_blue_grey",
        "label": "Cool blue-grey",
        "default": "#d6e3ea",
        "info": "Used for premium neutral sections."
      },
      {
        "type": "color",
        "id": "brand_light_teal",
        "label": "Light teal",
        "default": "#bfe1db",
        "info": "Used for subtle teal-tinted elements."
      },
      {
        "type": "color",
        "id": "brand_neutral_grey",
        "label": "Neutral grey",
        "default": "#e1e7ea",
        "info": "Universal backdrop color for product sections."
      },
      {
        "type": "color",
        "id": "brand_soft_navy",
        "label": "Soft navy tint",
        "default": "#ccdce6",
        "info": "Used for contrast with dark products."
      }
    ]
  },
  {
    "name": "Animations",
    "settings": [
      {
        "type": "header",
        "content": "Scroll Reveal"
      },
      {
        "type": "checkbox",
        "id": "enable_scroll_reveal",
        "label": "Enable scroll reveal animations",
        "default": true,
        "info": "Fade-in and slide-up effects as sections enter the viewport."
      },
      {
        "type": "select",
        "id": "reveal_direction",
        "label": "Reveal direction",
        "options": [
          {
            "value": "up",
            "label": "Slide up"
          },
          {
            "value": "left",
            "label": "Slide left"
          },
          {
            "value": "right",
            "label": "Slide right"
          },
          {
            "value": "scale",
            "label": "Scale in"
          },
          {
            "value": "fade",
            "label": "Fade only"
          }
        ],
        "default": "up"
      },
      {
        "type": "range",
        "id": "reveal_duration",
        "min": 300,
        "max": 1200,
        "step": 50,
        "unit": "ms",
        "label": "Reveal animation duration",
        "default": 750
      },
      {
        "type": "header",
        "content": "Hover Effects"
      },
      {
        "type": "checkbox",
        "id": "enable_hover_lift",
        "label": "Enable card hover lift",
        "default": true,
        "info": "Cards rise slightly on hover."
      },
      {
        "type": "checkbox",
        "id": "enable_image_zoom",
        "label": "Enable product image zoom on hover",
        "default": true
      },
      {
        "type": "header",
        "content": "Ambient Effects"
      },
      {
        "type": "checkbox",
        "id": "enable_grain_overlay",
        "label": "Enable grain texture overlay",
        "default": false,
        "info": "Adds a subtle noise texture over section backgrounds. Works best on dark sections."
      },
      {
        "type": "range",
        "id": "grain_opacity",
        "min": 10,
        "max": 80,
        "step": 5,
        "unit": "%",
        "label": "Grain opacity",
        "default": 45,
        "info": "Visible only when grain texture overlay is enabled."
      },
      {
        "type": "checkbox",
        "id": "enable_ambient_glows",
        "label": "Enable ambient glow blobs",
        "default": true,
        "info": "Soft blurred color orbs in dark sections. Adds depth and brand character."
      }
    ]
  },
