  {
    "name": "Typography",
    "settings": [
      {
        "type": "header",
        "content": "Headings"
      },
      {
        "type": "paragraph",
        "content": "Brand heading font: QUI Bold (custom). Fallback: Archivo Black (loaded via Google Fonts in theme.liquid). Upload qui-bold.woff2 to assets to activate."
      },
      {
        "type": "font_picker",
        "id": "type_header_font",
        "default": "assistant_n7",
        "label": "Font"
      },
      {
        "type": "range",
        "id": "heading_scale",
        "min": 100,
        "max": 150,
        "step": 5,
        "unit": "%",
        "label": "Font size scale",
        "default": 100
      },
      {
        "type": "header",
        "content": "Body"
      },
      {
        "type": "paragraph",
        "content": "Brand body font: Newblack Typeface (custom). Fallback: DM Sans (loaded via Google Fonts in theme.liquid). Upload newblack-typeface.woff2 to assets to activate."
      },
      {
        "type": "font_picker",
        "id": "type_body_font",
        "default": "assistant_n4",
        "label": "Font"
      },
      {
        "type": "range",
        "id": "body_scale",
        "min": 100,
        "max": 130,
        "step": 5,
        "unit": "%",
        "label": "Font size scale",
        "default": 100
      }
    ]
  },
