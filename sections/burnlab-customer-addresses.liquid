<script>
(function () {
  var SEC          = document.getElementById('{{ section_id }}');
  if (!SEC) return;

  var panelTitle   = document.getElementById('al-panel-title-{{ section.id }}');
  var cancelBtn    = document.getElementById('al-cancel-edit-{{ section.id }}');
  var newFormEl    = document.getElementById('al-new-form-{{ section.id }}');
  var formColEl    = SEC.querySelector('.al-form-col');

  var ADD_TITLE    = {{ form_add_title | escape | json }};
  var EDIT_TITLE   = {{ form_edit_title | escape | json }};

  /* ── Switch to edit mode ── */
  function switchToEdit(addressId) {
    var editForm = document.getElementById('al-edit-form-' + addressId);
    if (!editForm) return;

    /* Fade out */
    var active = SEC.querySelector('.al-form-instance:not(.is-hidden)');
    if (active) {
      active.classList.add('is-switching');
      setTimeout(function () {
        active.classList.add('is-hidden');
        active.classList.remove('is-switching');
        showForm(editForm);
      }, 200);
    } else {
      showForm(editForm);
    }

    /* Update panel header */
    if (panelTitle) panelTitle.textContent = EDIT_TITLE;
    if (cancelBtn)  cancelBtn.classList.add('is-visible');

    /* Highlight card */
    SEC.querySelectorAll('.al-card').forEach(function (c) { c.classList.remove('al-card--active'); });
    var card = document.getElementById('al-card-' + addressId);
    if (card) card.classList.add('al-card--active');

    /* Scroll to form panel on small screens */
    if (window.innerWidth < 960 && formColEl) {
      setTimeout(function () {
        formColEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }, 100);
    }
  }

  function showForm(el) {
    el.classList.remove('is-hidden');
    requestAnimationFrame(function () {
      el.classList.remove('is-switching');
    });
    /* Focus first input */
    var first = el.querySelector('input:not([type=hidden])');
    if (first) setTimeout(function () { try { first.focus(); } catch(e) {} }, 100);
  }

  /* ── Reset to add new mode ── */
  function resetToAdd() {
    var active = SEC.querySelector('.al-form-instance:not(.is-hidden)');
    if (active && active !== newFormEl) {
      active.classList.add('is-switching');
      setTimeout(function () {
        active.classList.add('is-hidden');
        active.classList.remove('is-switching');
        if (newFormEl) {
          newFormEl.classList.remove('is-hidden');
        }
      }, 200);
    }
    if (panelTitle) panelTitle.textContent = ADD_TITLE;
    if (cancelBtn)  cancelBtn.classList.remove('is-visible');
    SEC.querySelectorAll('.al-card').forEach(function (c) { c.classList.remove('al-card--active'); });
  }

  /* ── Edit buttons ── */
  SEC.querySelectorAll('[data-edit-address]').forEach(function (btn) {
    btn.addEventListener('click', function () {
      switchToEdit(btn.getAttribute('data-edit-address'));
    });
  });

  /* ── Cancel edit ── */
  if (cancelBtn) cancelBtn.addEventListener('click', resetToAdd);

  /* ── Delete ── */
  SEC.querySelectorAll('[data-delete-url]').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var url = btn.getAttribute('data-delete-url');
      var msg = btn.getAttribute('data-confirm') || 'Are you sure?';
      if (confirm(msg)) {
        Shopify.postLink(url, { parameters: { _method: 'delete' } });
      }
    });
  });

  {% if enable_anims %}
  /* ── Card pin-drop reveal ── */
  var cards = SEC.querySelectorAll('.al-card');
  if (cards.length) {
    var obs = new IntersectionObserver(function (entries, o) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          var idx = parseInt(entry.target.getAttribute('data-card-index') || 0, 10);
          entry.target.style.transitionDelay = (idx * 0.09) + 's';
          entry.target.classList.add('is-visible');
          o.unobserve(entry.target);
        }
      });
    }, { threshold: 0.08 });
    cards.forEach(function (c) { obs.observe(c); });
  }

  var emptyEl = document.getElementById('al-empty-{{ section.id }}');
  if (emptyEl) {
    var emptyObs = new IntersectionObserver(function (entries, o) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) { entry.target.classList.add('is-visible'); o.unobserve(entry.target); }
      });
    }, { threshold: 0.12 });
    emptyObs.observe(emptyEl);
  }
  {% endif %}

})();
</script>

<script>
(function () {
  if (customElements.get('province-selector')) return;

  class ProvinceSelector extends HTMLElement {
    constructor() {
      super();
      this.countryEl        = this.querySelector('[data-country]');
      this.provinceEl       = this.querySelector('[data-province]');
      this.provinceContainer = this.querySelector('.al-province-row:last-child, [id*="prov-wrap"]');
      if (!this.countryEl || !this.provinceEl) return;
      this.defaultCountry  = this.countryEl.dataset.default || '';
      this.defaultProvince = this.provinceEl.dataset.default || '';
    }

    connectedCallback() {
      if (!this.countryEl) return;
      this.countryEl.querySelectorAll('option').forEach(function (opt) {
        if (opt.value === this.defaultCountry) this.countryEl.value = opt.value;
        var data = Shopify.countryProvinceSelector
          && Shopify.countryProvinceSelector.countries
          && Shopify.countryProvinceSelector.countries[opt.value];
        if (data && data.provinces) opt.setAttribute('data-provinces', JSON.stringify(data.provinces));
      }.bind(this));
      this.updateProvinces();
      this.countryEl.addEventListener('change', this.updateProvinces.bind(this));
    }

    updateProvinces() {
      if (!this.countryEl || !this.provinceEl) return;
      var selected  = this.countryEl.options[this.countryEl.selectedIndex];
      var provinces = [];
      try { provinces = JSON.parse(selected.getAttribute('data-provinces') || '[]'); } catch (e) {}
      this.provinceEl.innerHTML = '';
      /* Find container: look for the div with style="display:none" or the province wrap */
      var container = this.querySelector('[id*="prov-wrap"]') || this.querySelector('.al-province-row:not(:first-child)');
      if (!container) {
        /* Fallback: second .al-form-group */
        var groups = this.querySelectorAll('.al-form-group');
        if (groups.length > 1) container = groups[1];
      }
      if (provinces.length === 0) {
        if (container) container.style.display = 'none';
        this.provinceEl.required = false;
        return;
      }
      if (container) container.style.display = '';
      this.provinceEl.required = true;
      provinces.forEach(function (pair) {
        var opt = document.createElement('option');
        opt.value = pair[1]; opt.textContent = pair[1];
        if (pair[1] === this.defaultProvince) opt.selected = true;
        this.provinceEl.appendChild(opt);
      }.bind(this));
    }
  }

  customElements.define('province-selector', ProvinceSelector);
}());
</script>

