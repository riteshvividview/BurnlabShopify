                  <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/>
                  <circle cx="12" cy="9" r="2.5"/>
                </svg>
              </div>
            {% endif %}
            <h2 class="al-empty-h">{{ empty_heading | escape }}</h2>
            <p class="al-empty-p">{{ empty_subtext | escape }}</p>
          </div>

        {% endif %}

      </div><!-- /al-list-col -->

      <!-- ── Right col: sticky form panel ── -->
      <div class="al-form-col">
        <div class="al-panel">

          <!-- Panel header: shows mode + cancel button -->
