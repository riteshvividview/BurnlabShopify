        {
          "value": "container_width",
          "label": "Container"
        }
      ],
      "default": "container_width"
    },
    {
      "type": "range",
      "id": "border-radius",
      "label": "Section border radius",
      "min": 0,
      "max": 100,
      "default": 20,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "height",
      "label": "Section height",
      "options": [
        {
          "value": "one-third",
          "label": "Small"
        },
        {
          "value": "two-third",
          "label": "Large"
        }, 
        {
          "value": "full",
          "label": "Full screen"
        },
        {
          "value": "auto",
          "label": "Adapt"
        }
      ],
      "default": "auto"
    },
    {
      "type": "range",
      "id": "overlay",
      "label": "Overlay",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 20,
      "unit": "%"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000",
    },
    {
      "type": "checkbox",
      "id": "show_overlay_maxwidth",
      "label": "Show overlay",
      "info": "Show overlay with max-width",
      "default": false
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Overlay border color",
      "info": "Add overlay border color",
      "visible_if": "{{ section.settings.show_overlay_maxwidth == true }}"
    },
    {
      "type": "checkbox",
