{% style %}
#shopify-section-{{ section.id }} .image_banner_wrap  {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    position: relative;
    z-index: 1; 
  }  
  @media screen and (max-width: 640px) {
    #shopify-section-{{ section.id }} .image_banner_wrap  {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    } 
  }
   
{% endstyle %}

{{ 'image-banner.css' | asset_url | stylesheet_tag }}

<div
  class="image_banner_wrap image-background-wrapper-{{ section.id }} color_scheme color-{{ section.settings.color_scheme }}"
  style="
    --border-radius: {{ section.settings.border-radius }}px;
    --overlay: {{ section.settings.overlay }}%;
    --max-width: {{ section.settings.max_width }}px; --overlay_color: {{ section.settings.overlay_color }}; --border_color: {{ section.settings.border_color }};"
>
  <div class="{% if section.settings.width == 'full_width' %}img-full-width{%else%}container{% endif %}">
    <div class="image-bg-inner img-sec-{{ section.settings.height }}">
      <div class="image_bg_inner_overlay{% if section.settings.show_overlay_maxwidth %} overlay_maxwidth{% endif %}">
        {% if section.settings.highlight_corner_left_top %}<div class="border--left-top"></div>{% endif %}
        {% if section.settings.highlight_corner_top_right %}<div class="border--top-right"></div>{% endif %}
        {% if section.settings.highlight_corner_right_bottom %}<div class="border--right-bottom"></div>{% endif %}
        {% if section.settings.highlight_corner_bottom_left %}<div class="border--bottom-left"></div>{% endif %}
      </div>
      <div class="image-bg-outer img-bg-{{ section.settings.height }}">
        {% if section.settings.video != blank %}
          {{
            section.settings.video
            | video_tag: image_size: '1920x', autoplay: true, loop: true, playsinline: true, muted: true, tabindex: '-1'
          }}
        {% elsif section.settings.image != blank %}
          {% render 'image' image: section.settings.image %}
        {% else %}
          {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
        {% endif %}
      </div>

      <div class="img-bg-content-wrapper image-background-text--{{ section.settings.text_align }} im-content--{{ section.settings.position }}">
        <div class="image-bg-content-inner">
          <div class="section_content_gap">
              {% for block in section.blocks %}
                {% case block.type %}
                    {% when 'subheading' %}
                    {% if block.settings.subhead != blank %}
                      <span {{ block.shopify_attributes }}
                        class="subheading {{ block.settings.font-size }} {% if block.settings.font_style == 'body' %}body_style{% endif %}"
                        style="--color: {{ block.settings.color }};"
                      >
                        {{ block.settings.subhead }}
                      </span>
                    {% endif %}

                  {% when 'heading' %}
                    {% if block.settings.head != blank %}
                      <h2 {{ block.shopify_attributes }}
                        class="section_heading {{ block.settings.font-size }} {% if block.settings.font_style == 'body' %}body_style{% endif %}"
                      >
                        {{ block.settings.head }}
                      </h2>
                    {% endif %}

                  {% when 'text' %}
                    {% if block.settings.text != blank %}
                      <div {{ block.shopify_attributes }}
                        class="image-with-text"
                      >
                        {{ block.settings.text }}
                      </div>
                    {% endif %}

                  {% when 'button' %}
                    {% if block.settings.btn_link != blank or block.settings.btn_label != blank %}
                      <div {{ block.shopify_attributes }} class="image-with-btn">
                        {% if settings.enable_magnet %}<magnetic-button data-radius="200">{% endif %}
                         {% render 'section-button' 
                          button_label: block.settings.btn_label,
                          btn_link: block.settings.btn_link,
                          new_tab: block.settings.new_tab,
                          style: block.settings.style
                         %}
                         {%if settings.enable_magnet %}{% endif %}
                         {%if settings.enable_magnet %}</magnetic-button>{% endif %}
                      </div>
                    {% endif %}
                {% endcase %}
              {% endfor %}
            </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  var imageRoot = document.querySelector('.image-background-wrapper-{{ section.id }}');
  var imageVideo = imageRoot.querySelector('video');
  if (imageVideo) {
    imageVideo.querySelector('img').setAttribute('alt', 'Video background image');
  }
</script>

{% schema %}
{
  "name": "Image banner",
  "class": "image-banner",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
