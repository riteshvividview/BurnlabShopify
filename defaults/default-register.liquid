{% style %}
  .main_customer_register_wrapper {
      padding-top: {{ section.settings.top_spacing }}px;
      padding-bottom: {{ section.settings.bottom_spacing }}px;
  }

  @media screen and (max-width: 640px) {
      .main_customer_register_wrapper {
          padding-top: {{ section.settings.mob_top_spacing }}px;
          padding-bottom: {{ section.settings.mob_bottom_spacing }}px;
      }
  }
{% endstyle %}

{{ 'customer-register.css' | asset_url | stylesheet_tag }}

<div
  class="main_customer_register_wrapper color_scheme color-{{ section.settings.color_scheme }}"
  style="--border-radius: {{ section.settings.border_radius }}px;"
>
  <div class="container">
    <div class="customer_register_form_inner{% if section.settings.img != blank %} has_img img--{{ section.settings.img_alignment }}{% endif %}">
      {% if section.settings.img != blank %}
        <div class="customer_register_form_img_wrapper">
          {{ section.settings.img | image_url: width: 1920 | image_tag }}
        </div>
      {% endif %}
      <div class="customer_register_form_wrapper">
        <div class="customer_register_form_header">
          <h1>{{ 'customer.register.title' | t }}</h1>
          <p>
            {{ 'customer.register.have_account' | t }}
            <a aria-label="{{ 'customer.register.login' | t }}" href="{{ routes.account_login_url }}">
              {{- 'customer.register.login' | t -}}
            </a>
          </p>
        </div>

        <div class="customer_register_form">
          {% form 'create_customer' %}
            {% if form.errors %}
              <div class="form_error_msg">
                <p class="form__message" role="alert" tabindex="-1" autofocus>
                  <svg aria-hidden="true" focusable="false" viewBox="0 0 13 13">
                    <circle cx="6.5" cy="6.50049" r="5.5" stroke="white" stroke-width="2"/>
                    <circle cx="6.5" cy="6.5" r="5.5" fill="#EB001B" stroke="#EB001B" stroke-width="0.7"/>
                    <path d="M5.87413 3.52832L5.97439 7.57216H7.02713L7.12739 3.52832H5.87413ZM6.50076 9.66091C6.88091 9.66091 7.18169 9.37267 7.18169 9.00504C7.18169 8.63742 6.88091 8.34917 6.50076 8.34917C6.12061 8.34917 5.81982 8.63742 5.81982 9.00504C5.81982 9.37267 6.12061 9.66091 6.50076 9.66091Z" fill="white"/>
                    <path d="M5.87413 3.17832H5.51535L5.52424 3.537L5.6245 7.58083L5.63296 7.92216H5.97439H7.02713H7.36856L7.37702 7.58083L7.47728 3.537L7.48617 3.17832H7.12739H5.87413ZM6.50076 10.0109C7.06121 10.0109 7.5317 9.57872 7.5317 9.00504C7.5317 8.43137 7.06121 7.99918 6.50076 7.99918C5.94031 7.99918 5.46982 8.43137 5.46982 9.00504C5.46982 9.57872 5.94031 10.0109 6.50076 10.0109Z" fill="white" stroke="#EB001B" stroke-width="0.7">
                  </svg>
                  {{ 'templates.contact.form.error_heading' | t }}
                </p>
              </div>
              <div class="form_errors">
                {{ form.errors | default_errors }}
              </div>
            {% endif %}

            <div class="{%if section.settings.img != blank %}input_wrapper_split{% else %} no_split{% endif %}">
              <div class="input_wrapper">
                <input
                  type="text"
                  name="customer[first_name]"
                  id="RegisterForm-FirstName"
                  {% if form.first_name %}
                    value="{{ form.first_name }}"
                  {% endif %}
                  required
                  autocomplete="given-name"
                  placeholder="{{ 'customer.register.first_name' | t }}"
                >
                <label for="RegisterForm-FirstName">{{ 'customer.register.first_name' | t | append: ' *' }}</label>
                {{ 'icon-user.svg' | inline_asset_content }}
              </div>

              <div class="input_wrapper">
                <input
                  type="text"
                  name="customer[last_name]"
                  id="RegisterForm-LastName"
                  {% if form.last_name %}
                    value="{{ form.last_name }}"
                  {% endif %}
                  required
                  autocomplete="family-name"
                  placeholder="{{ 'customer.register.last_name' | t }}"
                >
                <label for="RegisterForm-LastName">{{ 'customer.register.last_name' | t | append: ' *' }}</label>
                {{ 'icon-user.svg' | inline_asset_content }}
              </div>
            </div>

            <div class="{%if section.settings.img != blank %}input_wrapper_split{% else %} no_split{% endif %}">
              <div class="input_wrapper">
                <input
                  type="email"
                  name="customer[email]"
                  id="RegisterForm-email"
                  {% if form.email %}
                    value="{{ form.email }}"
                  {% endif %}
                  spellcheck="false"
                  autocapitalize="off"
                  autocomplete="email"
                  aria-required="true"
                  {% if form.errors contains 'email' %}
                    aria-invalid="true"
                    aria-describedby="RegisterForm-email-error"
                  {% endif %}
                  required
                  placeholder="{{ 'customer.register.email' | t }}"
                >
                <label for="RegisterForm-email">{{ 'customer.register.email' | t | append: ' *' }}</label>
                {{ 'icon-envelope.svg' | inline_asset_content }}
              </div>

              <div class="input_wrapper">
                <input
                  type="password"
                  name="customer[password]"
                  id="RegisterForm-password"
                  aria-required="true"
                  {% if form.errors contains 'password' %}
                    aria-invalid="true"
                    aria-describedby="RegisterForm-password-error"
                  {% endif %}
                  required
                  placeholder="{{ 'customer.register.password' | t }}"
                >
                <label for="RegisterForm-password">{{ 'customer.register.password' | t | append: ' *' }}</label>
                {{ 'icon-lock.svg' | inline_asset_content }}
              </div>
            </div>

            <div class="customer_register_form_btns">
              {% if settings.enable_magnet %}<magnetic-button data-radius="200">{% endif %}
              <button class="btn" type="submit">
                {{ 'customer.register.submit' | t }}
              </button>
              {% if settings.enable_magnet %}</magnetic-button>{% endif %}

              <a href="{{ routes.root_url }}">{{ 'customer.login_page.return_to_store' | t }}</a>
            </div>
          {% endform %}
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Customer register",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Section border radius",
      "min": 0,
      "max": 20,
      "step": 1,
      "default": 10,
      "unit": "px"
    },
    {
      "type": "image_picker",
      "id": "img",
      "label": "Select image"
    },
    {
      "type": "select",
      "id": "img_alignment",
      "label": "Image alignment",
      "visible_if": "{{ section.settings.img != blank }}",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "right"
    },
    {
      "type": "header",
      "content": "Desktop spacing"
    },
    {
      "type": "range",
      "id": "top_spacing",
      "label": "Top spacing",
      "unit": "px",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 40
    },
    {
      "type": "range",
      "id": "bottom_spacing",
      "label": "Bottom spacing",
      "unit": "px",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 40
    },
    {
      "type": "header",
      "content": "Mobile spacing"
    },
    {
      "type": "range",
      "id": "mob_top_spacing",
      "label": "Top spacing",
      "unit": "px",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 20
    },
    {
      "type": "range",
      "id": "mob_bottom_spacing",
      "label": "Bottom spacing",
      "unit": "px",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 20
    }
  ]
}
{% endschema %}
