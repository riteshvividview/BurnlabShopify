      "label": "Padding bottom",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "default": 30,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "icon-with-image",
      "name": "Icon With Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "image_picker",
