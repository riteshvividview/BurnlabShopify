{% style %}
    #shopify-section-{{ section.id }} .section_padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    position: relative;
    z-index: 1;
  }

    @media screen and (max-width: 640px) {
    #shopify-section-{{ section.id }} .section_padding {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
  }
{% endstyle %}

{{ 'image-gallery-collage.css' | asset_url | stylesheet_tag }}

<div class="gallery-collage color_scheme color-{{ section.settings.color_scheme }} section_padding"
    style="--border-radius: {{ section.settings.border_radius }}px;"
>
  <div class="container">

    <!-- Heading -->
    <div class="collage_head_head collage_head--{{ section.settings.head_align }}">
      {% if section.settings.head != blank %}
        <h2 class="section_heading {{ section.settings.font-size }} {% if section.settings.font_style == 'body' %}body_style{% endif %}">
          {{ section.settings.head }}
        </h2>
      {% endif %}

      {% if section.settings.text != blank %}
        <div class="section_rteText" style="--text-max-width:{{ section.settings.max-width }}%;">
          {{ section.settings.text }}
        </div>
      {% endif %}

      {% if section.settings.btn_link != blank or section.settings.btn_label != blank %}
          <div class="collage-with-btn">
          {% if settings.enable_magnet %}<magnetic-button data-radius="200">{% endif %}
              {% render 'section-button' 
              button_label: section.settings.btn_label,
              btn_link: section.settings.btn_link,
              new_tab: section.settings.new_tab,
              style: section.settings.style
              %}
              {%if settings.enable_magnet %}{% endif %}
              {%if settings.enable_magnet %}</magnetic-button>{% endif %}
          </div>
      {% endif %}

    </div>

    <!-- Blocks -->
    <div class="image-gallery-collage-blocks">
      {% for block in section.blocks %}
        {% case block.type %}
        {% when 'icon-with-image' %}
        <div class="icon_with_image_collage collage_gallery_col"  
            style="
            --block-padding-top: {{ block.settings.padding_top }}px;
            --block-padding-bottom: {{ block.settings.padding_bottom }}px;
            --block-margin-top: {{ block.settings.margin_top }}px;
            --block-margin-bottom: {{ block.settings.margin_bottom }}px;
          ">
            <div class="icon_image_collage">
                <div class="image_collage_block collage-icon">
                    {% if block.settings.icon != blank %}
                        {% render 'image' image: block.settings.icon %}
                    {% else %}
                        {{ 'product-2' | placeholder_svg_tag: 'placeholder_svg' }}
                    {% endif %} 
                </div>
                <div class="image_collage_block">
                    {% if block.settings.image != blank %}
                        {% render 'image' image: block.settings.image %}
                    {% else %}
                        {{ 'product-2' | placeholder_svg_tag: 'placeholder_svg' }}
                    {% endif %} 
                </div>
            </div>
        </div>
        {% when 'multiple-image' %}
        <div class="multi-images-collage collage_gallery_col"
         style="
            --block-padding-top: {{ block.settings.padding_top }}px;
            --block-padding-bottom: {{ block.settings.padding_bottom }}px;
            --block-margin-top: {{ block.settings.margin_top }}px;
            --block-margin-bottom: {{ block.settings.margin_bottom }}px;
        ">
            <div class="multiple_image_collage">
                <div class="image_collage_block">
                    {% if block.settings.image_1 != blank %}
                        {% render 'image' image: block.settings.image_1 %}
                    {% else %}
                        {{ 'product-2' | placeholder_svg_tag: 'placeholder-svg' }}
                    {% endif %} 
                </div>
                <div class="image_collage_block">
                    {% if block.settings.image_2 != blank %}
                        {% render 'image' image: block.settings.image_2 %}
                    {% else %}
                        {{ 'product-2' | placeholder_svg_tag: 'placeholder-svg' }}
                    {% endif %} 
                </div>
            </div>
        </div>
        {% endcase %}
      {% endfor %}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Image Gallery Collage",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
