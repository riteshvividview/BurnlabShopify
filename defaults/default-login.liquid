{% style %}
  .main_customer_login_wrapper {
      padding-top: {{ section.settings.top_spacing }}px;
      padding-bottom: {{ section.settings.bottom_spacing }}px;
  }

  @media screen and (max-width: 640px) {
      .main_customer_login_wrapper {
          padding-top: {{ section.settings.mob_top_spacing }}px;
          padding-bottom: {{ section.settings.mob_bottom_spacing }}px;
      }
  }
{% endstyle %}

{{ 'customer-login.css' | asset_url | stylesheet_tag }}

{%- if section.settings.enable_shop_login_button == false -%}
  {%- assign hide_shop_login_button = true -%}
{%- endif -%}

<div
  class="main_customer_login_wrapper color_scheme color-{{ section.settings.color_scheme }}"
  style="--border-radius: {{ section.settings.border_radius }}px;"
>
  <div class="container">
    <customer-login>
      <div class="main_customer_login_inner{% if section.settings.img != blank %} has_img img--{{ section.settings.img_alignment }}{% endif %}">
        {% if section.settings.img != blank %}
          <div class="main_customer_login_img_wrapper">
            {{ section.settings.img | image_url: width: 1920 | image_tag }}
          </div>
        {% endif %}

        <div class="main_customer_login_form_wrapper">
          <div class="main_customer_login_form_header">
            <h1>{{ 'customer.login_page.title' | t }}</h1>
            <p>
              {{ 'customer.login_page.new_here' | t }}
              <a aria-label="" href="{{ routes.account_register_url }}">
                {{- 'customer.login_page.create_account' | t -}}
              </a>
            </p>
          </div>

          <div class="main_customer_login_form">
            {% form 'customer_login' %}
              {% if form.errors %}
                <div class="form_error_msg">
                  <p class="form__message" role="alert" tabindex="-1" autofocus>
                    <svg aria-hidden="true" focusable="false" viewBox="0 0 13 13">
                      <circle cx="6.5" cy="6.50049" r="5.5" stroke="white" stroke-width="2"/>
                      <circle cx="6.5" cy="6.5" r="5.5" fill="#EB001B" stroke="#EB001B" stroke-width="0.7"/>
                      <path d="M5.87413 3.52832L5.97439 7.57216H7.02713L7.12739 3.52832H5.87413ZM6.50076 9.66091C6.88091 9.66091 7.18169 9.37267 7.18169 9.00504C7.18169 8.63742 6.88091 8.34917 6.50076 8.34917C6.12061 8.34917 5.81982 8.63742 5.81982 9.00504C5.81982 9.37267 6.12061 9.66091 6.50076 9.66091Z" fill="white"/>
                      <path d="M5.87413 3.17832H5.51535L5.52424 3.537L5.6245 7.58083L5.63296 7.92216H5.97439H7.02713H7.36856L7.37702 7.58083L7.47728 3.537L7.48617 3.17832H7.12739H5.87413ZM6.50076 10.0109C7.06121 10.0109 7.5317 9.57872 7.5317 9.00504C7.5317 8.43137 7.06121 7.99918 6.50076 7.99918C5.94031 7.99918 5.46982 8.43137 5.46982 9.00504C5.46982 9.57872 5.94031 10.0109 6.50076 10.0109Z" fill="white" stroke="#EB001B" stroke-width="0.7">
                    </svg>
                    {{ 'templates.contact.form.error_heading' | t }}
                  </p>
                </div>
                <div class="form_errors">
                  {{ form.errors | default_errors }}
                </div>
              {% endif %}

              {%- if shop.features.login_with_shop_classic_customer_accounts? -%}
                <section name="sign-in-with-shop-provider">
                  {{ shop | login_button: hide_button: hide_shop_login_button }}

                  {%- unless hide_shop_login_button -%}
                    <p style="text-align: center;">
                      {{ 'customer.login_page.alternate_provider_separator' | t }}
                    </p>
                  {%- endunless -%}
                </section>
              {%- endif -%}

              <div class="input_wrapper">
                <input
                  type="email"
                  name="customer[email]"
                  id="CustomerEmail"
                  autocomplete="email"
                  autocorrect="off"
                  autocapitalize="off"
                  {% if form.errors contains 'form' %}
                    aria-invalid="true"
                  {% endif %}
                  required
                  placeholder="{{ 'customer.login_page.email' | t }}"
                >
                <label for="CustomerEmail">{{ 'customer.login_page.email' | t | append: ' *' }}</label>
                {{ 'icon-envelope.svg' | inline_asset_content }}
              </div>

              {%- if form.password_needed -%}
                <div
                  class="input_wrapper"
                >
                  <input
                    type="password"
                    value=""
                    name="customer[password]"
                    id="CustomerPassword"
                    autocomplete="current-password"
                    {% if form.errors contains 'form' %}
                      aria-invalid="true"
                    {% endif %}
                    required
                    placeholder="{{ 'customer.login_page.password' | t }}"
                  >
                  <label for="CustomerPassword">{{ 'customer.login_page.password' | t | append: ' *' }}</label>
                  {{ 'icon-lock.svg' | inline_asset_content }}
                </div>
              {%- endif -%}

              <div class="main_customer_login_form_btns">
                {% if form.password_needed %}
                  <a href="javascript:void" id="forgot_password">
                    {{ 'customer.login_page.forgot_password' | t }}
                  </a>
                {% endif %}

                {% if settings.enable_magnet %}<magnetic-button data-radius="200">{% endif %}
                <button type="submit" class="btn">{{ 'customer.login_page.login' | t }}</button>
                {% if settings.enable_magnet %}</magnetic-button>{% endif %}

                <a href="{{ routes.root_url }}">{{ 'customer.login_page.return_to_store' | t }}</a>
              </div>
            {% endform %}
          </div>
        </div>

        <div class="main_customer_recover_form_wrapper hidden" id="recover">
          <div class="main_customer_recover_form_header">
            <h1>{{ 'customer.recover_password.title' | t }}</h1>
            <p>{{ 'customer.recover_password.text' | t }}</p>
          </div>

          <div class="main_customer_recover_form">
            {% form 'recover_customer_password' %}
              {% if form.errors %}
                <div class="form_error_msg">
                  <p class="form__message" role="alert" tabindex="-1" autofocus>
                    <svg aria-hidden="true" focusable="false" viewBox="0 0 13 13">
                      <circle cx="6.5" cy="6.50049" r="5.5" stroke="white" stroke-width="2"/>
                      <circle cx="6.5" cy="6.5" r="5.5" fill="#EB001B" stroke="#EB001B" stroke-width="0.7"/>
                      <path d="M5.87413 3.52832L5.97439 7.57216H7.02713L7.12739 3.52832H5.87413ZM6.50076 9.66091C6.88091 9.66091 7.18169 9.37267 7.18169 9.00504C7.18169 8.63742 6.88091 8.34917 6.50076 8.34917C6.12061 8.34917 5.81982 8.63742 5.81982 9.00504C5.81982 9.37267 6.12061 9.66091 6.50076 9.66091Z" fill="white"/>
                      <path d="M5.87413 3.17832H5.51535L5.52424 3.537L5.6245 7.58083L5.63296 7.92216H5.97439H7.02713H7.36856L7.37702 7.58083L7.47728 3.537L7.48617 3.17832H7.12739H5.87413ZM6.50076 10.0109C7.06121 10.0109 7.5317 9.57872 7.5317 9.00504C7.5317 8.43137 7.06121 7.99918 6.50076 7.99918C5.94031 7.99918 5.46982 8.43137 5.46982 9.00504C5.46982 9.57872 5.94031 10.0109 6.50076 10.0109Z" fill="white" stroke="#EB001B" stroke-width="0.7">
                    </svg>
                    {{ 'templates.contact.form.error_heading' | t }}
                  </p>
                </div>
                <div class="form_errors">
                  {{ form.errors | default_errors }}
                </div>
              {% endif %}

              <div class="input_wrapper">
                <input
                  type="email"
                  value=""
                  name="email"
                  id="RecoverEmail"
                  autocorrect="off"
                  autocapitalize="off"
                  autocomplete="email"
                  required
                  {% if form.errors %}
                    aria-invalid="true"
                    aria-describedby="RecoverEmail-email-error"
                    autofocus
                  {% endif %}

                  placeholder="{{ 'customer.login_page.email' | t }}"
                >
                <label for="RecoverEmail">{{ 'customer.login_page.email' | t | append: ' *' }}</label>
                {{ 'icon-envelope.svg' | inline_asset_content }}
              </div>

              <div class="main_customer_recover_password_btns">
                {% if settings.enable_magnet %}<magnetic-button data-radius="200">{% endif %}
                <button class="btn" type="submit">
                  {{ 'customer.login_page.submit' | t }}
                </button>
                {% if settings.enable_magnet %}</magnetic-button>{% endif %}

                <a
                  id="recover_cancel_link"
                  aria-label="{{ 'customer.login_page.cancel' | t }}"
                  href="javascript:void"
                >
                  {{- 'customer.login_page.cancel' | t -}}
                </a>
              </div>
            {% endform %}
          </div>
        </div>
      </div>
    </customer-login>

    {%- if shop.checkout.guest_login -%}
      <div class="guest_login_wrapper">
        <h2>{{ 'customer.login_page.guest_title' | t }}</h2>

        {%- form 'guest_login' -%}
          <button class="btn">
            {{ 'customer.login_page.guest_continue' | t }}
          </button>
        {%- endform -%}
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Customer login",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "enable_shop_login_button",
      "label": "Enable Sign in with Shop",
      "default": false
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Section border radius",
      "min": 0,
      "max": 20,
      "step": 1,
      "default": 10,
      "unit": "px"
    },
    {
      "type": "image_picker",
      "id": "img",
      "label": "Select image"
    },
    {
      "type": "select",
      "id": "img_alignment",
      "label": "Image alignment",
      "visible_if": "{{ section.settings.img != blank }}",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "right"
    },
    {
      "type": "header",
      "content": "Desktop spacing"
    },
    {
      "type": "range",
      "id": "top_spacing",
      "label": "Top spacing",
      "unit": "px",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 40
    },
    {
      "type": "range",
      "id": "bottom_spacing",
      "label": "Bottom spacing",
      "unit": "px",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 40
    },
    {
      "type": "header",
      "content": "Mobile spacing"
    },
    {
      "type": "range",
      "id": "mob_top_spacing",
      "label": "Top spacing",
      "unit": "px",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 20
    },
    {
      "type": "range",
      "id": "mob_bottom_spacing",
      "label": "Bottom spacing",
      "unit": "px",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 20
    }
  ]
}
{% endschema %}