  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Section border radius",
      "min": 0,
      "max": 100,
      "default": 20,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "inline_richtext",
      "id": "head",
      "label": "Heading",
      "default": "Featured Collection Tab"
    },
    {
      "type": "select",
      "id": "font_style",
      "label": "Font style",
      "options": [
        { "value": "heading", "label": "Heading" },
        { "value": "body", "label": "Body" }
      ],
      "default": "heading"
    },
    {
      "type": "select",
      "id": "font-size",
      "label": "Font size",
      "options": [
        { "value": "XXXL", "label": "XXX large" },
        { "value": "h1",   "label": "Extra large" },
        { "value": "h2",   "label": "Large" },
        { "value": "h3",   "label": "Medium" },
        { "value": "h4",   "label": "Small" },
        { "value": "h5",   "label": "Extra small" }
      ],
      "default": "h2"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Description",
      "default": "<p>Showcase the products from the collection in a grid or slider format.</p>"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Content max width",
      "min": 30,
      "max": 100,
      "default": 60,
      "step": 5,
      "unit": "%"
