{% style %}
  #shopify-section-{{ section.id }} .bl-article-section {
    position: relative;
    overflow: hidden;
    padding-top: {{ section.settings.top_spacing }}px;
    padding-bottom: {{ section.settings.bottom_spacing }}px;
    background: var(--bl-mode-bg);
    transition: background .4s ease;
  }

  #shopify-section-{{ section.id }} .bl-article-container {
    max-width: {{ section.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 24px;
    position: relative;
    z-index: 2;
  }

  #shopify-section-{{ section.id }} .bl-article-glow {
    position: absolute;
    width: 600px;
    height: 600px;
    border-radius: 100%;
    background: radial-gradient(circle, {{ section.settings.glow_color }} 0%, transparent 70%);
    opacity: {{ section.settings.glow_opacity | divided_by: 100.0 }};
    filter: blur(90px);
    top: -220px;
    right: -180px;
    pointer-events: none;
    animation: blArticleFloat 8s ease-in-out infinite alternate;
  }

  #shopify-section-{{ section.id }} .bl-article-hero {
    position: relative;
    border-radius: {{ section.settings.image_radius }}px;
    overflow: hidden;
    margin-bottom: 50px;
    transform: translateY(40px);
    opacity: 0;
    animation: blArticleReveal .8s cubic-bezier(.16,1,.3,1) forwards;
    background: rgba(255,255,255,.03);
    border: 1px solid rgba(255,255,255,.08);
  }

  #shopify-section-{{ section.id }} .bl-article-hero img {
    width: 100%;
    display: block;
    object-fit: cover;
    transition: transform .8s ease;
  }

  #shopify-section-{{ section.id }} .bl-article-hero:hover img {
    transform: scale(1.05);
  }

  #shopify-section-{{ section.id }} .bl-article-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0,0,0,.72) 0%,
      rgba(0,0,0,.2) 45%,
      rgba(0,0,0,0) 100%
    );
    z-index: 1;
  }

  #shopify-section-{{ section.id }} .bl-article-meta {
    position: absolute;
    left: 40px;
    bottom: 40px;
    z-index: 3;
    max-width: 850px;
  }

  #shopify-section-{{ section.id }} .bl-article-author-row {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 16px;
  }

  #shopify-section-{{ section.id }} .bl-article-chip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 16px;
    border-radius: 999px;
    background: rgba(255,255,255,.08);
    border: 1px solid rgba(255,255,255,.1);
    backdrop-filter: blur(14px);
    color: #fff;
    font-size: 14px;
    letter-spacing: .03em;
    transition: all .3s ease;
  }

  #shopify-section-{{ section.id }} .bl-article-chip:hover {
    transform: translateY(-2px);
    background: rgba(255,255,255,.14);
  }

  #shopify-section-{{ section.id }} .bl-article-title h1 {
    margin: 0;
    color: #fff;
    line-height: 1;
    letter-spacing: -.04em;
    text-shadow: 0 10px 35px rgba(0,0,0,.4);
  }

  #shopify-section-{{ section.id }} .bl-article-body-wrap {
    display: grid;
    grid-template-columns: {% if section.settings.enable_sidebar %}1fr 320px{% else %}1fr{% endif %};
    gap: 40px;
    align-items: start;
  }

  #shopify-section-{{ section.id }} .bl-article-content {
    position: relative;
    padding: 50px;
    border-radius: {{ section.settings.content_radius }}px;
    background: rgba(255,255,255,.04);
    border: 1px solid rgba(255,255,255,.08);
    backdrop-filter: blur(18px);
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .bl-article-content::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        135deg,
        rgba(255,255,255,.05),
        transparent 40%
      );
    pointer-events: none;
  }

  #shopify-section-{{ section.id }} .bl-article-content .rte,
  #shopify-section-{{ section.id }} .bl-article-content .rte * {
    color: var(--bl-mode-text) !important;
    transition: color .35s ease;
  }

  #shopify-section-{{ section.id }} .bl-article-content .rte p {
    font-size: {{ section.settings.content_size }}px;
    line-height: 1.9;
    margin-bottom: 28px;
  }

  #shopify-section-{{ section.id }} .bl-article-content .rte h2,
  #shopify-section-{{ section.id }} .bl-article-content .rte h3,
  #shopify-section-{{ section.id }} .bl-article-content .rte h4 {
    color: var(--bl-mode-text) !important;
    margin-top: 42px;
    margin-bottom: 18px;
    line-height: 1.2;
  }

  #shopify-section-{{ section.id }} .bl-article-content .rte img {
    border-radius: 22px;
    overflow: hidden;
    margin: 40px 0;
    transform: scale(1);
    transition: transform .5s ease;
  }

  #shopify-section-{{ section.id }} .bl-article-content .rte img:hover {
    transform: scale(1.02);
  }

  #shopify-section-{{ section.id }} .bl-article-sidebar {
    position: sticky;
    top: 120px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  #shopify-section-{{ section.id }} .bl-sidebar-card {
    padding: 28px;
    border-radius: 24px;
    background: rgba(255,255,255,.04);
    border: 1px solid rgba(255,255,255,.08);
    backdrop-filter: blur(18px);
    transition: all .4s ease;
  }

  #shopify-section-{{ section.id }} .bl-sidebar-card:hover {
    transform: translateY(-4px);
    border-color: rgba(255,255,255,.16);
  }

  #shopify-section-{{ section.id }} .bl-sidebar-card h4 {
    margin-top: 0;
    margin-bottom: 18px;
    color: var(--bl-mode-text);
  }

  #shopify-section-{{ section.id }} .bl-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  #shopify-section-{{ section.id }} .bl-tags span {
    padding: 10px 16px;
    border-radius: 999px;
    background: rgba(255,255,255,.06);
    border: 1px solid rgba(255,255,255,.08);
    color: var(--bl-mode-text);
    font-size: 13px;
    transition: all .3s ease;
  }

  #shopify-section-{{ section.id }} .bl-tags span:hover {
    transform: translateY(-2px);
    background: rgba(255,255,255,.1);
  }

  #shopify-section-{{ section.id }} .bl-progress {
    position: fixed;
    top: 0;
    left: 0;
    width: 0%;
    height: {{ section.settings.progress_height }}px;
    background: linear-gradient(
      90deg,
      {{ section.settings.progress_color_1 }},
      {{ section.settings.progress_color_2 }}
    );
    z-index: 999;
    transition: width .1s linear;
  }

  #shopify-section-{{ section.id }} .bl-comments {
    margin-top: 70px;
  }

  #shopify-section-{{ section.id }} .bl-comments-grid {
    display: grid;
    gap: 24px;
  }

  #shopify-section-{{ section.id }} .bl-comment {
    padding: 28px;
    border-radius: 22px;
    background: rgba(255,255,255,.04);
    border: 1px solid rgba(255,255,255,.08);
    transition: all .35s ease;
  }

  #shopify-section-{{ section.id }} .bl-comment:hover {
    transform: translateY(-3px);
  }

  #shopify-section-{{ section.id }} .bl-comment * {
    color: var(--bl-mode-text);
  }

  #shopify-section-{{ section.id }} .bl-comment-meta {
    display: flex;
    gap: 14px;
    margin-top: 18px;
    opacity: .7;
    font-size: 14px;
  }

  #shopify-section-{{ section.id }} .bl-comment-form {
    margin-top: 60px;
    padding: 40px;
    border-radius: 28px;
    background: rgba(255,255,255,.04);
    border: 1px solid rgba(255,255,255,.08);
  }

  #shopify-section-{{ section.id }} .bl-comment-form * {
    color: var(--bl-mode-text);
  }

  #shopify-section-{{ section.id }} .bl-form-grid {
    display: grid;
    grid-template-columns: repeat(2,1fr);
    gap: 18px;
  }

  #shopify-section-{{ section.id }} .bl-input-group {
    position: relative;
  }

  #shopify-section-{{ section.id }} .bl-input-group.full {
    grid-column: span 2;
  }

  #shopify-section-{{ section.id }} .bl-input-group input,
  #shopify-section-{{ section.id }} .bl-input-group textarea {
    width: 100%;
    padding: 20px;
    border-radius: 18px;
    border: 1px solid rgba(255,255,255,.08);
    background: rgba(255,255,255,.03);
    color: var(--bl-mode-text);
    outline: none;
    transition: all .35s ease;
  }

  #shopify-section-{{ section.id }} .bl-input-group input:focus,
  #shopify-section-{{ section.id }} .bl-input-group textarea:focus {
    border-color: {{ section.settings.accent_color }};
    box-shadow: 0 0 0 4px rgba(0,255,170,.08);
  }

  #shopify-section-{{ section.id }} .bl-submit-btn {
    margin-top: 22px;
    border: none;
    cursor: pointer;
    padding: 18px 30px;
    border-radius: 999px;
    background: linear-gradient(
      135deg,
      {{ section.settings.button_color_1 }},
      {{ section.settings.button_color_2 }}
    );
    color: #fff;
    font-weight: 600;
    transition: all .35s ease;
  }

  #shopify-section-{{ section.id }} .bl-submit-btn:hover {
    transform: translateY(-3px) scale(1.02);
    box-shadow: 0 18px 40px rgba(0,0,0,.22);
  }

  @keyframes blArticleReveal {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes blArticleFloat {
    from {
      transform: translateY(0px);
    }
    to {
      transform: translateY(40px);
    }
  }

  @media screen and (max-width: 990px) {
    #shopify-section-{{ section.id }} .bl-article-body-wrap {
      grid-template-columns: 1fr;
    }

    #shopify-section-{{ section.id }} .bl-article-sidebar {
      position: relative;
      top: auto;
    }
  }

  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .bl-article-section {
      padding-top: {{ section.settings.mob_top_spacing }}px;
      padding-bottom: {{ section.settings.mob_bottom_spacing }}px;
    }

    #shopify-section-{{ section.id }} .bl-article-meta {
      left: 24px;
      right: 24px;
      bottom: 24px;
    }

    #shopify-section-{{ section.id }} .bl-article-content {
      padding: 28px;
    }

    #shopify-section-{{ section.id }} .bl-form-grid {
      grid-template-columns: 1fr;
    }

    #shopify-section-{{ section.id }} .bl-input-group.full {
      grid-column: span 1;
    }

    #shopify-section-{{ section.id }} .bl-comment-form {
      padding: 24px;
    }
  }

  /* THEME TOGGLE SUPPORT */

  #shopify-section-{{ section.id }} * {
    transition:
      background .35s ease,
      color .35s ease,
      border-color .35s ease;
  }

  [data-theme="dark"] #shopify-section-{{ section.id }} .bl-article-section * {
    color: #eaf4f5;
  }

  [data-theme="light"] #shopify-section-{{ section.id }} .bl-article-section * {
    color: #001a2e;
  }
{% endstyle %}

<div class="bl-progress" id="blProgressBar-{{ section.id }}"></div>

<div class="bl-article-section color-{{ section.settings.color_scheme }}">
  <div class="bl-article-glow"></div>

  <div class="bl-article-container">

    {% if article.image != blank %}
      <div class="bl-article-hero article_img--{{ section.settings.img_height }}">
        {{ article.image | image_url: width: 2200 | image_tag }}

        <div class="bl-article-overlay"></div>

        <div class="bl-article-meta">

          <div class="bl-article-author-row">

            {% if section.settings.show_author %}
              <div class="bl-article-chip">
                {{ article.author }}
              </div>
            {% endif %}

            {% if section.settings.show_date %}
              <div class="bl-article-chip">
                {{ article.published_at | date: '%B %d, %Y' }}
              </div>
            {% endif %}

          </div>

          <div class="bl-article-title">
            <h1 class="{{ section.settings.font_size }}{% if section.settings.font_style == 'body' %} body_style{% endif %}">
              {{ article.title }}
            </h1>
          </div>

        </div>
      </div>
    {% endif %}

    <div class="bl-article-body-wrap">

      <div class="bl-article-content">

        {% if article.content != blank %}
          <div class="rte">
            {{ article.content }}
          </div>
        {% endif %}

      </div>

      {% if section.settings.enable_sidebar %}
        <aside class="bl-article-sidebar">

          {% if section.settings.show_tags and article.tags.size > 0 %}
            <div class="bl-sidebar-card">
              <h4>Topics</h4>

              <div class="bl-tags">
                {% for tag in article.tags %}
                  <span>{{ tag }}</span>
                {% endfor %}
              </div>
            </div>
          {% endif %}

          <div class="bl-sidebar-card">
            <h4>Reading Time</h4>

            <p>
              {{ article.content | strip_html | split: ' ' | size | divided_by: 200 | at_least: 1 }}
              min read
            </p>
          </div>

        </aside>
      {% endif %}

    </div>

    {% if blog.comments_enabled? %}

      <div class="bl-comments">

        {% if article.comments_count > 0 %}
          <div class="bl-comments-grid">

            {% paginate article.comments by section.settings.comments_limit %}

              {% for comment in article.comments %}

                <div class="bl-comment">

                  <div class="bl-comment-body">
                    {{ comment.content }}
                  </div>

                  <div class="bl-comment-meta">
                    <span>{{ comment.author }}</span>
                    <span>{{ comment.created_at | date: '%B %d, %Y' }}</span>
                  </div>

                </div>

              {% endfor %}

              {% render 'pagination', paginate: paginate %}

            {% endpaginate %}

          </div>
        {% endif %}

        <div class="bl-comment-form">

          <h3>{{ section.settings.comment_heading }}</h3>

          {% form 'new_comment', article %}

            {% if form.posted_successfully? %}
              <div class="form_success_msg">
                {{ section.settings.success_text }}
              </div>
            {% endif %}

            {{ form.errors | default_errors }}

            <div class="bl-form-grid">

              <div class="bl-input-group">
                <input
                  type="text"
                  name="comment[author]"
                  value="{{ form.author }}"
                  placeholder="Your name"
                  required
                >
              </div>

              <div class="bl-input-group">
                <input
                  type="email"
                  name="comment[email]"
                  value="{{ form.email }}"
                  placeholder="Email address"
                  required
                >
              </div>

              <div class="bl-input-group full">
                <textarea
                  rows="6"
                  name="comment[body]"
                  placeholder="Write your comment..."
                  required
                >{{ form.body }}</textarea>
              </div>

            </div>

            {% if settings.enable_magnet %}
              <magnetic-button data-radius="220">
            {% endif %}

            <button type="submit" class="bl-submit-btn">
              {{ section.settings.button_text }}
            </button>

            {% if settings.enable_magnet %}
              </magnetic-button>
            {% endif %}

            {% if blog.moderated? %}
              <p class="moderated_comment_text">
                {{ section.settings.moderation_text }}
              </p>
            {% endif %}

          {% endform %}

        </div>

      </div>

    {% endif %}

  </div>
</div>

<script>
  (() => {
    const progressBar = document.getElementById('blProgressBar-{{ section.id }}');

    const updateProgress = () => {
      const scrollTop = window.scrollY;
      const docHeight = document.body.scrollHeight - window.innerHeight;
      const progress = (scrollTop / docHeight) * 100;

      progressBar.style.width = progress + '%';
    };

    window.addEventListener('scroll', updateProgress);

    const cards = document.querySelectorAll('#shopify-section-{{ section.id }} .bl-comment, #shopify-section-{{ section.id }} .bl-sidebar-card');

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if(entry.isIntersecting){
          entry.target.animate([
            {
              opacity: 0,
              transform: 'translateY(40px)'
            },
            {
              opacity: 1,
              transform: 'translateY(0)'
            }
          ], {
            duration: 700,
            easing: 'cubic-bezier(.16,1,.3,1)',
            fill: 'forwards'
          });

          observer.unobserve(entry.target);
        }
      });
    }, {
      threshold: 0.1
    });

    cards.forEach(card => observer.observe(card));
  })();
</script>

