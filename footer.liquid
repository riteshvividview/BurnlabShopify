{% comment %}
  ============================================================
  BURNLAB — Footer Section
  Supports: Shopify OS 2.0 | Min Width: 300px
  Animation: Signal Sweep — neon scan-line reveal +
             staggered column cascade + link draw-in underlines
  ============================================================
{% endcomment %}

{%- assign section_id = 'burnlab-footer-' | append: section.id -%}

{%- liquid
  assign logo              = section.settings.logo
  assign logo_light        = section.settings.logo_light
  assign logo_size         = section.settings.logo_size          | default: 120
  assign tagline           = section.settings.tagline
  assign show_socials      = section.settings.show_socials

  assign ig_url    = section.settings.social_instagram
  assign fb_url    = section.settings.social_facebook
  assign yt_url    = section.settings.social_youtube
  assign tw_url    = section.settings.social_twitter
  assign tt_url    = section.settings.social_tiktok
  assign wa_url    = section.settings.social_whatsapp

  assign side_image        = section.settings.side_image
  assign side_pos          = section.settings.side_image_position | default: 'right'
  assign side_width        = section.settings.side_image_width    | default: 22
  assign side_opacity_val  = section.settings.side_image_opacity  | default: 15
  assign side_opacity      = side_opacity_val | divided_by: 100.0

  assign bg_dark           = section.settings.bg_color_dark        | default: '#001a2e'
  assign text_dark         = section.settings.text_color_dark      | default: '#eaf4f5'
  assign accent_dark       = section.settings.accent_color_dark    | default: '#07d16e'
  assign border_dark       = section.settings.border_dark          | default: '#1a3a50'
  assign bottom_bg_dark    = section.settings.bottom_bg_dark       | default: '#000f1a'
  assign bg_light          = section.settings.bg_color_light       | default: '#eaf4f5'
  assign text_light        = section.settings.text_color_light     | default: '#001a2e'
  assign accent_light      = section.settings.accent_color_light   | default: '#07d16e'
  assign border_light      = section.settings.border_light         | default: '#b8d4dc'
  assign bottom_bg_light   = section.settings.bottom_bg_light      | default: '#d4eaee'

  assign show_payment      = section.settings.show_payment_icons
  assign show_policies     = section.settings.show_policies
  assign copyright_text    = section.settings.copyright_text       | default: 'All rights reserved.'
  assign show_powered      = section.settings.show_powered_by
  assign enable_anims      = section.settings.enable_animations
  assign padding_top       = section.settings.padding_top          | default: 80
  assign padding_bottom    = section.settings.padding_bottom       | default: 64
  assign pt_mob            = section.settings.padding_top_mobile   | default: 48
  assign pb_mob            = section.settings.padding_bottom_mobile | default: 40

  assign heading_color     = section.settings.column_heading_color  | default: '#eaf4f5'
  assign link_color        = section.settings.link_color            | default: '#b0c8d4'
  assign link_hover_color  = section.settings.link_hover_color      | default: '#07d16e'
  assign social_style      = section.settings.social_style          | default: 'circle'
  assign muted_dark        = text_dark  | color_modify: 'alpha', 0.5
  assign muted_light       = text_light | color_modify: 'alpha', 0.55
-%}

{% style %}

/* ── Reset ── */
#{{ section_id }} *,
#{{ section_id }} *::before,
#{{ section_id }} *::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

/* ── Dark mode tokens ── */
#{{ section_id }} {
  --ft-bg:          {{ bg_dark }};
  --ft-text:        {{ text_dark }};
  --ft-accent:      {{ accent_dark }};
  --ft-border:      {{ border_dark }};
  --ft-muted:       {{ text_dark | color_modify: 'alpha', 0.5 }};
  --ft-bottom-bg:   {{ bottom_bg_dark }};
  --ft-col-heading: {{ heading_color }};
  --ft-link:        {{ link_color }};
  --ft-link-hover:  {{ link_hover_color }};
  --ft-glow:        rgba(7, 209, 110, 0.08);
}

[data-theme="light"] #{{ section_id }} {
  --ft-bg:          {{ bg_light }};
  --ft-text:        {{ text_light }};
  --ft-accent:      {{ accent_light }};
  --ft-border:      {{ border_light }};
  --ft-muted:       {{ muted_light }};
  --ft-bottom-bg:   {{ bottom_bg_light }};
  --ft-col-heading: {{ text_light }};
  --ft-link:        #336870;
  --ft-glow:        rgba(7, 209, 110, 0.05);
}

/* ── Section root ── */
#{{ section_id }} {
  position: relative;
  overflow: hidden;
  isolation: isolate;
  background-color: var(--ft-bg);
  color: var(--ft-text);
  transition: background-color 0.35s ease, color 0.35s ease;
}

/* ── Ambient glow ── */
#{{ section_id }} .ft-glow {
  position: absolute;
  width: 80rem;
  height: 80rem;
  background: radial-gradient(ellipse at center, var(--ft-glow) 0%, transparent 60%);
  border-radius: 50%;
  pointer-events: none;
  z-index: 1;
  top: -30%;
  right: -20%;
  will-change: transform;
}

/* ── Side decorative image ── */
{% if side_image %}
#{{ section_id }} .ft-side-img {
  position: absolute;
  top: 0;
  {{ side_pos }}: 0;
  width: {{ side_width }}%;
  height: calc(100% - 80px); /* stop before bottom bar */
  z-index: 1;
  pointer-events: none;
}
#{{ section_id }} .ft-side-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  opacity: {{ side_opacity }};
  display: block;
}
#{{ section_id }} .ft-side-img::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(
    {% if side_pos == 'right' %}270deg{% else %}90deg{% endif %},
    var(--ft-bg) 0%,
    rgba(0,0,0,0) 65%
  );
  z-index: 1;
}
@media (max-width: 768px) {
  #{{ section_id }} .ft-side-img { display: none; }
}
{% endif %}

/* ── Signal Sweep scan line ── */
{% if enable_anims %}
@keyframes ft-scan-sweep {
  0%   { left: -6px; opacity: 0; }
  3%   { opacity: 1; }
  97%  { opacity: 0.7; }
  100% { left: calc(100% + 6px); opacity: 0; }
}

#{{ section_id }} .ft-scan-line {
  position: absolute;
  top: 0;
  left: -6px;
  width: 3px;
  height: 100%;
  background: linear-gradient(
    180deg,
    transparent 0%,
    var(--ft-accent) 30%,
    rgba(7, 209, 110, 0.6) 50%,
    var(--ft-accent) 70%,
    transparent 100%
  );
  box-shadow: 0 0 14px 4px rgba(7, 209, 110, 0.35);
  z-index: 3;
  pointer-events: none;
  animation: ft-scan-sweep 1.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  animation-play-state: paused;
  will-change: left, opacity;
}

#{{ section_id }}.ft-is-visible .ft-scan-line {
  animation-play-state: running;
}

@media (prefers-reduced-motion: reduce) {
  #{{ section_id }} .ft-scan-line { display: none; }
}
{% endif %}

/* ══════════════════════════════════════════════════════
   MAIN BODY
══════════════════════════════════════════════════════ */
#{{ section_id }} .ft-body {
  padding-top: {{ padding_top }}px;
  padding-bottom: {{ padding_bottom }}px;
  position: relative;
  z-index: 10;
}

@media (max-width: 768px) {
  #{{ section_id }} .ft-body {
    padding-top: {{ pt_mob }}px !important;
    padding-bottom: {{ pb_mob }}px !important;
  }
}

/* ── Container ── */
#{{ section_id }} .ft-container {
  max-width: 1400px;
  margin-inline: auto;
  padding-inline: clamp(1.6rem, 5vw, 8rem);
}

/* ── Main grid: brand | blocks ── */
#{{ section_id }} .ft-main {
  display: grid;
  grid-template-columns: minmax(180px, {{ logo_size | plus: 80 }}px) 1fr;
  gap: clamp(3.2rem, 6vw, 7rem);
  align-items: start;
}

@media (max-width: 1024px) {
  #{{ section_id }} .ft-main {
    grid-template-columns: 1fr;
    gap: clamp(2.4rem, 4vw, 4rem);
  }
}

/* ══════════════════════════════════════════════════════
   BRAND COLUMN
══════════════════════════════════════════════════════ */
#{{ section_id }} .ft-brand {
  display: flex;
  flex-direction: column;
  gap: clamp(1.6rem, 2.5vw, 2.4rem);
}

/* Logo */
#{{ section_id }} .ft-logo-wrap {
  display: block;
  line-height: 0;
}

#{{ section_id }} .ft-logo-dark {
  width: {{ logo_size }}px;
  max-width: 100%;
  height: auto;
  display: block;
  transition: opacity 0.3s ease;
}

#{{ section_id }} .ft-logo-light {
  width: {{ logo_size }}px;
  max-width: 100%;
  height: auto;
  display: none;
  transition: opacity 0.3s ease;
}

[data-theme="light"] #{{ section_id }} .ft-logo-dark  { display: none; }
[data-theme="light"] #{{ section_id }} .ft-logo-light { display: block; }

/* Tagline */
#{{ section_id }} .ft-tagline {
  font-family: 'DM Sans', sans-serif;
  font-size: clamp(1.3rem, 1.4vw, 1.55rem);
  line-height: 1.65;
  color: var(--ft-muted);
  overflow-wrap: break-word;
  word-break: break-word;
  max-width: 28rem;
  transition: color 0.35s ease;
}

/* Social icons */
#{{ section_id }} .ft-socials {
  display: flex;
  flex-wrap: wrap;
  gap: 1rem;
  align-items: center;
}

#{{ section_id }} .ft-social-link {
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--ft-muted);
  text-decoration: none;
  transition: color 0.25s ease, transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.25s ease;
  will-change: transform;
  {% if social_style == 'circle' %}
    width: 4rem;
    height: 4rem;
    border-radius: 50%;
    border: 1.5px solid var(--ft-border);
    background: transparent;
  {% else %}
    width: auto;
    height: auto;
    padding: 0.4rem;
  {% endif %}
}

#{{ section_id }} .ft-social-link:hover {
  color: var(--ft-accent);
  transform: translateY(-3px) scale(1.1);
  {% if social_style == 'circle' %}
    border-color: rgba(7, 209, 110, 0.55);
    box-shadow: 0 4px 18px rgba(7, 209, 110, 0.22);
  {% endif %}
}

#{{ section_id }} .ft-social-link svg {
  width: 1.8rem;
  height: 1.8rem;
  display: block;
  pointer-events: none;
  transition: filter 0.25s ease;
}

#{{ section_id }} .ft-social-link:hover svg {
  filter: drop-shadow(0 0 6px rgba(7, 209, 110, 0.5));
}

/* ══════════════════════════════════════════════════════
   BLOCKS GRID
══════════════════════════════════════════════════════ */
#{{ section_id }} .ft-blocks {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(min(190px, 100%), 1fr));
  gap: clamp(2.4rem, 3.5vw, 4rem) clamp(1.6rem, 2.5vw, 3rem);
  align-items: start;
}

/* ── Column heading ── */
#{{ section_id }} .ft-col-heading {
  font-family: 'Archivo Black', sans-serif;
  font-weight: 400;
  font-size: clamp(1rem, 1.1vw, 1.2rem);
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--ft-col-heading);
  margin-bottom: clamp(1.4rem, 2vw, 2rem);
  overflow-wrap: break-word;
  word-break: break-word;
  transition: color 0.35s ease;
  position: relative;
  padding-bottom: 1rem;
}

#{{ section_id }} .ft-col-heading::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  width: 2.4rem;
  height: 2px;
  background: var(--ft-accent);
  border-radius: 2px;
  transition: width 0.4s cubic-bezier(0.16, 1, 0.3, 1), background 0.35s ease;
}

#{{ section_id }} .ft-block:hover .ft-col-heading::after {
  width: 4.8rem;
}

/* ── Menu block ── */
#{{ section_id }} .ft-menu-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.9rem;
}

#{{ section_id }} .ft-menu-link {
  font-family: 'DM Sans', sans-serif;
  font-size: clamp(1.3rem, 1.35vw, 1.5rem);
  line-height: 1.5;
  color: var(--ft-link);
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  position: relative;
  overflow-wrap: break-word;
  word-break: break-word;
  transition: color 0.25s ease;
}

/* Draw-in underline on hover */
#{{ section_id }} .ft-menu-link::after {
  content: '';
  position: absolute;
  bottom: -1px;
  left: 0;
  width: 0;
  height: 1px;
  background: var(--ft-link-hover);
  transition: width 0.3s cubic-bezier(0.16, 1, 0.3, 1);
}

#{{ section_id }} .ft-menu-link:hover {
  color: var(--ft-link-hover);
}

#{{ section_id }} .ft-menu-link:hover::after {
  width: 100%;
}

/* ── Text block ── */
#{{ section_id }} .ft-text-content {
  font-family: 'DM Sans', sans-serif;
  font-size: clamp(1.3rem, 1.35vw, 1.5rem);
  line-height: 1.7;
  color: var(--ft-muted);
  overflow-wrap: break-word;
  word-break: break-word;
  transition: color 0.35s ease;
}

#{{ section_id }} .ft-text-content a {
  color: var(--ft-accent);
  text-decoration: none;
}

#{{ section_id }} .ft-text-content a:hover {
  text-decoration: underline;
}

/* ── Newsletter block ── */
#{{ section_id }} .ft-block--newsletter {
  grid-column: span 2;
}

@media (max-width: 480px) {
  #{{ section_id }} .ft-block--newsletter {
    grid-column: 1 / -1;
  }
}

#{{ section_id }} .ft-nl-desc {
  font-family: 'DM Sans', sans-serif;
  font-size: clamp(1.3rem, 1.35vw, 1.5rem);
  line-height: 1.65;
  color: var(--ft-muted);
  margin-bottom: 1.6rem;
  overflow-wrap: break-word;
  word-break: break-word;
  transition: color 0.35s ease;
}

#{{ section_id }} .ft-nl-field {
  display: flex;
  gap: 0;
  border: 1.5px solid var(--ft-border);
  border-radius: 99px;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.04);
  transition: border-color 0.3s ease, box-shadow 0.3s ease;
}

#{{ section_id }} .ft-nl-field:focus-within {
  border-color: rgba(7, 209, 110, 0.6);
  box-shadow: 0 0 0 3px rgba(7, 209, 110, 0.12);
}

#{{ section_id }} .ft-nl-input {
  flex: 1;
  background: transparent;
  border: none;
  outline: none;
  padding: 1.1rem 1.6rem;
  font-family: 'DM Sans', sans-serif;
  font-size: clamp(1.3rem, 1.35vw, 1.5rem);
  color: var(--ft-text);
  min-width: 0;
}

#{{ section_id }} .ft-nl-input::placeholder {
  color: var(--ft-muted);
}

#{{ section_id }} .ft-nl-btn {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  padding: 1rem 1.8rem;
  background: var(--ft-accent);
  color: #001a2e;
  border: none;
  cursor: pointer;
  font-family: 'DM Sans', sans-serif;
  font-size: clamp(1.1rem, 1.2vw, 1.3rem);
  font-weight: 700;
  letter-spacing: 0.04em;
  transition: background 0.25s ease, transform 0.25s ease, box-shadow 0.25s ease;
  will-change: transform;
  white-space: nowrap;
}

#{{ section_id }} .ft-nl-btn:hover {
  background: rgba(7, 209, 110, 0.85);
  transform: scale(1.04);
  box-shadow: 0 4px 20px rgba(7, 209, 110, 0.35);
}

#{{ section_id }} .ft-nl-btn svg {
  width: 1.6rem;
  height: 1.6rem;
  display: block;
  pointer-events: none;
}

#{{ section_id }} .ft-nl-error {
  font-family: 'DM Sans', sans-serif;
  font-size: clamp(1.1rem, 1.15vw, 1.25rem);
  color: #ff6b6b;
  margin-top: 0.8rem;
}

#{{ section_id }} .ft-nl-success {
  font-family: 'DM Sans', sans-serif;
  font-size: clamp(1.1rem, 1.15vw, 1.25rem);
  color: var(--ft-accent);
  margin-top: 0.8rem;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

#{{ section_id }} .ft-nl-success::before {
  content: '';
  display: inline-block;
  width: 0.8rem;
  height: 0.8rem;
  background: var(--ft-accent);
  border-radius: 50%;
}

/* ══════════════════════════════════════════════════════
   DIVIDER
══════════════════════════════════════════════════════ */
#{{ section_id }} .ft-divider {
  display: flex;
  align-items: center;
  gap: 1.2rem;
  padding: 0 clamp(1.6rem, 5vw, 8rem);
  margin-top: clamp(3rem, 5vw, 5rem);
  position: relative;
  z-index: 10;
}

#{{ section_id }} .ft-divider-line {
  flex: 1;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--ft-border), var(--ft-border), transparent);
  transition: background 0.35s ease;
}

#{{ section_id }} .ft-divider-accent {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  flex-shrink: 0;
}

#{{ section_id }} .ft-divider-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--ft-accent);
  box-shadow: 0 0 8px rgba(7, 209, 110, 0.6);
}

#{{ section_id }} .ft-divider-bar {
  width: 2.4rem;
  height: 2px;
  background: var(--ft-accent);
  border-radius: 2px;
  opacity: 0.7;
}

/* ══════════════════════════════════════════════════════
   BOTTOM BAR
══════════════════════════════════════════════════════ */
#{{ section_id }} .ft-bottom-bar {
  background: var(--ft-bottom-bg);
  border-top: 1px solid var(--ft-border);
  position: relative;
  z-index: 10;
  transition: background 0.35s ease, border-color 0.35s ease;
}

#{{ section_id }} .ft-bottom-inner {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: space-between;
  gap: 1.2rem 2rem;
  padding-top: clamp(1.6rem, 2vw, 2.2rem);
  padding-bottom: clamp(1.6rem, 2vw, 2.2rem);
}

#{{ section_id }} .ft-copyright {
  font-family: 'DM Sans', sans-serif;
  font-size: clamp(1.1rem, 1.15vw, 1.3rem);
  color: var(--ft-muted);
  overflow-wrap: break-word;
  word-break: break-word;
  transition: color 0.35s ease;
}

#{{ section_id }} .ft-copyright a {
  color: var(--ft-accent);
  text-decoration: none;
}

#{{ section_id }} .ft-copyright a:hover { text-decoration: underline; }

#{{ section_id }} .ft-bottom-right {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 1.6rem;
}

/* Policies */
#{{ section_id }} .ft-policies {
  display: flex;
  flex-wrap: wrap;
  gap: 0.6rem 1.4rem;
  list-style: none;
}

#{{ section_id }} .ft-policies a {
  font-family: 'DM Sans', sans-serif;
  font-size: clamp(1.1rem, 1.1vw, 1.25rem);
  color: var(--ft-muted);
  text-decoration: none;
  transition: color 0.25s ease;
}

#{{ section_id }} .ft-policies a:hover { color: var(--ft-accent); }

/* Payment icons */
#{{ section_id }} .ft-payment-list {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  align-items: center;
  list-style: none;
}

#{{ section_id }} .ft-payment-list .icon--full-color {
  width: 3.4rem;
  height: 2.2rem;
  border-radius: 4px;
  display: block;
  opacity: 0.7;
  transition: opacity 0.25s ease;
}

#{{ section_id }} .ft-payment-list li:hover .icon--full-color { opacity: 1; }

/* ══════════════════════════════════════════════════════
   SIGNAL SWEEP — reveal animations
══════════════════════════════════════════════════════ */
{% if enable_anims %}

#{{ section_id }} .ft-col-reveal {
  opacity: 0;
  transform: translateY(28px);
  transition: opacity 0.65s ease, transform 0.65s cubic-bezier(0.16, 1, 0.3, 1);
  will-change: transform;
}

#{{ section_id }}.ft-is-visible .ft-col-reveal,
.shopify-design-mode #{{ section_id }} .ft-col-reveal {
  opacity: 1;
  transform: translateY(0);
}

#{{ section_id }} .ft-bottom-bar {
  opacity: 0;
  transform: translateY(16px);
  transition: opacity 0.5s ease 0.5s, transform 0.5s ease 0.5s,
              background 0.35s ease, border-color 0.35s ease;
}

#{{ section_id }}.ft-is-visible .ft-bottom-bar,
.shopify-design-mode #{{ section_id }} .ft-bottom-bar {
  opacity: 1;
  transform: translateY(0);
}

@media (prefers-reduced-motion: reduce) {
  #{{ section_id }} .ft-col-reveal,
  #{{ section_id }} .ft-bottom-bar {
    opacity: 1;
    transform: none;
    transition: background 0.35s ease, border-color 0.35s ease, color 0.35s ease;
  }
}

{% else %}

#{{ section_id }} .ft-col-reveal { opacity: 1; transform: none; }

{% endif %}

/* ── Theme toggle transitions ── */
#{{ section_id }} .ft-brand,
#{{ section_id }} .ft-col-heading,
#{{ section_id }} .ft-tagline,
#{{ section_id }} .ft-menu-link,
#{{ section_id }} .ft-text-content,
#{{ section_id }} .ft-nl-desc,
#{{ section_id }} .ft-nl-field,
#{{ section_id }} .ft-nl-input,
#{{ section_id }} .ft-copyright,
#{{ section_id }} .ft-policies a,
#{{ section_id }} .ft-divider-line {
  transition: color 0.35s ease, background 0.35s ease, border-color 0.35s ease;
}

/* ══════════════════════════════════════════════════════
   RESPONSIVE
══════════════════════════════════════════════════════ */
@media (max-width: 768px) {
  #{{ section_id }} .ft-blocks {
    grid-template-columns: repeat(2, 1fr);
  }
  #{{ section_id }} .ft-bottom-inner {
    flex-direction: column;
    align-items: flex-start;
    gap: 1.2rem;
  }
  #{{ section_id }} .ft-bottom-right {
    width: 100%;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
  }
}

@media (max-width: 480px) {
  #{{ section_id }} .ft-blocks {
    grid-template-columns: 1fr;
  }
  #{{ section_id }} .ft-block--newsletter {
    grid-column: 1 / -1;
  }
  #{{ section_id }} .ft-nl-btn span { display: none; }
  #{{ section_id }} .ft-socials { gap: 0.8rem; }
  #{{ section_id }} .ft-social-link {
    width: 3.6rem;
    height: 3.6rem;
  }
}

@media (max-width: 300px) {
  #{{ section_id }} .ft-container { padding-inline: 1.2rem; }
  #{{ section_id }} .ft-divider { padding: 0 1.2rem; }
}

{% endstyle %}

<section
  id="{{ section_id }}"
  aria-label="{{ shop.name }} footer"
>

  <!-- Ambient glow blob -->
  <div class="ft-glow" aria-hidden="true"></div>

  <!-- Signal sweep line -->
  {% if enable_anims %}
    <div class="ft-scan-line" aria-hidden="true"></div>
  {% endif %}

  <!-- Side decorative image -->
  {% if side_image %}
    <div class="ft-side-img" aria-hidden="true">
      <img
        src="{{ side_image | image_url: width: 600 }}"
        alt=""
        loading="lazy"
        width="{{ side_image.width }}"
        height="{{ side_image.height }}"
      >
    </div>
  {% endif %}

  <!-- ── Main footer body ── -->
  <div class="ft-body">
    <div class="ft-container">
      <div class="ft-main">

        <!-- Brand column -->
        <div class="ft-brand ft-col-reveal">

          <!-- Logo -->
          {% if logo %}
            <a href="{{ routes.root_url }}" class="ft-logo-wrap" aria-label="{{ shop.name }} — home">
              <img
                class="ft-logo-dark"
                src="{{ logo | image_url: width: logo_size }}"
                srcset="{{ logo | image_url: width: logo_size }} 1x,
                        {{ logo | image_url: width: logo_size | times: 2 }} 2x"
                alt="{{ shop.name }}"
                width="{{ logo_size }}"
                height="auto"
                loading="lazy"
              >
              {% if logo_light %}
                <img
                  class="ft-logo-light"
                  src="{{ logo_light | image_url: width: logo_size }}"
                  alt="{{ shop.name }}"
                  width="{{ logo_size }}"
                  height="auto"
                  loading="lazy"
                >
              {% endif %}
            </a>
          {% else %}
            <a href="{{ routes.root_url }}" class="ft-logo-wrap" aria-label="{{ shop.name }}">
              <span style="font-family:'Archivo Black',sans-serif;font-weight:400;font-size:2.4rem;letter-spacing:-0.02em;color:var(--ft-text);">
                {{ shop.name }}
              </span>
            </a>
          {% endif %}

          <!-- Tagline -->
          {% if tagline != blank %}
            <p class="ft-tagline">{{ tagline | escape }}</p>
          {% endif %}

          <!-- Social icons -->
          {% if show_socials %}
            {%- assign has_social = false -%}
            {%- if ig_url != blank or fb_url != blank or yt_url != blank or tw_url != blank or tt_url != blank or wa_url != blank -%}
              {%- assign has_social = true -%}
            {%- endif -%}
            {% if has_social %}
              <div class="ft-socials" aria-label="Social media links">

                {% if ig_url != blank %}
                  <a href="{{ ig_url }}" class="ft-social-link" target="_blank" rel="noopener" aria-label="Instagram">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
                    </svg>
                  </a>
                {% endif %}

                {% if fb_url != blank %}
                  <a href="{{ fb_url }}" class="ft-social-link" target="_blank" rel="noopener" aria-label="Facebook">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
                    </svg>
                  </a>
                {% endif %}

                {% if yt_url != blank %}
                  <a href="{{ yt_url }}" class="ft-social-link" target="_blank" rel="noopener" aria-label="YouTube">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58 2.78 2.78 0 0 0 1.95 1.95C5.12 20 12 20 12 20s6.88 0 8.59-.47a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/>
                      <polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" fill="#001a2e"/>
                    </svg>
                  </a>
                {% endif %}

                {% if tw_url != blank %}
                  <a href="{{ tw_url }}" class="ft-social-link" target="_blank" rel="noopener" aria-label="Twitter / X">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                    </svg>
                  </a>
                {% endif %}

                {% if tt_url != blank %}
                  <a href="{{ tt_url }}" class="ft-social-link" target="_blank" rel="noopener" aria-label="TikTok">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.76a4.84 4.84 0 0 1-1.8-.07z"/>
                    </svg>
                  </a>
                {% endif %}

                {% if wa_url != blank %}
                  <a href="{{ wa_url }}" class="ft-social-link" target="_blank" rel="noopener" aria-label="WhatsApp">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26C3.16 6.43 7.58 2 13.032 2c2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/>
                    </svg>
                  </a>
                {% endif %}

              </div>
            {% endif %}
          {% endif %}

        </div><!-- /ft-brand -->

        <!-- ── Dynamic blocks ── -->
        {% if section.blocks.size > 0 %}
          <div class="ft-blocks">
            {%- for block in section.blocks -%}

              {%- case block.type -%}

                {%- when 'menu' -%}
                  <div class="ft-block ft-block--menu ft-col-reveal" {{ block.shopify_attributes }}>
                    {% if block.settings.heading != blank %}
                      <h3 class="ft-col-heading">{{ block.settings.heading | escape }}</h3>
                    {% endif %}
                    {% if block.settings.menu != blank %}
                      <ul class="ft-menu-list" role="list">
                        {% for link in block.settings.menu.links %}
                          <li>
                            <a href="{{ link.url }}" class="ft-menu-link">
                              {{- link.title -}}
                            </a>
                          </li>
                        {% endfor %}
                      </ul>
                    {% endif %}
                  </div>

                {%- when 'newsletter' -%}
                  <div class="ft-block ft-block--newsletter ft-col-reveal" {{ block.shopify_attributes }}>
                    {% if block.settings.heading != blank %}
                      <h3 class="ft-col-heading">{{ block.settings.heading | escape }}</h3>
                    {% endif %}
                    {% if block.settings.description != blank %}
                      <p class="ft-nl-desc">{{ block.settings.description | escape }}</p>
                    {% endif %}

                    {%- form 'customer', id: 'ft-nl-{{ block.id }}', class: 'ft-nl-form' -%}
                      <input type="hidden" name="contact[tags]" value="newsletter">
                      <div class="ft-nl-field">
                        <input
                          type="email"
                          name="contact[email]"
                          id="ft-email-{{ block.id }}"
                          class="ft-nl-input"
                          value="{{ form.email }}"
                          placeholder="{{ block.settings.email_placeholder | default: 'Enter your email' | escape }}"
                          autocomplete="email"
                          required
                          {% if form.errors %}aria-invalid="true"{% endif %}
                        >
                        <button type="submit" class="ft-nl-btn" aria-label="{{ block.settings.btn_label | default: 'Subscribe' | escape }}">
                          <span>{{ block.settings.btn_label | default: 'Subscribe' | escape }}</span>
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <line x1="22" y1="2" x2="11" y2="13"/>
                            <polygon points="22 2 15 22 11 13 2 9 22 2"/>
                          </svg>
                        </button>
                      </div>
                      {%- if form.errors -%}
                        <p class="ft-nl-error">{{ form.errors.translated_fields['email'] | capitalize }}: {{ form.errors.messages['email'] }}</p>
                      {%- endif -%}
                      {%- if form.posted_successfully? -%}
                        <p class="ft-nl-success">{{ block.settings.success_message | default: 'Thank you for subscribing!' | escape }}</p>
                      {%- endif -%}
                    {%- endform -%}
                  </div>

                {%- when 'text' -%}
                  <div class="ft-block ft-block--text ft-col-reveal" {{ block.shopify_attributes }}>
                    {% if block.settings.heading != blank %}
                      <h3 class="ft-col-heading">{{ block.settings.heading | escape }}</h3>
                    {% endif %}
                    {% if block.settings.content != blank %}
                      <div class="ft-text-content">{{ block.settings.content }}</div>
                    {% endif %}
                  </div>

              {%- endcase -%}

            {%- endfor -%}
          </div><!-- /ft-blocks -->
        {% endif %}

      </div><!-- /ft-main -->
    </div><!-- /ft-container -->

    <!-- ── Divider ── -->
    <div class="ft-divider" aria-hidden="true">
      <span class="ft-divider-line"></span>
      <span class="ft-divider-accent">
        <span class="ft-divider-bar"></span>
        <span class="ft-divider-dot"></span>
        <span class="ft-divider-bar"></span>
      </span>
      <span class="ft-divider-line"></span>
    </div>

  </div><!-- /ft-body -->

  <!-- ══════════════════════════════════════════
       BOTTOM BAR
  ══════════════════════════════════════════ -->
  <div class="ft-bottom-bar">
    <div class="ft-container">
      <div class="ft-bottom-inner">

        <!-- Copyright -->
        <p class="ft-copyright">
          &copy; {{ 'now' | date: '%Y' }}
          <a href="{{ routes.root_url }}">{{ shop.name }}</a>.
          {{ copyright_text | escape }}
          {% if show_powered %}
            &nbsp;&middot;&nbsp;{{ powered_by_link }}
          {% endif %}
        </p>

        <div class="ft-bottom-right">

          <!-- Policies -->
          {% if show_policies and shop.policies.size > 0 %}
            <ul class="ft-policies" role="list">
              {%- for policy in shop.policies -%}
                {%- if policy != blank -%}
                  <li><a href="{{ policy.url }}">{{ policy.title | escape }}</a></li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          {% endif %}

          <!-- Payment icons -->
          {% if show_payment and shop.enabled_payment_types.size > 0 %}
            <ul class="ft-payment-list" role="list" aria-label="Accepted payment methods">
              {%- for type in shop.enabled_payment_types -%}
                <li>{{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}</li>
              {%- endfor -%}
            </ul>
          {% endif %}

        </div><!-- /ft-bottom-right -->

      </div><!-- /ft-bottom-inner -->
    </div><!-- /ft-container -->
  </div><!-- /ft-bottom-bar -->

</section>

<script>
(function () {
  var SECTION = document.getElementById('{{ section_id }}');
  if (!SECTION) return;

  // ── Signal Sweep: reveal when footer enters viewport ───────────
  var sweepObs = new IntersectionObserver(function (entries, obs) {
    entries.forEach(function (entry) {
      if (entry.isIntersecting) {
        SECTION.classList.add('ft-is-visible');
        obs.disconnect();
      }
    });
  }, { threshold: 0.08 });
  sweepObs.observe(SECTION);

  // ── Theme color map (Liquid bakes values at render time) ──────
  var FT_DARK = {
    bg: '{{ bg_dark }}', text: '{{ text_dark }}', accent: '{{ accent_dark }}',
    border: '{{ border_dark }}', muted: '{{ muted_dark }}',
    bottomBg: '{{ bottom_bg_dark }}', heading: '{{ heading_color }}', link: '{{ link_color }}'
  };
  var FT_LIGHT = {
    bg: '{{ bg_light }}', text: '{{ text_light }}', accent: '{{ accent_light }}',
    border: '{{ border_light }}', muted: '{{ muted_light }}',
    bottomBg: '{{ bottom_bg_light }}', heading: '{{ text_light }}', link: '#336870'
  };

  function applyFooterTheme() {
    var isLight = document.documentElement.getAttribute('data-theme') === 'light';
    var c = isLight ? FT_LIGHT : FT_DARK;
    // Set CSS vars directly on section (inline > stylesheet — wins regardless of theme CSS)
    SECTION.style.setProperty('--ft-bg',          c.bg);
    SECTION.style.setProperty('--ft-text',        c.text);
    SECTION.style.setProperty('--ft-accent',      c.accent);
    SECTION.style.setProperty('--ft-border',      c.border);
    SECTION.style.setProperty('--ft-muted',       c.muted);
    SECTION.style.setProperty('--ft-bottom-bg',   c.bottomBg);
    SECTION.style.setProperty('--ft-col-heading', c.heading);
    SECTION.style.setProperty('--ft-link',        c.link);
    // Also set background-color / color directly so theme CSS cannot override
    SECTION.style.backgroundColor = c.bg;
    SECTION.style.color            = c.text;
    var bar = SECTION.querySelector('.ft-bottom-bar');
    if (bar) {
      bar.style.background    = c.bottomBg;
      bar.style.borderTopColor = c.border;
    }
  }

  // Sync immediately to current theme (header anti-FOUC already set data-theme)
  applyFooterTheme();

  // Re-sync on every toggle
  var themeObs = new MutationObserver(applyFooterTheme);
  themeObs.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

  {% if enable_anims %}
  // ── Stagger column reveals ─────────────────────────────────────
  SECTION.querySelectorAll('.ft-col-reveal').forEach(function (el, i) {
    el.style.transitionDelay = (0.1 + i * 0.09) + 's';
  });

  // ── Newsletter: client-side email validation ───────────────────
  SECTION.querySelectorAll('.ft-nl-form').forEach(function (form) {
    var input   = form.querySelector('.ft-nl-input');
    var errEl   = form.querySelector('.ft-nl-error');
    var successEl = form.querySelector('.ft-nl-success');

    form.addEventListener('submit', function (e) {
      if (!input) return;
      var val = input.value.trim();
      var valid = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(val);
      if (!valid) {
        e.preventDefault();
        if (errEl) {
          errEl.textContent = 'Please enter a valid email address.';
          errEl.style.display = 'block';
        }
        input.focus();
      } else {
        if (errEl) errEl.style.display = 'none';
      }
    });

    if (input && errEl) {
      input.addEventListener('input', function () {
        errEl.style.display = 'none';
      });
    }
  });
  {% endif %}
})();
</script>

