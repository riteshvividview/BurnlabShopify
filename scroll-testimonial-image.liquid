        },
        {
          "type": "select",
          "id": "hover_position",
          "label": "Testimonial Position",
          "options": [
            { "value": "top",    "label": "Top" },
            { "value": "center", "label": "Center" },
            { "value": "bottom", "label": "Bottom" }
          ],
          "default": "bottom"
        },
        {
          "type": "range",
