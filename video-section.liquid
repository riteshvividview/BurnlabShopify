{% comment %}
  ============================================================
  BURNLAB — Video Section
  Supports: Shopify OS 2.0 | Min Width: 300px
  ============================================================
{% endcomment %}

{%- liquid
  assign section_id = 'burnlab-video-' | append: section.id

  assign above_eyebrow     = section.settings.above_eyebrow
  assign above_heading     = section.settings.above_heading
  assign above_description = section.settings.above_description
  assign text_align_above  = section.settings.text_align_above  | default: 'center'

  assign video_url         = section.settings.video_url
  assign video_poster      = section.settings.video_poster
  assign video_layout      = section.settings.video_layout      | default: 'boxed'
  assign video_max_width   = section.settings.video_max_width   | default: 1200
  assign video_aspect      = section.settings.video_aspect      | default: '16/9'
  assign video_radius      = section.settings.video_radius      | default: 16
  assign video_opacity     = section.settings.video_opacity     | default: 100
  assign video_autoplay    = section.settings.video_autoplay
  assign video_loop        = section.settings.video_loop
  assign video_muted       = section.settings.video_muted
  assign video_controls    = section.settings.video_controls

  assign overlay_title     = section.settings.overlay_title
  assign overlay_desc      = section.settings.overlay_desc
  assign overlay_position  = section.settings.overlay_position  | default: 'bottom-left'
  assign overlay_text_color     = section.settings.overlay_text_color     | default: '#eaf4f5'
  assign overlay_bg_color       = section.settings.overlay_bg_color       | default: '#001a2e'
  assign overlay_bg_opacity     = section.settings.overlay_bg_opacity     | default: 50
  assign overlay_heading_size   = section.settings.overlay_heading_size   | default: 32
  assign overlay_heading_size_mob = section.settings.overlay_heading_size_mob | default: 22

  assign heading_size      = section.settings.heading_size      | default: 52
  assign heading_size_mob  = section.settings.heading_size_mob  | default: 32

  assign bg_type           = section.settings.bg_type           | default: 'color'
  assign bg_color          = section.settings.bg_color          | default: '#001a2e'
  assign bg_gradient       = section.settings.bg_gradient       | default: 'linear-gradient(135deg, #001a2e 0%, #0a3d55 50%, #001a2e 100%)'
  assign bg_image          = section.settings.bg_image
  assign bg_image_pos      = section.settings.bg_image_pos      | default: 'center center'
  assign bg_video_url      = section.settings.bg_video_url
  assign bg_overlay_color  = section.settings.bg_overlay_color  | default: '#001a2e'
  assign bg_overlay_opacity = section.settings.bg_overlay_opacity | default: 40

  assign text_color        = section.settings.text_color        | default: '#eaf4f5'
  assign accent_color      = section.settings.accent_color      | default: '#07d16e'

  assign enable_animations = section.settings.enable_animations

  assign overlay_text_align = 'left'
  if overlay_position contains 'center'
    assign overlay_text_align = 'center'
  elsif overlay_position contains 'right'
    assign overlay_text_align = 'right'
  endif

  assign show_above = false
  if above_eyebrow != blank or above_heading != blank or above_description != blank
    assign show_above = true
  endif

  assign show_overlay = false
  if overlay_title != blank or overlay_desc != blank
    assign show_overlay = true
  endif
-%}

<style>
  #{{ section_id }} *, #{{ section_id }} *::before, #{{ section_id }} *::after {
    box-sizing: border-box; margin: 0; padding: 0;
  }

  #{{ section_id }} {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    background-color: var(--vs-bg-color, {{ bg_color }});
    {% if bg_type == 'gradient' and bg_gradient != blank %}
    background: {{ bg_gradient }};
    {% endif %}
    color: var(--vs-text-color, {{ text_color }});
  }

  /* ── Section background layers ───────────────────────── */
  #{{ section_id }} .bl-sec-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  #{{ section_id }} .bl-sec-bg__img,
  #{{ section_id }} .bl-sec-bg__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: {{ bg_image_pos }};
    display: block;
  }
  #{{ section_id }} .bl-sec-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: {{ bg_overlay_color }};
    opacity: {{ bg_overlay_opacity | divided_by: 100.0 }};
    pointer-events: none;
  }

  /* ── Decorative glows (z-index 2) ─────────────────────── */
  #{{ section_id }} .bl-vs__glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(90px);
    pointer-events: none;
    z-index: 2;
    will-change: transform;
  }
  #{{ section_id }} .bl-vs__glow--1 {
    width: clamp(300px, 40vw, 600px);
    height: clamp(200px, 28vw, 400px);
    background: radial-gradient(ellipse, {{ accent_color }}1a 0%, transparent 70%);
    top: -8%;
    right: -4%;
  }
  #{{ section_id }} .bl-vs__glow--2 {
    width: clamp(240px, 32vw, 500px);
    height: clamp(180px, 24vw, 350px);
    background: radial-gradient(ellipse, #33687026 0%, transparent 70%);
    bottom: -6%;
    left: -4%;
  }

  /* ── Above-video zone ─────────────────────────────────── */
  #{{ section_id }} .bl-vs__above-zone {
    position: relative;
    z-index: 10;
    max-width: 1400px;
    margin-inline: auto;
    padding-inline: clamp(1.6rem, 5vw, 8rem);
    margin-bottom: clamp(2.4rem, 4vw, 4rem);
  }
  #{{ section_id }} .bl-vs__above {
    display: flex;
    flex-direction: column;
    gap: clamp(0.8rem, 1.5vw, 1.4rem);
    text-align: {{ text_align_above }};
    {% if text_align_above == 'center' %}
    align-items: center;
    max-width: 760px;
    margin-inline: auto;
    {% elsif text_align_above == 'right' %}
    align-items: flex-end;
    {% else %}
    align-items: flex-start;
    {% endif %}
  }
  #{{ section_id }} .bl-vs__above-heading {
    font-family: var(--bl-font-primary, 'Archivo Black', sans-serif);
    font-weight: 400;
    font-size: clamp({{ heading_size_mob }}px, 5vw, {{ heading_size }}px);
    line-height: 1.05;
    letter-spacing: -0.025em;
    color: var(--vs-text-color, {{ text_color }});
    overflow-wrap: break-word;
    word-break: break-word;
  }
  #{{ section_id }} .bl-vs__above-desc {
    font-family: var(--bl-font-secondary, 'DM Sans', sans-serif);
    font-size: clamp(1.3rem, 1.5vw, 1.6rem);
    line-height: 1.7;
    color: var(--vs-text-color, {{ text_color }});
    opacity: 0.78;
    overflow-wrap: break-word;
    word-break: break-word;
    max-width: 620px;
  }

  /* ── Video zone ───────────────────────────────────────── */
  #{{ section_id }} .bl-vs__video-zone {
    position: relative;
    z-index: 10;
  }
  #{{ section_id }} .bl-vs__video-zone--boxed {
    max-width: 1400px;
    margin-inline: auto;
    padding-inline: clamp(1.6rem, 5vw, 8rem);
  }
  #{{ section_id }} .bl-vs__video-outer {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: {{ video_radius }}px;
  }
  #{{ section_id }} .bl-vs__video-zone--boxed .bl-vs__video-outer {
    max-width: var(--vs-video-max-width, {{ video_max_width }}px);
    margin-inline: auto;
  }
  #{{ section_id }} .bl-vs__video-zone--full .bl-vs__video-outer {
    border-radius: 0;
    max-width: none;
  }

  /* ── Video inner & element ────────────────────────────── */
  #{{ section_id }} .bl-vs__video-inner {
    position: relative;
    width: 100%;
    aspect-ratio: {{ video_aspect }};
    background: #060f18;
    overflow: hidden;
  }
  #{{ section_id }} .bl-vs__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    opacity: var(--vs-video-opacity, 1);
    will-change: transform;
  }

  /* ── Placeholder ──────────────────────────────────────── */
  #{{ section_id }} .bl-vs__placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #0a2030;
  }
  #{{ section_id }} .bl-vs__placeholder svg {
    width: 100%;
    height: 100%;
    opacity: 0.25;
    object-fit: cover;
  }

  /* ── Overlay text container ───────────────────────────── */
  #{{ section_id }} .bl-vs__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    padding: clamp(1.4rem, 2.5vw, 2.4rem);
    z-index: 5;
    pointer-events: none;
  }
  #{{ section_id }} .bl-vs__overlay--top-left     { align-items: flex-start; justify-content: flex-start; }
  #{{ section_id }} .bl-vs__overlay--top-center   { align-items: flex-start; justify-content: center; }
  #{{ section_id }} .bl-vs__overlay--top-right    { align-items: flex-start; justify-content: flex-end; }
  #{{ section_id }} .bl-vs__overlay--center-left  { align-items: center;     justify-content: flex-start; }
  #{{ section_id }} .bl-vs__overlay--center       { align-items: center;     justify-content: center; }
  #{{ section_id }} .bl-vs__overlay--center-right { align-items: center;     justify-content: flex-end; }
  #{{ section_id }} .bl-vs__overlay--bottom-left  { align-items: flex-end;   justify-content: flex-start; }
  #{{ section_id }} .bl-vs__overlay--bottom-center{ align-items: flex-end;   justify-content: center; }
  #{{ section_id }} .bl-vs__overlay--bottom-right { align-items: flex-end;   justify-content: flex-end; }

  #{{ section_id }} .bl-vs__overlay-content {
    position: relative;
    isolation: isolate;
    max-width: min(460px, 85%);
    padding: clamp(1rem, 1.8vw, 1.8rem) clamp(1.2rem, 2vw, 2rem);
    border-radius: 12px;
    text-align: {{ overlay_text_align }};
    pointer-events: auto;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }
  #{{ section_id }} .bl-vs__overlay-content::before {
    content: '';
    position: absolute;
    inset: 0;
    background: {{ overlay_bg_color }};
    opacity: {{ overlay_bg_opacity | divided_by: 100.0 }};
    border-radius: inherit;
    z-index: -1;
  }
  #{{ section_id }} .bl-vs__overlay-title {
    font-family: var(--bl-font-primary, 'Archivo Black', sans-serif);
    font-weight: 400;
    font-size: clamp({{ overlay_heading_size_mob }}px, 2.5vw, {{ overlay_heading_size }}px);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: {{ overlay_text_color }};
    overflow-wrap: break-word;
    word-break: break-word;
    margin-bottom: 0.4em;
  }
  #{{ section_id }} .bl-vs__overlay-desc {
    font-family: var(--bl-font-secondary, 'DM Sans', sans-serif);
    font-size: clamp(1.1rem, 1.2vw, 1.35rem);
    line-height: 1.65;
    color: {{ overlay_text_color }};
    opacity: 0.85;
    overflow-wrap: break-word;
    word-break: break-word;
  }

  /* ── Play button ──────────────────────────────────────── */
  #{{ section_id }} .bl-vs__play-btn {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: none;
    cursor: pointer;
    z-index: 8;
    padding: 0;
    transition: opacity 0.4s ease;
  }
  #{{ section_id }} .bl-vs__play-btn.is-playing {
    opacity: 0;
    pointer-events: none;
  }
  #{{ section_id }} .bl-vs__play-icon {
    position: relative;
    width: clamp(56px, 7vw, 80px);
    height: clamp(56px, 7vw, 80px);
    border-radius: 50%;
    background: {{ accent_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s ease;
    will-change: transform;
    box-shadow: 0 0 32px {{ accent_color }}55, 0 8px 24px rgba(0,0,0,0.45);
  }
  #{{ section_id }} .bl-vs__play-btn:hover .bl-vs__play-icon {
    transform: scale(1.12);
    box-shadow: 0 0 48px {{ accent_color }}77, 0 12px 32px rgba(0,0,0,0.5);
  }
  #{{ section_id }} .bl-vs__play-icon svg {
    width: 36%;
    height: 36%;
    fill: #001a2e;
    margin-left: 4px;
    flex-shrink: 0;
  }
  #{{ section_id }} .bl-vs__play-ring {
    position: absolute;
    inset: -10px;
    border-radius: 50%;
    border: 2px solid {{ accent_color }}55;
    animation: bl-vs-pulse 2.2s ease-out infinite;
    pointer-events: none;
  }
  @keyframes bl-vs-pulse {
    0%   { transform: scale(1);   opacity: 0.7; }
    100% { transform: scale(1.6); opacity: 0; }
  }

  /* ── Animations ───────────────────────────────────────── */
  {% if enable_animations %}

  #{{ section_id }} .bl-vs__above {
    opacity: 0;
    transform: translateY(22px);
    will-change: transform, opacity;
    transition: opacity 0.75s ease, transform 0.75s cubic-bezier(0.16, 1, 0.3, 1);
  }
  #{{ section_id }}.is-visible .bl-vs__above,
  .shopify-design-mode #{{ section_id }} .bl-vs__above {
    opacity: 1;
    transform: translateY(0);
  }

  #{{ section_id }} .bl-vs__video-outer {
    clip-path: inset(8% 4% 8% 4% round {{ video_radius }}px);
    opacity: 0;
    will-change: clip-path, opacity;
    transition: clip-path 1.3s cubic-bezier(0.16, 1, 0.3, 1) 0.25s,
                opacity 0.55s ease 0.1s;
  }
  #{{ section_id }} .bl-vs__video-zone--full .bl-vs__video-outer {
    clip-path: inset(8% 0% 8% 0% round 0px);
  }
  #{{ section_id }}.is-visible .bl-vs__video-outer,
  .shopify-design-mode #{{ section_id }} .bl-vs__video-outer {
    clip-path: inset(0% 0% 0% 0% round {{ video_radius }}px);
    opacity: 1;
  }
  #{{ section_id }}.is-visible .bl-vs__video-zone--full .bl-vs__video-outer,
  .shopify-design-mode #{{ section_id }} .bl-vs__video-zone--full .bl-vs__video-outer {
    clip-path: inset(0% 0% 0% 0% round 0px);
  }

  #{{ section_id }} .bl-vs__overlay-content {
    opacity: 0;
    transform: translateY(10px);
    will-change: transform, opacity;
    transition: opacity 0.6s ease 1.1s, transform 0.6s cubic-bezier(0.16, 1, 0.3, 1) 1.1s;
  }
  #{{ section_id }}.is-visible .bl-vs__overlay-content,
  .shopify-design-mode #{{ section_id }} .bl-vs__overlay-content {
    opacity: 1;
    transform: translateY(0);
  }

  #{{ section_id }} .bl-reveal,
  #{{ section_id }} .bl-reveal--left,
  #{{ section_id }} .bl-reveal--right,
  #{{ section_id }} .bl-reveal--scale {
    opacity: 0;
    will-change: transform, opacity;
  }
  #{{ section_id }}.is-visible .bl-reveal,
  #{{ section_id }}.is-visible .bl-reveal--left,
  #{{ section_id }}.is-visible .bl-reveal--right,
  #{{ section_id }}.is-visible .bl-reveal--scale,
  .shopify-design-mode #{{ section_id }} .bl-reveal,
  .shopify-design-mode #{{ section_id }} .bl-reveal--left,
  .shopify-design-mode #{{ section_id }} .bl-reveal--right,
  .shopify-design-mode #{{ section_id }} .bl-reveal--scale {
    opacity: 1;
    transform: none;
  }

  @media (prefers-reduced-motion: reduce) {
    #{{ section_id }} .bl-vs__video-outer,
    #{{ section_id }} .bl-vs__above,
    #{{ section_id }} .bl-vs__overlay-content,
    #{{ section_id }} .bl-reveal,
    #{{ section_id }} .bl-reveal--left,
    #{{ section_id }} .bl-reveal--right,
    #{{ section_id }} .bl-reveal--scale {
      opacity: 1 !important;
      transform: none !important;
      clip-path: none !important;
      transition: none !important;
    }
    #{{ section_id }} .bl-vs__play-ring {
      animation: none !important;
    }
  }

  {% else %}

  @media (prefers-reduced-motion: reduce) {
    #{{ section_id }} .bl-vs__play-ring { animation: none !important; }
  }

  {% endif %}

  /* ── Responsive ───────────────────────────────────────── */
  @media (max-width: 1024px) {
    #{{ section_id }} .bl-vs__above {
      max-width: 100%;
    }
  }

  @media (max-width: 768px) {
    #{{ section_id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px !important;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px !important;
    }
    #{{ section_id }} .bl-vs__above-zone {
      margin-bottom: clamp(1.8rem, 4vw, 3rem);
    }
    #{{ section_id }} .bl-vs__overlay-content {
      max-width: 88%;
    }
  }

  @media (max-width: 480px) {
    #{{ section_id }} .bl-vs__above-heading {
      font-size: clamp(2rem, 8vw, 3rem) !important;
    }
    #{{ section_id }} .bl-vs__overlay-title {
      font-size: clamp(1.6rem, 6vw, 2.4rem) !important;
    }
    #{{ section_id }} .bl-vs__overlay {
      padding: 1rem;
    }
    #{{ section_id }} .bl-vs__overlay-content {
      max-width: 92%;
    }
    #{{ section_id }} .bl-vs__play-icon {
      width: 56px;
      height: 56px;
    }
    #{{ section_id }} .bl-vs__above {
      text-align: left;
      align-items: flex-start;
    }
  }
</style>

<section
  id="{{ section_id }}"
  style="
    --vs-text-color: {{ text_color }};
    --vs-accent-color: {{ accent_color }};
    --vs-bg-color: {{ bg_color }};
    --vs-video-opacity: {{ video_opacity | divided_by: 100.0 }};
    --vs-overlay-bg: {{ overlay_bg_color }};
    --vs-overlay-text: {{ overlay_text_color }};
    --vs-radius: {{ video_radius }}px;
    --vs-video-max-width: {{ video_max_width }}px;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>

  {%- if bg_type == 'image' and bg_image != blank -%}
    <div class="bl-sec-bg" aria-hidden="true">
      <img
        class="bl-sec-bg__img"
        src="{{ bg_image | image_url: width: 2000 }}"
        srcset="{{ bg_image | image_url: width: 800 }} 800w,
                {{ bg_image | image_url: width: 1200 }} 1200w,
                {{ bg_image | image_url: width: 2000 }} 2000w"
        sizes="100vw"
        alt=""
        loading="lazy"
        width="2000"
        height="1200"
      >
    </div>
  {%- elsif bg_type == 'video' and bg_video_url != blank -%}
    <div class="bl-sec-bg" aria-hidden="true">
      <video class="bl-sec-bg__video" autoplay muted loop playsinline preload="metadata">
        <source src="{{ bg_video_url }}" type="video/mp4">
      </video>
    </div>
  {%- endif -%}

  {%- if bg_type != 'color' and bg_overlay_opacity > 0 -%}
    <div class="bl-sec-overlay" aria-hidden="true"></div>
  {%- endif -%}

  <div class="bl-vs__glow bl-vs__glow--1" aria-hidden="true"></div>
  <div class="bl-vs__glow bl-vs__glow--2" aria-hidden="true"></div>

  {%- if show_above -%}
    <div class="bl-vs__above-zone">
      <div class="bl-vs__above">
        {%- if above_eyebrow != blank -%}
          <span class="bl-eyebrow">{{ above_eyebrow | escape }}</span>
        {%- endif -%}
        {%- if above_heading != blank -%}
          <h2 class="bl-vs__above-heading">{{ above_heading | escape }}</h2>
        {%- endif -%}
        {%- if above_description != blank -%}
          <p class="bl-vs__above-desc">{{ above_description | escape }}</p>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}

  <div class="bl-vs__video-zone{% if video_layout == 'full' %} bl-vs__video-zone--full{% else %} bl-vs__video-zone--boxed{% endif %}">
    <div class="bl-vs__video-outer">
      <div class="bl-vs__video-inner">

        {%- if video_url != blank -%}
          <video
            class="bl-vs__video"
            {% if video_autoplay %}autoplay{% endif %}
            {% if video_muted or video_autoplay %}muted{% endif %}
            {% if video_loop %}loop{% endif %}
            {% if video_controls %}controls{% endif %}
            playsinline
            preload="metadata"
            {% if video_poster != blank %}poster="{{ video_poster | image_url: width: 1600 }}"{% endif %}
          >
            <source src="{{ video_url }}" type="video/mp4">
          </video>
        {%- else -%}
          <div class="bl-vs__placeholder">
            {{ 'lifestyle-1' | placeholder_svg_tag: 'bl-placeholder-svg' }}
          </div>
        {%- endif -%}

        {%- if show_overlay -%}
          <div class="bl-vs__overlay bl-vs__overlay--{{ overlay_position }}">
            <div class="bl-vs__overlay-content">
              {%- if overlay_title != blank -%}
                <p class="bl-vs__overlay-title">{{ overlay_title | escape }}</p>
              {%- endif -%}
              {%- if overlay_desc != blank -%}
                <p class="bl-vs__overlay-desc">{{ overlay_desc | escape }}</p>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}

        {%- unless video_autoplay -%}
          {%- if video_url != blank -%}
            <button class="bl-vs__play-btn" aria-label="Play video" type="button">
              <span class="bl-vs__play-icon">
                <span class="bl-vs__play-ring" aria-hidden="true"></span>
                <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg">
                  <path d="M8 5v14l11-7z"/>
                </svg>
              </span>
            </button>
          {%- endif -%}
        {%- endunless -%}

      </div>
    </div>
  </div>

</section>

{% if enable_animations %}
<script>
(function() {
  var section = document.getElementById('{{ section_id }}');
  if (!section) return;

  function initReveal() {
    var sectionObserver = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          sectionObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.08 });
    sectionObserver.observe(section);

    var revealEls = section.querySelectorAll('.bl-reveal, .bl-reveal--left, .bl-reveal--right, .bl-reveal--scale');
    if (revealEls.length) {
      var elObserver = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            elObserver.unobserve(entry.target);
          }
        });
      }, { threshold: 0.15 });
      revealEls.forEach(function(el) { elObserver.observe(el); });
    }

    if (window.Shopify && window.Shopify.designMode) {
      document.addEventListener('shopify:section:load', function(e) {
        if (e.detail && e.detail.sectionId === '{{ section.id }}') {
          section.classList.add('is-visible');
        }
      });
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initReveal);
  } else {
    initReveal();
  }
})();
</script>
{% endif %}

<script>
(function() {
  var section = document.getElementById('{{ section_id }}');
  if (!section) return;

  function initPlayer() {
    var playBtn = section.querySelector('.bl-vs__play-btn');
    var video   = section.querySelector('.bl-vs__video');
    if (!playBtn || !video) return;

    playBtn.addEventListener('click', function() {
      video.muted = false;
      var p = video.play();
      if (p !== undefined) {
        p.then(function() {
          playBtn.classList.add('is-playing');
          {% if video_controls %}video.controls = true;{% endif %}
        }).catch(function() {
          video.muted = true;
          video.play().then(function() {
            playBtn.classList.add('is-playing');
            {% if video_controls %}video.controls = true;{% endif %}
          }).catch(function() {});
        });
      } else {
        playBtn.classList.add('is-playing');
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPlayer);
  } else {
    initPlayer();
  }
})();
</script>

