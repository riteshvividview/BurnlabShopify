{% comment %}
  ============================================================
  BURNLAB — COLLECTION LIST
  Supports: Shopify OS 2.0 | Min Width: 300px
  ============================================================
{% endcomment %}

{%- liquid
  assign section_id      = 'burnlab-clist-' | append: section.id
  assign eyebrow         = section.settings.eyebrow         | default: 'Shop By Category'
  assign heading         = section.settings.heading         | default: 'Our Collections'
  assign subtitle        = section.settings.subtitle        | default: 'Explore a curated selection of collections to find exactly what you are looking for'
  assign show_hdr        = section.settings.show_header
  assign hdr_align       = section.settings.header_align    | default: 'center'
  assign bg_type         = section.settings.bg_type         | default: 'pale'
  assign bg_custom       = section.settings.bg_custom       | default: '#001a2e'
  assign text_color      = section.settings.text_color      | default: '#001a2e'
  assign accent_color    = section.settings.accent_color    | default: '#07d16e'
  assign col_desktop     = section.settings.columns_desktop | default: 4
  assign col_tablet      = section.settings.columns_tablet  | default: 2
  assign card_gap        = section.settings.card_gap        | default: 20
  assign card_radius     = section.settings.card_radius     | default: 16
  assign card_style      = section.settings.card_style      | default: 'overlay'
  assign aspect_ratio    = section.settings.aspect_ratio    | default: '3/4'
  assign overlay_opacity = section.settings.overlay_opacity | default: 75 | divided_by: 100.0
  assign overlay_color   = section.settings.overlay_color   | default: '#001a2e'
  assign img_hover       = section.settings.img_hover       | default: 'zoom'
  assign show_shop_cta   = section.settings.show_shop_cta
  assign shop_cta_label  = section.settings.shop_cta_label  | default: 'Shop Now'
  assign enable_bg_text  = section.settings.enable_bg_text
  assign bg_text_val     = section.settings.bg_text_val     | default: 'COLLECTIONS'
  assign enable_grain    = section.settings.enable_grain
  assign enable_glows    = section.settings.enable_glows
  assign enable_anim     = section.settings.enable_animations
  assign heading_size    = section.settings.heading_size    | default: 48
  assign subtitle_size   = section.settings.subtitle_size   | default: 16
  assign card_title_size = section.settings.card_title_size | default: 18
  assign below_bg        = section.settings.below_bg_color  | default: '#001a2e'

  if bg_type == 'navy'
    assign resolved_bg = '#001a2e'
  elsif bg_type == 'teal'
    assign resolved_bg = '#336870'
  elsif bg_type == 'custom'
    assign resolved_bg = bg_custom
  else
    assign resolved_bg = '#eaf4f5'
  endif
-%}

<style>
  /* ── CSS VARIABLES ─────────────────────────────────────── */
  #{{ section_id }} {
    --bl-green:         {{ accent_color }};
    --bl-navy:          #001a2e;
    --bl-pale:          #eaf4f5;
    --bl-teal:          #336870;
    --font-primary:     'Archivo Black', sans-serif;
    --font-secondary:   'DM Sans', sans-serif;
    --ease-expo:        cubic-bezier(0.16, 1, 0.3, 1);
    --ease-back:        cubic-bezier(0.34, 1.56, 0.64, 1);
    --section-bg:       {{ resolved_bg }};
    --section-text:     {{ text_color }};
    --section-accent:   {{ accent_color }};
    --col-desktop:      {{ col_desktop }};
    --col-tablet:       {{ col_tablet }};
    --card-gap:         {{ card_gap }}px;
    --card-radius:      {{ card_radius }}px;
    --overlay-color:    {{ overlay_color }};
    --overlay-opacity:  {{ overlay_opacity }};
    --below-bg:         {{ below_bg }};
  }

  /* ── RESET ─────────────────────────────────────────────── */
  #{{ section_id }} *, #{{ section_id }} *::before, #{{ section_id }} *::after {
    box-sizing: border-box; margin: 0; padding: 0;
  }

  /* ── SECTION SHELL ──────────────────────────────────────── */
  #{{ section_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    background-color: var(--section-bg);
    color: var(--section-text);
    isolation: isolate;
  }

  /* ── GRAIN ──────────────────────────────────────────────── */
  #{{ section_id }} .clist-grain {
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
    background-size: 220px;
    opacity: 0.35;
    pointer-events: none;
    z-index: 2;
  }

  /* ── AMBIENT GLOWS ──────────────────────────────────────── */
  #{{ section_id }} .clist-glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(110px);
    pointer-events: none;
    z-index: 1;
    will-change: transform;
  }
  #{{ section_id }} .clist-glow--a {
    width: clamp(180px, 35vw, 440px);
    height: clamp(180px, 35vw, 440px);
    background: var(--section-accent);
    opacity: 0.07;
    top: -8%;
    left: -4%;
    animation: clistGlowA 14s ease-in-out infinite alternate;
  }
  #{{ section_id }} .clist-glow--b {
    width: clamp(140px, 28vw, 360px);
    height: clamp(140px, 28vw, 360px);
    background: var(--bl-teal);
    opacity: 0.08;
    bottom: -4%;
    right: -2%;
    animation: clistGlowB 17s ease-in-out infinite alternate;
  }
  @keyframes clistGlowA {
    from { transform: translate(0,0) scale(1); }
    to   { transform: translate(35px,-25px) scale(1.12); }
  }
  @keyframes clistGlowB {
    from { transform: translate(0,0) scale(1); }
    to   { transform: translate(-28px,20px) scale(1.1); }
  }

  /* ── BACKGROUND WATERMARK TEXT ──────────────────────────── */
  #{{ section_id }} .clist-bg-text {
    position: absolute;
    top: 50%;
    left: 0;
    white-space: nowrap;
    font-family: var(--font-primary);
    font-weight: 400;
    font-size: clamp(6rem, 18vw, 26rem);
    color: transparent;
    -webkit-text-stroke: 1px rgba(7,209,110,0.07);
    pointer-events: none;
    user-select: none;
    z-index: 2;
    transform: translateY(-50%);
    animation: clistBgDrift 30s ease-in-out infinite alternate;
    will-change: transform;
  }
  @keyframes clistBgDrift {
    from { transform: translateY(-50%) translateX(0); }
    to   { transform: translateY(-50%) translateX(-8%); }
  }
  @media (max-width: 768px) {
    #{{ section_id }} .clist-bg-text { display: none; }
  }

  /* ── CONTAINER ──────────────────────────────────────────── */
  #{{ section_id }} .clist-container {
    position: relative;
    z-index: 10;
    max-width: 1400px;
    margin-inline: auto;
    padding-inline: clamp(1.6rem, 5vw, 8rem);
  }

  /* ── SECTION HEADER ─────────────────────────────────────── */
  #{{ section_id }} .clist-header {
    margin-bottom: clamp(2.4rem, 5vw, 4.8rem);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
  }
  #{{ section_id }} .clist-header[data-align="center"] {
    align-items: center;
    text-align: center;
  }
  #{{ section_id }} .clist-header[data-align="right"] {
    align-items: flex-end;
    text-align: right;
  }

  #{{ section_id }} .clist-eyebrow {
    font-family: var(--font-secondary);
    font-size: clamp(0.9rem, 1.1vw, 1.2rem);
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--section-accent);
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: clamp(0.8rem, 1.5vw, 1.2rem);
  }
  #{{ section_id }} .clist-header[data-align="center"] .clist-eyebrow { justify-content: center; }
  #{{ section_id }} .clist-header[data-align="right"]  .clist-eyebrow { justify-content: flex-end; }
  #{{ section_id }} .clist-eyebrow::before {
    content: '';
    display: inline-block;
    width: 32px;
    height: 2px;
    background: var(--section-accent);
    flex-shrink: 0;
    border-radius: 2px;
  }

  #{{ section_id }} .clist-heading {
    font-family: var(--font-primary);
    font-weight: 400;
    font-size: clamp(2rem, 5vw, {{ heading_size }}px);
    line-height: 1.0;
    letter-spacing: -0.025em;
    color: var(--section-text);
    overflow-wrap: break-word;
    word-break: break-word;
    margin-bottom: clamp(0.8rem, 1.5vw, 1.2rem);
  }

  #{{ section_id }} .clist-subtitle {
    font-family: var(--font-secondary);
    font-size: clamp(1.3rem, 1.5vw, {{ subtitle_size }}px);
    font-weight: 400;
    line-height: 1.65;
    color: var(--section-text);
    opacity: 0.68;
    max-width: 60ch;
    overflow-wrap: break-word;
    word-break: break-word;
  }

  #{{ section_id }} .clist-header-line {
    width: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--section-accent), transparent);
    margin-top: clamp(1rem, 1.8vw, 1.8rem);
    border-radius: 2px;
    transition: width 1.1s var(--ease-expo) 0.3s;
  }
  #{{ section_id }} .clist-header-line.is-visible { width: clamp(60px, 8vw, 100px); }
  #{{ section_id }} .clist-header[data-align="center"] .clist-header-line {
    background: linear-gradient(90deg, transparent, var(--section-accent), transparent);
    align-self: center;
    width: 0;
  }
  #{{ section_id }} .clist-header[data-align="center"] .clist-header-line.is-visible {
    width: clamp(80px, 10vw, 140px);
  }
  #{{ section_id }} .clist-header[data-align="right"] .clist-header-line {
    background: linear-gradient(270deg, var(--section-accent), transparent);
    align-self: flex-end;
  }

  /* ── GRID ───────────────────────────────────────────────── */
  #{{ section_id }} .clist-grid {
    display: grid;
    grid-template-columns: repeat(var(--col-desktop), 1fr);
    gap: var(--card-gap);
    align-items: start;
  }

  /* ── CARD BASE ──────────────────────────────────────────── */
  #{{ section_id }} .clist-card {
    position: relative;
    display: block;
    text-decoration: none;
    border-radius: var(--card-radius);
    overflow: hidden;
    will-change: transform;
    transition: box-shadow 0.45s ease, transform 0.45s var(--ease-back);
    color: inherit;
    -webkit-tap-highlight-color: transparent;
  }

  /* ── IMAGE WRAPPER ──────────────────────────────────────── */
  #{{ section_id }} .clist-img-wrap {
    position: relative;
    overflow: hidden;
    aspect-ratio: {{ aspect_ratio }};
    width: 100%;
    background: rgba(0,26,46,0.12);
  }

  #{{ section_id }} .clist-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.75s var(--ease-expo), filter 0.4s ease;
    will-change: transform;
    transform: scale(1.0);
  }

  /* Placeholder when no image */
  #{{ section_id }} .clist-img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(7,209,110,0.06);
    color: var(--section-accent);
    opacity: 0.4;
  }
  #{{ section_id }} .clist-img-placeholder svg {
    width: clamp(40px, 8vw, 64px);
    height: clamp(40px, 8vw, 64px);
  }

  /* ── GRADIENT OVERLAY (inside img-wrap) ─────────────────── */
  #{{ section_id }} .clist-card-grad {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      transparent 30%,
      var(--overlay-color) 100%
    );
    opacity: var(--overlay-opacity);
    pointer-events: none;
    z-index: 2;
    transition: opacity 0.4s ease;
  }

  /* ── BADGE ──────────────────────────────────────────────── */
  #{{ section_id }} .clist-badge {
    position: absolute;
    top: clamp(10px, 1.5vw, 16px);
    right: clamp(10px, 1.5vw, 16px);
    z-index: 5;
    padding: 5px 12px;
    border-radius: 100px;
    background: var(--section-accent);
    color: var(--bl-navy);
    font-family: var(--font-secondary);
    font-size: clamp(0.8rem, 0.9vw, 1rem);
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    line-height: 1;
    pointer-events: none;
  }

  /* ── CARD INFO ──────────────────────────────────────────── */
  #{{ section_id }} .clist-card-info {
    padding: clamp(1rem, 1.5vw, 1.4rem) clamp(0.8rem, 1.2vw, 1.2rem);
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  /* ── CARD TITLE ─────────────────────────────────────────── */
  #{{ section_id }} .clist-card-title {
    font-family: var(--font-secondary);
    font-weight: 600;
    font-size: clamp(1.3rem, 1.4vw, {{ card_title_size }}px);
    line-height: 1.25;
    overflow-wrap: break-word;
    word-break: break-word;
    transition: color 0.25s ease;
  }

  #{{ section_id }} .clist-card-count {
    font-family: var(--font-secondary);
    font-size: clamp(1.1rem, 1vw, 1.2rem);
    font-weight: 400;
    opacity: 0.55;
    line-height: 1;
  }

  /* ── SHOP CTA ───────────────────────────────────────────── */
  #{{ section_id }} .clist-cta-row {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-secondary);
    font-size: clamp(1.1rem, 1.1vw, 1.2rem);
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--section-accent);
    margin-top: 0.3rem;
    transition: gap 0.25s var(--ease-back);
    overflow-wrap: break-word;
  }
  #{{ section_id }} .clist-card:hover .clist-cta-row { gap: 10px; }

  /* ════════════════════════════════════════════
     CARD STYLE VARIANTS
  ════════════════════════════════════════════ */

  /* ── OVERLAY style ──────────────────────────────────────── */
  #{{ section_id }} .clist-card--overlay .clist-img-wrap {
    aspect-ratio: {{ aspect_ratio }};
    border-radius: var(--card-radius);
  }
  #{{ section_id }} .clist-card--overlay .clist-card-info {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: clamp(1.4rem, 2.2vw, 2.2rem) clamp(1.2rem, 1.8vw, 1.8rem);
    z-index: 4;
    gap: 0.4rem;
  }
  #{{ section_id }} .clist-card--overlay .clist-card-title {
    color: #eaf4f5;
  }
  #{{ section_id }} .clist-card--overlay .clist-card-count {
    color: rgba(234,244,245,0.65);
  }
  #{{ section_id }} .clist-card--overlay .clist-card-grad {
    display: block;
  }
  /* "Shop Now" in overlay starts slightly below, slides up on hover */
  #{{ section_id }} .clist-card--overlay .clist-cta-row {
    color: var(--section-accent);
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.35s ease, transform 0.35s var(--ease-back), gap 0.25s var(--ease-back);
    margin-top: 0.2rem;
  }
  #{{ section_id }} .clist-card--overlay:hover .clist-cta-row {
    opacity: 1;
    transform: translateY(0);
    gap: 10px;
  }

  /* ── BELOW style ────────────────────────────────────────── */
  #{{ section_id }} .clist-card--below {
    background: var(--below-bg);
  }
  #{{ section_id }} .clist-card--below .clist-img-wrap {
    border-radius: var(--card-radius) var(--card-radius) 0 0;
    aspect-ratio: {{ aspect_ratio }};
  }
  #{{ section_id }} .clist-card--below .clist-card-grad {
    display: none;
  }
  #{{ section_id }} .clist-card--below .clist-card-info {
    padding: clamp(1rem, 1.6vw, 1.6rem) clamp(1rem, 1.4vw, 1.4rem);
  }
  #{{ section_id }} .clist-card--below .clist-card-title { color: #eaf4f5; }
  #{{ section_id }} .clist-card--below .clist-card-count { color: rgba(234,244,245,0.55); }

  /* ── FRAMED style ───────────────────────────────────────── */
  #{{ section_id }} .clist-card--framed {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(234,244,245,0.10);
    padding: clamp(0.8rem, 1.2vw, 1.2rem);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }
  #{{ section_id }} .clist-card--framed .clist-img-wrap {
    border-radius: calc(var(--card-radius) - 6px);
    aspect-ratio: {{ aspect_ratio }};
  }
  #{{ section_id }} .clist-card--framed .clist-card-grad {
    display: none;
  }
  #{{ section_id }} .clist-card--framed .clist-card-info {
    padding: clamp(0.8rem, 1vw, 1rem) 0 0;
  }
  #{{ section_id }} .clist-card--framed .clist-card-title { color: #eaf4f5; }
  #{{ section_id }} .clist-card--framed .clist-card-count { color: rgba(234,244,245,0.55); }

  /* ── PLAIN style (matches screenshot — light bg, title below) */
  #{{ section_id }} .clist-card--plain .clist-img-wrap {
    border-radius: var(--card-radius);
    aspect-ratio: {{ aspect_ratio }};
  }
  #{{ section_id }} .clist-card--plain .clist-card-grad { display: none; }
  #{{ section_id }} .clist-card--plain .clist-card-info {
    padding: clamp(0.8rem, 1.2vw, 1.2rem) 0;
  }
  #{{ section_id }} .clist-card--plain .clist-card-title {
    color: var(--section-text);
  }
  #{{ section_id }} .clist-card--plain .clist-card-count {
    color: var(--section-text);
    opacity: 0.55;
  }

  /* ── HOVER LIFT on all card styles ─────────────────────── */
  #{{ section_id }} .clist-card:hover {
    box-shadow: 0 22px 55px rgba(7,209,110,0.13), 0 6px 20px rgba(0,0,0,0.18);
    transform: translateY(-5px) scale(1.01);
  }
  #{{ section_id }} .clist-card:hover .clist-card-title {
    color: var(--section-accent);
  }
  #{{ section_id }} .clist-card--plain:hover .clist-card-title {
    color: var(--section-accent);
  }

  /* ── IMAGE HOVER EFFECTS ────────────────────────────────── */
  {%- if img_hover == 'zoom' -%}
  #{{ section_id }} .clist-card:hover .clist-img {
    transform: scale(1.08);
  }
  {%- elsif img_hover == 'pan' -%}
  #{{ section_id }} .clist-card:hover .clist-img {
    transform: scale(1.04) translateX(6px);
  }
  {%- elsif img_hover == 'brightness' -%}
  #{{ section_id }} .clist-card:hover .clist-img {
    transform: scale(1.04);
    filter: brightness(1.12) saturate(1.05);
  }
  {%- elsif img_hover == 'zoom-dark' -%}
  #{{ section_id }} .clist-card:hover .clist-img {
    transform: scale(1.08);
    filter: brightness(0.72) saturate(0.85);
  }
  {%- elsif img_hover == 'zoom-bright' -%}
  #{{ section_id }} .clist-card:hover .clist-img {
    transform: scale(1.07);
    filter: brightness(1.15) contrast(1.05);
  }
  {%- endif -%}

  /* ── REVEAL ANIMATION (page-flip catalog feel) ──────────── */
  #{{ section_id }} .clist-reveal {
    opacity: 0;
    transform: perspective(1000px) rotateY(-15deg) translateX(-20px) scale(0.96);
    will-change: transform;
    transition: opacity 0.8s var(--ease-expo), transform 0.8s var(--ease-expo);
  }
  #{{ section_id }} .clist-reveal.is-visible {
    opacity: 1;
    transform: perspective(1000px) rotateY(0deg) translateX(0) scale(1);
  }

  /* Header elements: simple fade-up */
  #{{ section_id }} .clist-hdr-reveal {
    opacity: 0;
    transform: translateY(24px);
    will-change: transform;
    transition: opacity 0.7s var(--ease-expo), transform 0.7s var(--ease-expo);
  }
  #{{ section_id }} .clist-hdr-reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Shopify editor — always visible */
  #{{ section_id }}.is-visible .clist-reveal,
  .shopify-design-mode #{{ section_id }} .clist-reveal,
  #{{ section_id }}.is-visible .clist-hdr-reveal,
  .shopify-design-mode #{{ section_id }} .clist-hdr-reveal {
    opacity: 1;
    transform: none;
  }
  .shopify-design-mode #{{ section_id }} .clist-header-line {
    width: clamp(60px, 8vw, 100px);
  }
  .shopify-design-mode #{{ section_id }} .clist-header[data-align="center"] .clist-header-line {
    width: clamp(80px, 10vw, 140px);
  }

  /* ── REDUCED MOTION ─────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    #{{ section_id }} .clist-reveal,
    #{{ section_id }} .clist-hdr-reveal {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
    #{{ section_id }} .clist-header-line { width: clamp(60px, 8vw, 100px); transition: none; }
    #{{ section_id }} .clist-glow--a,
    #{{ section_id }} .clist-glow--b   { animation: none; }
    #{{ section_id }} .clist-bg-text   { animation: none; }
    #{{ section_id }} .clist-card      { transition: none; }
    #{{ section_id }} .clist-img       { transition: none; }
    #{{ section_id }} .clist-card--overlay .clist-cta-row {
      opacity: 1;
      transform: none;
    }
  }

  /* ── RESPONSIVE ─────────────────────────────────────────── */
  @media (max-width: 768px) {
    #{{ section_id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px !important;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px !important;
    }
    #{{ section_id }} .clist-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    #{{ section_id }} .clist-heading {
      font-size: clamp(2rem, 8vw, 3rem);
    }
    #{{ section_id }} .clist-header {
      text-align: left !important;
      align-items: flex-start !important;
    }
    #{{ section_id }} .clist-eyebrow { justify-content: flex-start !important; }
    #{{ section_id }} .clist-subtitle { text-align: left !important; }
  }

  @media (max-width: 1024px) {
    #{{ section_id }} .clist-grid {
      grid-template-columns: repeat(var(--col-tablet), 1fr);
    }
  }

  @media (max-width: 480px) {
    #{{ section_id }} .clist-grid {
      grid-template-columns: 1fr;
    }
    #{{ section_id }} .clist-heading {
      font-size: clamp(2rem, 8vw, 3rem);
    }
  }
</style>

<section
  id="{{ section_id }}"
  class="burnlab-clist"
  data-section-id="{{ section.id }}"
  style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;"
>

  {%- if enable_grain -%}
  <div class="clist-grain" aria-hidden="true"></div>
  {%- endif -%}

  {%- if enable_glows -%}
  <div class="clist-glow clist-glow--a" aria-hidden="true"></div>
  <div class="clist-glow clist-glow--b" aria-hidden="true"></div>
  {%- endif -%}

  {%- if enable_bg_text and bg_text_val != blank -%}
  <div class="clist-bg-text" aria-hidden="true">{{ bg_text_val }}</div>
  {%- endif -%}

  <div class="clist-container">

    {%- if show_hdr -%}
    <div class="clist-header" data-align="{{ hdr_align }}">
      {%- if eyebrow != blank -%}
      <p class="clist-eyebrow clist-hdr-reveal">{{ eyebrow }}</p>
      {%- endif -%}
      {%- if heading != blank -%}
      <h2 class="clist-heading clist-hdr-reveal">{{ heading }}</h2>
      {%- endif -%}
      {%- if subtitle != blank -%}
      <p class="clist-subtitle clist-hdr-reveal">{{ subtitle }}</p>
      {%- endif -%}
      <div class="clist-header-line" aria-hidden="true"></div>
    </div>
    {%- endif -%}

    <div class="clist-grid">
      {%- for block in section.blocks -%}
        {%- liquid
          assign bk_collection = collections[block.settings.collection]

          if block.settings.custom_image != blank
            assign bk_img = block.settings.custom_image
          elsif bk_collection != blank and bk_collection.image != blank
            assign bk_img = bk_collection.image
          else
            assign bk_img = blank
          endif

          if block.settings.custom_title != blank
            assign bk_title = block.settings.custom_title
          elsif bk_collection != blank
            assign bk_title = bk_collection.title
          else
            assign bk_title = 'Collection'
          endif

          if block.settings.custom_url != blank
            assign bk_url = block.settings.custom_url
          elsif bk_collection != blank
            assign bk_url = bk_collection.url
          else
            assign bk_url = '#'
          endif

          assign bk_count = ''
          if block.settings.show_product_count and bk_collection != blank
            assign bk_count = bk_collection.all_products_count
          endif

          assign bk_badge = block.settings.badge_text
        -%}
        <a
          href="{{ bk_url }}"
          class="clist-card clist-card--{{ card_style }} clist-reveal"
          data-card-index="{{ forloop.index0 }}"
          aria-label="{{ bk_title }}"
          {{ block.shopify_attributes }}
        >
          <!-- Image -->
          <div class="clist-img-wrap">
            {%- if bk_img != blank -%}
              {{ bk_img | image_url: width: 900 | image_tag:
                loading: 'lazy',
                alt: bk_img.alt | default: bk_title,
                class: 'clist-img',
                widths: '400, 600, 900',
                sizes: '(max-width: 480px) 100vw, (max-width: 1024px) 50vw, 25vw'
              }}
            {%- else -%}
              <div class="clist-img-placeholder">
                <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <rect x="8" y="8" width="20" height="20" rx="4" stroke="currentColor" stroke-width="2"/>
                  <rect x="36" y="8" width="20" height="20" rx="4" stroke="currentColor" stroke-width="2"/>
                  <rect x="8" y="36" width="20" height="20" rx="4" stroke="currentColor" stroke-width="2"/>
                  <rect x="36" y="36" width="20" height="20" rx="4" stroke="currentColor" stroke-width="2"/>
                </svg>
              </div>
            {%- endif -%}

            <!-- Gradient overlay (used by overlay/dark styles) -->
            <div class="clist-card-grad" aria-hidden="true"></div>

            {%- if bk_badge != blank -%}
            <span class="clist-badge">{{ bk_badge }}</span>
            {%- endif -%}
          </div>

          <!-- Card info (positioned by card style via CSS) -->
          <div class="clist-card-info">
            {%- if bk_count != '' -%}
            <span class="clist-card-count">{{ bk_count }} items</span>
            {%- endif -%}
            <h3 class="clist-card-title">{{ bk_title }}</h3>
            {%- if show_shop_cta -%}
            <span class="clist-cta-row" aria-hidden="true">
              {{ shop_cta_label }}
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                <path d="M1 6H11M11 6L6.5 1.5M11 6L6.5 10.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
            {%- endif -%}
          </div>
        </a>
      {%- endfor -%}
    </div>

  </div>
</section>

{% if section.settings.enable_animations %}
<script>
(function () {
  'use strict';

  var root = document.getElementById('{{ section_id }}');
  if (!root) return;

  var reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  /* ── 1. HEADER ELEMENTS — simple stagger fade-up ──────── */
  var hdrEls = root.querySelectorAll('.clist-hdr-reveal');
  hdrEls.forEach(function (el, i) {
    if (!reducedMotion) {
      el.style.transitionDelay = (i * 0.10) + 's';
    }
  });

  var hdrObserver = new IntersectionObserver(function (entries) {
    entries.forEach(function (entry) {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
        hdrObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.15 });
  hdrEls.forEach(function (el) { hdrObserver.observe(el); });

  /* ── 2. HEADER LINE — width draw ─────────────────────── */
  var lineEl = root.querySelector('.clist-header-line');
  if (lineEl) {
    new IntersectionObserver(function (entries) {
      if (entries[0].isIntersecting) {
        lineEl.classList.add('is-visible');
      }
    }, { threshold: 0.1 }).observe(lineEl);
  }

  /* ── 3. CARD REVEAL — page-flip catalog cascade ─────── */
  var cardEls = root.querySelectorAll('.clist-card.clist-reveal');

  if (!reducedMotion) {
    /* Apply stagger delays (per card, left-to-right in grid) */
    cardEls.forEach(function (card) {
      var idx = parseInt(card.getAttribute('data-card-index') || '0', 10);
      card.style.transitionDelay = (idx * 0.10) + 's';
    });
  }

  var cardObserver = new IntersectionObserver(function (entries) {
    entries.forEach(function (entry) {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
        /* Remove stagger delay after reveal so hover is instant */
        entry.target.addEventListener('transitionend', function cleanup() {
          entry.target.style.transitionDelay = '';
          entry.target.removeEventListener('transitionend', cleanup);
        });
        cardObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.12 });
  cardEls.forEach(function (card) { cardObserver.observe(card); });

  /* ── 4. SUBTLE PARALLAX TILT on card hover ──────────── */
  if (!reducedMotion) {
    cardEls.forEach(function (card) {
      card.addEventListener('mousemove', function (e) {
        var rect = card.getBoundingClientRect();
        var cx = rect.left + rect.width  / 2;
        var cy = rect.top  + rect.height / 2;
        var dx = (e.clientX - cx) / (rect.width  / 2);
        var dy = (e.clientY - cy) / (rect.height / 2);
        card.style.transform = [
          'translateY(-5px)',
          'scale(1.01)',
          'rotateX(' + (-dy * 4) + 'deg)',
          'rotateY(' + (dx * 4) + 'deg)'
        ].join(' ');
        card.style.transition = 'box-shadow 0.4s ease';
      }, { passive: true });

      card.addEventListener('mouseleave', function () {
        card.style.transform  = '';
        card.style.transition = 'box-shadow 0.45s ease, transform 0.5s var(--ease-back)';
      });
    });
  }

  /* ── 5. CLEANUP on section unmount ──────────────────── */
  document.addEventListener('shopify:section:unload', function (e) {
    if (e.detail.sectionId === '{{ section.id }}') {
      hdrObserver.disconnect();
      cardObserver.disconnect();
    }
  });

})();
</script>
{% endif %}

{% schema %}
{
  "name": "Collection List",
  "tag": "section",
  "class": "burnlab-clist-section",
  "max_blocks": 12,
  "blocks": [
    {
      "type": "collection_card",
      "name": "Collection Card",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection",
          "info": "Auto-fills image and title from the selected collection."
        },
        {
          "type": "header",
          "content": "Manual Overrides"
        },
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Custom Image",
          "info": "Overrides the collection image if set."
        },
        {
          "type": "text",
          "id": "custom_title",
          "label": "Custom Title",
          "info": "Overrides the collection title if set."
        },
        {
          "type": "url",
          "id": "custom_url",
          "label": "Custom Link URL",
          "info": "Overrides the collection link if set."
        },
        {
          "type": "text",
          "id": "badge_text",
          "label": "Badge Text",
          "info": "Leave empty to hide badge. Example: New, Sale, Hot."
        },
        {
          "type": "checkbox",
          "id": "show_product_count",
          "label": "Show Product Count",
          "default": false
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Section Header"
    },
    {
