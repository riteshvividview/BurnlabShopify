{% comment %}
  ============================================================
  BURNLAB — Header Section
  Supports: Shopify OS 2.0 | Min Width: 300px
  v3 — mobile layout overhaul, drawer JS theming, green toggle,
       dark/light logo inputs, expanded mobile schema
  ============================================================
{% endcomment %}

{%- assign section_id = 'burnlab-header-' | append: section.id -%}

{%- liquid
  assign logo            = section.settings.logo
  assign logo_light      = section.settings.logo_light
  assign logo_size       = section.settings.logo_size        | default: 48
  assign logo_size_mob   = section.settings.logo_size_mobile | default: 44
  assign menu_handle     = section.settings.menu             | default: 'main-menu'
  assign acct_menu       = section.settings.customer_account_menu | default: 'customer-account-main-menu'
  assign enable_anims    = section.settings.enable_animations
  assign default_theme   = section.settings.default_theme    | default: 'dark'
  assign nav_size        = section.settings.nav_font_size    | default: 13
  assign header_height   = section.settings.header_height    | default: 72
  assign hdr_height_mob  = section.settings.header_height_mobile | default: 60
  assign header_position = section.settings.header_position  | default: 'sticky'
  assign menu_side       = section.settings.mobile_menu_side | default: 'right'
  assign mob_icons_gap   = section.settings.mobile_icons_gap | default: 6
  assign hdr_dark_bg     = section.settings.hdr_dark_bg      | default: '#001a2e'
  assign hdr_light_bg    = section.settings.hdr_light_bg     | default: '#f5f9fa'
  assign hdr_dark_text   = section.settings.hdr_dark_text    | default: '#eaf4f5'
  assign hdr_light_text  = section.settings.hdr_light_text   | default: '#001a2e'
  assign accent          = section.settings.accent_color     | default: '#07d16e'
  assign drawer_bg_dark  = section.settings.drawer_bg_dark   | default: '#001a2e'
  assign drawer_bg_light = section.settings.drawer_bg_light  | default: '#f0f5f8'
  assign drawer_txt_dark = section.settings.drawer_text_dark | default: '#eaf4f5'
  assign drawer_txt_light = section.settings.drawer_text_light | default: '#001a2e'
  assign drawer_accent    = section.settings.drawer_accent    | default: '#07d16e'
  assign drawer_logo_size = section.settings.drawer_logo_size | default: 40
-%}

{% style %}

/* ═══════════════════════════════════════════════════════════════
   GLOBAL — Dark / Light mode tokens
   ═══════════════════════════════════════════════════════════════ */

:root,
[data-theme="dark"] {
  --bl-mode-bg:          {{ hdr_dark_bg | color_modify: 'alpha', 0.97 }};
  --bl-mode-bg-solid:    {{ hdr_dark_bg }};
  --bl-mode-text:        {{ hdr_dark_text }};
  --bl-mode-text-muted:  {{ hdr_dark_text | color_modify: 'alpha', 0.50 }};
  --bl-mode-border:      rgba(51, 104, 112, 0.22);
  --bl-mode-icon-bg:     rgba(255, 255, 255, 0.06);
  --bl-mode-icon-hover:  rgba(7, 209, 110, 0.13);
  --bl-mode-dropdown-bg: #001828;
  --bl-mode-body-bg:     #000f1c;
  --bl-mode-shadow:      0 4px 40px rgba(0, 0, 0, 0.42);
  --bl-mode-accent:      {{ accent }};
  --bl-drawer-bg:        {{ drawer_bg_dark }};
  --bl-drawer-text:      {{ drawer_txt_dark }};
  --bl-drawer-accent:    {{ drawer_accent }};
  --bl-drawer-border:    rgba(51, 104, 112, 0.25);
}

[data-theme="light"] {
  --bl-mode-bg:          {{ hdr_light_bg | color_modify: 'alpha', 0.97 }};
  --bl-mode-bg-solid:    {{ hdr_light_bg }};
  --bl-mode-text:        {{ hdr_light_text }};
  --bl-mode-text-muted:  {{ hdr_light_text | color_modify: 'alpha', 0.50 }};
  --bl-mode-border:      rgba(0, 26, 46, 0.10);
  --bl-mode-icon-bg:     rgba(0, 26, 46, 0.05);
  --bl-mode-icon-hover:  rgba(7, 209, 110, 0.10);
  --bl-mode-dropdown-bg: #ecf3f5;
  --bl-mode-body-bg:     #f0f5f8;
  --bl-mode-shadow:      0 4px 40px rgba(0, 26, 46, 0.10);
  --bl-mode-accent:      {{ accent }};
  --bl-drawer-bg:        {{ drawer_bg_light }};
  --bl-drawer-text:      {{ drawer_txt_light }};
  --bl-drawer-accent:    {{ drawer_accent }};
  --bl-drawer-border:    rgba(0, 26, 46, 0.12);
}

body {
  background-color: var(--bl-mode-body-bg);
  color: var(--bl-mode-text);
  transition: background-color 0.35s ease, color 0.35s ease;
}

/* ═══════════════════════════════════════════════════════════════
   MOBILE DRAWER — comprehensive theming
   JS injection handles runtime colours. CSS covers structure,
   inner containers, logo sizing, and hard-to-reach elements.
   ═══════════════════════════════════════════════════════════════ */

/* ── All root drawer containers ── */
#mobile_menu_drawer,
.menu-drawer,
.mobile-menu-drawer,
[id*="MenuDrawer"],
[class*="menu-drawer__container"] {
  background-color: var(--bl-drawer-bg) !important;
  background: var(--bl-drawer-bg) !important;
  color: var(--bl-drawer-text) !important;
}

/* ── Inner panels — these are the main culprit for white backgrounds.
   They often carry their own background-color that overrides the root. ── */
#mobile_menu_drawer .menu-drawer__inner-container,
#mobile_menu_drawer .menu-drawer__navigation,
#mobile_menu_drawer .menu-drawer__navigation-items,
#mobile_menu_drawer .menu-drawer__header,
#mobile_menu_drawer .menu-drawer__content,
#mobile_menu_drawer > div,
#mobile_menu_drawer > nav,
.menu-drawer .menu-drawer__inner-container,
.menu-drawer .menu-drawer__navigation,
.menu-drawer .menu-drawer__navigation-items,
.menu-drawer .menu-drawer__header,
.menu-drawer .menu-drawer__content,
.menu-drawer > div,
.menu-drawer > nav {
  background-color: var(--bl-drawer-bg) !important;
  background: var(--bl-drawer-bg) !important;
  color: var(--bl-drawer-text) !important;
}

/* ── All text elements inside drawer ── */
#mobile_menu_drawer a,
#mobile_menu_drawer summary,
#mobile_menu_drawer button,
#mobile_menu_drawer span:not(.visually-hidden),
#mobile_menu_drawer p,
#mobile_menu_drawer li,
#mobile_menu_drawer .header_name-link,
#mobile_menu_drawer .header_name span,
.menu-drawer a,
.menu-drawer summary,
.menu-drawer button,
.menu-drawer span:not(.visually-hidden) {
  color: var(--bl-drawer-text) !important;
  font-family: 'DM Sans', sans-serif;
  transition: color 0.22s ease, padding-left 0.22s ease !important;
}

/* ── summary / disclosure nav items — explicit sizing for Evolve theme ── */
#mobile_menu_drawer details > summary,
#mobile_menu_drawer summary,
.menu-drawer details > summary,
.menu-drawer summary {
  color: var(--bl-drawer-text) !important;
  font-family: 'DM Sans', sans-serif !important;
  font-weight: 600 !important;
  font-size: 1.55rem !important;
  letter-spacing: 0.015em !important;
}

/* ── Link list items ── */
#mobile_menu_drawer .menu-drawer__menu-item > a,
#mobile_menu_drawer li > a,
.menu-drawer .menu-drawer__menu-item > a,
.menu-drawer li > a {
  color: var(--bl-drawer-text) !important;
  font-weight: 500 !important;
  font-size: 1.55rem !important;
}

#mobile_menu_drawer a:hover,
#mobile_menu_drawer summary:hover,
#mobile_menu_drawer li > a:hover,
.menu-drawer a:hover,
.menu-drawer summary:hover,
.menu-drawer li > a:hover {
  color: var(--bl-drawer-accent) !important;
  padding-left: 4px !important;
}

/* ── Close button — green accent ── */
#mobile_menu_drawer button[aria-label*="lose"] svg,
#mobile_menu_drawer button[aria-label*="Close"] svg,
#mobile_menu_drawer [class*="close"] svg,
#mobile_menu_drawer .menu-drawer__close-button svg,
.menu-drawer button[aria-label*="lose"] svg,
.menu-drawer button[aria-label*="Close"] svg,
.menu-drawer [class*="close"] svg,
.menu-drawer .menu-drawer__close-button svg {
  color: var(--bl-drawer-accent) !important;
  stroke: var(--bl-drawer-accent) !important;
  fill: none !important;
}
#mobile_menu_drawer button[aria-label*="lose"],
#mobile_menu_drawer button[aria-label*="Close"],
#mobile_menu_drawer .menu-drawer__close-button,
.menu-drawer button[aria-label*="lose"],
.menu-drawer button[aria-label*="Close"],
.menu-drawer .menu-drawer__close-button {
  color: var(--bl-drawer-accent) !important;
  transition: transform 0.22s ease, color 0.22s ease !important;
}
#mobile_menu_drawer button[aria-label*="lose"]:hover,
.menu-drawer button[aria-label*="lose"]:hover {
  transform: rotate(90deg) scale(1.1);
  color: var(--bl-drawer-accent) !important;
}

/* ── Chevron / caret icons in drawer items ── */
#mobile_menu_drawer .icon-caret,
#mobile_menu_drawer [class*="caret"] svg,
.menu-drawer .icon-caret,
.menu-drawer [class*="caret"] svg {
  color: var(--bl-drawer-text) !important;
  transition: transform 0.25s ease !important;
}
#mobile_menu_drawer details[open] .icon-caret,
#mobile_menu_drawer details[open] [class*="caret"] svg,
.menu-drawer details[open] .icon-caret {
  transform: rotate(180deg);
  color: var(--bl-drawer-accent) !important;
}

/* ── Divider lines ── */
#mobile_menu_drawer li,
#mobile_menu_drawer .menu-drawer__menu-item,
.menu-drawer li {
  border-bottom-color: var(--bl-drawer-border) !important;
  border-top-color: var(--bl-drawer-border) !important;
}

/* ── Close button ── */
#mobile_menu_drawer button[aria-label*="lose"],
#mobile_menu_drawer button[aria-label*="Close"],
#mobile_menu_drawer .menu-drawer__close-button,
.menu-drawer button[aria-label*="lose"],
.menu-drawer .menu-drawer__close-button {
  color: var(--bl-drawer-text) !important;
  background: transparent !important;
}

#mobile_menu_drawer button[aria-label*="lose"]:hover,
.menu-drawer button[aria-label*="lose"]:hover {
  color: var(--bl-drawer-accent) !important;
}

/* ── SVG icons and chevrons — color + stroke for stroked icons ── */
#mobile_menu_drawer svg,
#mobile_menu_drawer .icon-caret,
.menu-drawer svg,
.menu-drawer .icon-caret {
  color: var(--bl-drawer-text) !important;
  stroke: var(--bl-drawer-text) !important;
}
#mobile_menu_drawer svg path,
#mobile_menu_drawer svg polyline,
#mobile_menu_drawer svg line,
.menu-drawer svg path,
.menu-drawer svg polyline,
.menu-drawer svg line {
  stroke: var(--bl-drawer-text) !important;
}
/* Summary accordion chevrons — light color, no fill override (chevrons may be fill-based) */
#mobile_menu_drawer summary svg,
#mobile_menu_drawer summary svg path,
#mobile_menu_drawer summary svg polyline,
#mobile_menu_drawer details > summary svg,
.menu-drawer summary svg,
.menu-drawer summary svg path,
.menu-drawer summary svg polyline,
.menu-drawer details > summary svg {
  color: var(--bl-drawer-text) !important;
  stroke: var(--bl-drawer-text) !important;
  fill: currentColor !important;
}
#mobile_menu_drawer details[open] > summary svg,
#mobile_menu_drawer details[open] > summary svg path,
.menu-drawer details[open] > summary svg,
.menu-drawer details[open] > summary svg path {
  stroke: var(--bl-drawer-accent) !important;
  color: var(--bl-drawer-accent) !important;
  fill: currentColor !important;
}

/* ── Accordion expand animation — content slides in when details opens ── */
#mobile_menu_drawer details > :not(summary),
.menu-drawer details > :not(summary) {
  animation: bl-drawer-slide-in 0.3s cubic-bezier(0.16, 1, 0.3, 1) both;
}
@keyframes bl-drawer-slide-in {
  from { opacity: 0; transform: translateY(-8px); }
  to   { opacity: 1; transform: none; }
}
/* Sub-links inside expanded accordions */
#mobile_menu_drawer details[open] a,
.menu-drawer details[open] a {
  color: var(--bl-drawer-text) !important;
  font-size: 1.4rem !important;
  padding-left: 1.2rem !important;
  border-left: 2px solid rgba(7,209,110,0.25) !important;
  display: block;
}
#mobile_menu_drawer details[open] a:hover,
.menu-drawer details[open] a:hover {
  color: var(--bl-drawer-accent) !important;
  border-left-color: var(--bl-drawer-accent) !important;
}
/* Stagger animation — applied via JS-added bl-drawer-stagger class */
.bl-drawer-stagger #mobile_menu_drawer > * > li:nth-child(1),
.bl-drawer-stagger .menu-drawer li:nth-child(1) { animation-delay: 0.04s; }
.bl-drawer-stagger #mobile_menu_drawer > * > li:nth-child(2),
.bl-drawer-stagger .menu-drawer li:nth-child(2) { animation-delay: 0.09s; }
.bl-drawer-stagger #mobile_menu_drawer > * > li:nth-child(3),
.bl-drawer-stagger .menu-drawer li:nth-child(3) { animation-delay: 0.14s; }
.bl-drawer-stagger #mobile_menu_drawer > * > li:nth-child(4),
.bl-drawer-stagger .menu-drawer li:nth-child(4) { animation-delay: 0.19s; }
.bl-drawer-stagger #mobile_menu_drawer > * > li:nth-child(5),
.bl-drawer-stagger .menu-drawer li:nth-child(5) { animation-delay: 0.24s; }
.bl-drawer-stagger #mobile_menu_drawer li,
.bl-drawer-stagger .menu-drawer li {
  animation: bl-drawer-item-in 0.45s cubic-bezier(0.16, 1, 0.3, 1) both;
}
@keyframes bl-drawer-item-in {
  from { opacity: 0; transform: translateX(-18px); }
  to   { opacity: 1; transform: none; }
}
@media (prefers-reduced-motion: reduce) {
  #mobile_menu_drawer details > :not(summary),
  .menu-drawer details > :not(summary),
  .bl-drawer-stagger li { animation: none !important; }
}

/* ── Logo in drawer — schema-controlled height ── */
#mobile_menu_drawer img,
#mobile_menu_drawer .header_name-logo-wrapper img,
#mobile_menu_drawer .menu-drawer__logo img,
.menu-drawer .menu-drawer__logo img,
.menu-drawer .header_name-logo-wrapper img,
.menu-drawer img:not([class*="icon"]) {
  height: {{ drawer_logo_size }}px !important;
  max-height: {{ drawer_logo_size }}px !important;
  width: auto !important;
  object-fit: contain !important;
}

/* ── Hide account icon at bottom of drawer ── */
{% if section.settings.drawer_hide_account %}
#mobile_menu_drawer .menu-drawer__utility-links,
#mobile_menu_drawer [class*="utility-links"],
#mobile_menu_drawer [class*="customer-account"],
#mobile_menu_drawer shopify-account,
#mobile_menu_drawer .customer-account-drawer,
.menu-drawer .menu-drawer__utility-links,
.menu-drawer shopify-account {
  display: none !important;
}
{% endif %}

/* ═══════════════════════════════════════════════════════════════
   SECTION SCOPED STYLES
   ═══════════════════════════════════════════════════════════════ */

/* ─── Root-level stacking fix ────────────────────────────────────
   Shopify OS 2.0 wraps the header in a section-group div that the
   Evolve theme may give transform:translateZ(0) for GPU compositing.
   That creates a stacking context at z-index:auto (layer 0 in root),
   which loses to ANY positively z-indexed element — including the
   ATC bar's z-index:2. We force every ancestor wrapper we can reach
   to participate in root at z-index:9999 so the dropdown always wins.
   !important is necessary because Evolve's asset CSS loads before
   these inline styles and may assign conflicting values.              */

/* Shopify section-group wrapper (OS 2.0 header group) */
.shopify-section-group-header-group,
#shopify-section-group-header-group {
  position: relative !important;
  z-index: 9999 !important;
}

/* Shopify section wrapper (.shopify-section.header_block) */
.header_block {
  position: relative !important;
  z-index: 9999 !important;
}

/* Custom element wrapper (<header-element>) */
header-element {
  display: block;
  position: relative !important;
  z-index: 9999 !important;
}

#{{ section_id }} *,
#{{ section_id }} *::before,
#{{ section_id }} *::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

#{{ section_id }} { position: relative; isolation: isolate; z-index: 9999 !important; }

/* ─── Outer positioning ──────────────────────────────────────── */

#{{ section_id }} .bl-hdr-outer {
  {% if header_position == 'sticky' %}
    position: sticky; top: 0;
  {% elsif header_position == 'fixed' %}
    position: fixed; top: 0; left: 0; right: 0;
  {% else %}
    position: relative;
  {% endif %}
  z-index: 200;
  width: 100%;
}

{% if header_position == 'fixed' %}
  #{{ section_id }} .bl-hdr-spacer { display: block; height: {{ header_height }}px; }
  @media (max-width: 1024px) {
    #{{ section_id }} .bl-hdr-spacer { height: {{ hdr_height_mob }}px; }
  }
{% else %}
  #{{ section_id }} .bl-hdr-spacer { display: none; }
{% endif %}

/* ─── Wrapper — NO overflow:hidden (would clip dropdowns) ────── */

#{{ section_id }} .bl-hdr-wrapper {
  position: relative;
  background: var(--bl-mode-bg);
  border-bottom: 1px solid var(--bl-mode-border);
  backdrop-filter: blur(24px) saturate(1.4);
  -webkit-backdrop-filter: blur(24px) saturate(1.4);
  box-shadow: var(--bl-mode-shadow);
  transition: background 0.35s ease, border-color 0.35s ease, box-shadow 0.35s ease;
  will-change: background, border-color;
}

{% if section.settings.overlay_header %}
  #{{ section_id }} .bl-hdr-outer.bl-overlay .bl-hdr-wrapper {
    background: transparent; border-bottom-color: transparent; box-shadow: none;
  }
  #{{ section_id }} .bl-hdr-outer.bl-overlay.bl-scrolled .bl-hdr-wrapper {
    background: var(--bl-mode-bg);
    border-bottom-color: var(--bl-mode-border);
    box-shadow: var(--bl-mode-shadow);
  }
{% endif %}

/* ─── Inner flex row ─────────────────────────────────────────── */

#{{ section_id }} .bl-hdr-inner {
  max-width: 1400px;
  margin-inline: auto;
  padding-inline: clamp(1.6rem, 4vw, 4.8rem);
  display: flex;
  align-items: center;
  gap: clamp(1.2rem, 2vw, 2.4rem);
  height: {{ header_height }}px;
  position: relative;
}

/* ─── Logo ───────────────────────────────────────────────────── */

#{{ section_id }} .bl-logo-area { flex-shrink: 0; }

#{{ section_id }} .bl-logo-link {
  display: flex;
  align-items: center;
  text-decoration: none;
  color: var(--bl-mode-text);
  transition: opacity 0.2s ease;
}

#{{ section_id }} .bl-logo-link:hover { opacity: 0.82; }

#{{ section_id }} .bl-logo-img {
  height: {{ logo_size }}px;
  width: auto;
  max-width: 28rem;
  display: block;
  object-fit: contain;
  flex-shrink: 0;
}

/* Dark/light logo switching */
#{{ section_id }} .bl-logo-img--dark  { display: block; }
#{{ section_id }} .bl-logo-img--light { display: none;  }
[data-theme="light"] #{{ section_id }} .bl-logo-img--dark  { display: none;  }
[data-theme="light"] #{{ section_id }} .bl-logo-img--light { display: block; }

/* ─── Desktop Navigation ─────────────────────────────────────── */

#{{ section_id }} .bl-nav {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  list-style: none;
  gap: 0.2rem;
}

#{{ section_id }} .bl-nav-item {
  position: relative;
  will-change: transform;
}

{% if enable_anims %}
#{{ section_id }} .bl-nav-item {
  animation: bl-nav-fall 0.5s var(--bl-ease-expo, cubic-bezier(0.16, 1, 0.3, 1)) both;
  opacity: 0;
}
#{{ section_id }} .bl-nav-item:nth-child(1) { animation-delay: 0.06s; }
#{{ section_id }} .bl-nav-item:nth-child(2) { animation-delay: 0.12s; }
#{{ section_id }} .bl-nav-item:nth-child(3) { animation-delay: 0.18s; }
#{{ section_id }} .bl-nav-item:nth-child(4) { animation-delay: 0.24s; }
#{{ section_id }} .bl-nav-item:nth-child(5) { animation-delay: 0.30s; }
#{{ section_id }} .bl-nav-item:nth-child(6) { animation-delay: 0.36s; }
#{{ section_id }} .bl-nav-item:nth-child(7) { animation-delay: 0.42s; }
#{{ section_id }} .bl-nav-item:nth-child(8) { animation-delay: 0.48s; }

@keyframes bl-nav-fall {
  from { opacity: 0; transform: translateY(-8px); }
  to   { opacity: 1; transform: translateY(0); }
}

@media (prefers-reduced-motion: reduce) {
  #{{ section_id }} .bl-nav-item { animation: none; opacity: 1; }
}
{% else %}
#{{ section_id }} .bl-nav-item { opacity: 1; }
{% endif %}

#{{ section_id }} .bl-nav-link {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  padding: 0.75rem 1.2rem;
  font-family: var(--bl-font-secondary, 'DM Sans', sans-serif);
  font-size: clamp(1.1rem, 1.1vw, {{ nav_size }}px);
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--bl-mode-text);
  text-decoration: none;
  border-radius: 8px;
  position: relative;
  white-space: nowrap;
  transition: color 0.25s ease, background 0.25s ease;
}

#{{ section_id }} .bl-nav-link::after {
  content: '';
  position: absolute;
  bottom: 3px;
  left: 50%;
  transform: translateX(-50%);
  width: 0;
  height: 2px;
  background: var(--bl-mode-accent);
  border-radius: 2px;
  transition: width 0.35s var(--bl-ease-expo, cubic-bezier(0.16, 1, 0.3, 1));
}

#{{ section_id }} .bl-nav-link:hover,
#{{ section_id }} .bl-nav-link[aria-current="page"],
#{{ section_id }} .bl-nav-link.is-active {
  color: var(--bl-mode-accent);
  background: var(--bl-mode-icon-hover);
}

#{{ section_id }} .bl-nav-link:hover::after,
#{{ section_id }} .bl-nav-link[aria-current="page"]::after,
#{{ section_id }} .bl-nav-link.is-active::after {
  width: calc(100% - 2.4rem);
}

#{{ section_id }} .bl-nav-chevron {
  width: 1rem;
  height: 1rem;
  flex-shrink: 0;
  color: var(--bl-mode-text-muted);
  transition: transform 0.25s ease, color 0.25s ease;
}

#{{ section_id }} .bl-nav-item:hover .bl-nav-chevron,
#{{ section_id }} .bl-nav-item:focus-within .bl-nav-chevron {
  transform: rotate(180deg);
  color: var(--bl-mode-accent);
}

/* ─── Dropdown — z-index:300 ensures it floats above page content */

#{{ section_id }} .bl-nav-dropdown {
  position: absolute;
  top: calc(100% + 0.8rem);
  left: 50%;
  transform: translateX(-50%) translateY(-8px);
  min-width: 19rem;
  background: var(--bl-mode-dropdown-bg);
  border: 1px solid var(--bl-mode-border);
  border-radius: 12px;
  padding: 0.6rem;
  list-style: none;
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
  transition: opacity 0.22s ease, transform 0.22s ease, visibility 0.22s ease;
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  box-shadow: 0 12px 40px rgba(0, 0, 0, 0.28), 0 0 0 1px var(--bl-mode-border);
  z-index: 300;
  will-change: opacity, transform;
}

/* Invisible bridge fills the gap so cursor doesn't leave hover zone */
#{{ section_id }} .bl-nav-dropdown::before {
  content: '';
  position: absolute;
  bottom: 100%;
  left: 0;
  right: 0;
  height: 1rem;
}

#{{ section_id }} .bl-nav-item:hover .bl-nav-dropdown,
#{{ section_id }} .bl-nav-item:focus-within .bl-nav-dropdown {
  opacity: 1;
  visibility: visible;
  pointer-events: all;
  transform: translateX(-50%) translateY(0);
}

#{{ section_id }} .bl-nav-dropdown-link {
  display: block;
  padding: 0.85rem 1.4rem;
  font-family: var(--bl-font-secondary, 'DM Sans', sans-serif);
  font-size: clamp(1.2rem, 1.2vw, 1.4rem);
  color: var(--bl-mode-text);
  text-decoration: none;
  border-radius: 8px;
  white-space: nowrap;
  overflow-wrap: break-word;
  transition: color 0.2s ease, background 0.2s ease, padding-left 0.25s ease;
}

#{{ section_id }} .bl-nav-dropdown-link:hover,
#{{ section_id }} .bl-nav-dropdown-link[aria-current="page"] {
  color: var(--bl-mode-accent);
  background: var(--bl-mode-icon-hover);
  padding-left: 2rem;
}

/* ─── Right icon group ───────────────────────────────────────── */

#{{ section_id }} .bl-hdr-icons {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  flex-shrink: 0;
}

#{{ section_id }} .bl-icon-btn {
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 3.8rem;
  height: 3.8rem;
  border-radius: 50%;
  border: 1px solid var(--bl-mode-border);
  background: var(--bl-mode-icon-bg);
  color: var(--bl-mode-text);
  cursor: pointer;
  text-decoration: none;
  transition: background 0.25s ease, color 0.25s ease, border-color 0.25s ease, transform 0.2s ease;
  will-change: transform;
}

#{{ section_id }} .bl-icon-btn:hover {
  background: var(--bl-mode-icon-hover);
  color: var(--bl-mode-accent);
  border-color: var(--bl-mode-accent);
  transform: translateY(-2px);
}

#{{ section_id }} .bl-icon-btn svg {
  width: 1.8rem;
  height: 1.8rem;
  display: block;
  pointer-events: none;
}

#{{ section_id }} .bl-cart-badge {
  position: absolute;
  top: -3px;
  right: -3px;
  min-width: 1.8rem;
  height: 1.8rem;
  background: var(--bl-mode-accent);
  color: #001a2e;
  font-size: 1rem;
  font-weight: 700;
  font-family: var(--bl-font-secondary, 'DM Sans', sans-serif);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  pointer-events: none;
}

#{{ section_id }} .bl-cart-badge[data-count="0"] { display: none; }

/* ─── Theme Toggle — green circular icon button ─────────────────
   Moon = dark mode. Sun = light mode.
   Both icons are BurnLab green on hover; active icon is full green.
   Icons cross-fade with a spring rotation on toggle.             */

#{{ section_id }} .bl-theme-toggle {
  position: relative;
  width: 3.8rem;
  height: 3.8rem;
  border-radius: 50%;
  cursor: pointer;
  flex-shrink: 0;
  padding: 0;
  overflow: visible;
  border: 1.5px solid rgba(7, 209, 110, 0.35);
  background: rgba(7, 209, 110, 0.07);
  transition: transform 0.25s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  will-change: transform;
}

#{{ section_id }} .bl-theme-toggle:hover {
  transform: scale(1.12) rotate(12deg);
  border-color: rgba(7, 209, 110, 0.75);
  box-shadow: 0 0 18px rgba(7, 209, 110, 0.45);
}

@media (prefers-reduced-motion: reduce) {
  #{{ section_id }} .bl-theme-toggle:hover { transform: scale(1.06); }
}

#{{ section_id }} .bl-toggle-icon {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: opacity 0.35s ease, transform 0.45s cubic-bezier(0.34, 1.56, 0.64, 1);
  will-change: opacity, transform;
  pointer-events: none;
}

#{{ section_id }} .bl-toggle-icon svg {
  width: 1.8rem;
  height: 1.8rem;
  pointer-events: none;
}

/* Both icons green — matches BurnLab brand accent */
#{{ section_id }} .bl-toggle-icon--moon { color: var(--bl-mode-accent); }
#{{ section_id }} .bl-toggle-icon--sun  { color: var(--bl-mode-accent); }

/* Dark mode: moon visible */
[data-theme="dark"]  #{{ section_id }} .bl-toggle-icon--moon {
  opacity: 1; transform: rotate(0deg) scale(1);
}
[data-theme="dark"]  #{{ section_id }} .bl-toggle-icon--sun {
  opacity: 0; transform: rotate(80deg) scale(0.3);
}
/* Light mode: sun visible */
[data-theme="light"] #{{ section_id }} .bl-toggle-icon--sun {
  opacity: 1; transform: rotate(0deg) scale(1);
}
[data-theme="light"] #{{ section_id }} .bl-toggle-icon--moon {
  opacity: 0; transform: rotate(-80deg) scale(0.3);
}

@media (prefers-reduced-motion: reduce) {
  #{{ section_id }} .bl-toggle-icon { transition: opacity 0.2s ease; }
  [data-theme="dark"]  #{{ section_id }} .bl-toggle-icon--sun  { transform: none; }
  [data-theme="light"] #{{ section_id }} .bl-toggle-icon--moon { transform: none; }
}

/* ─── Mobile Gym Menu Button ─────────────────────────────────── */

#{{ section_id }} .bl-gym-menu-btn {
  display: none;
  align-items: center;
  justify-content: center;
  width: 4.2rem;
  height: 4.2rem;
  background: var(--bl-mode-icon-bg);
  border: 1px solid var(--bl-mode-border);
  border-radius: 10px;
  color: var(--bl-mode-text);
  cursor: pointer;
  flex-shrink: 0;
  transition: background 0.25s ease, color 0.25s ease, border-color 0.25s ease, transform 0.2s ease;
  will-change: transform;
}

#{{ section_id }} .bl-gym-menu-btn:hover {
  background: var(--bl-mode-icon-hover);
  color: var(--bl-mode-accent);
  border-color: var(--bl-mode-accent);
  transform: scale(1.06);
}

#{{ section_id }} .bl-gym-menu-btn svg {
  width: 2.6rem;
  height: 2.6rem;
  display: block;
  pointer-events: none;
}

/* ─── Progress bar ───────────────────────────────────────────── */

#{{ section_id }} .bl-hdr-progress {
  position: absolute;
  bottom: 0;
  left: 0;
  width: var(--bl-scroll-pct, 0%);
  height: 2px;
  background: linear-gradient(90deg, var(--bl-mode-accent) 0%, rgba(7,209,110,0.35) 100%);
  border-radius: 0 2px 2px 0;
  transition: width 0.1s linear;
  z-index: 5;
  pointer-events: none;
}

/* ─── MOBILE LAYOUT ──────────────────────────────────────────────
   Goal: [LOGO — far left] ............. [icons + hamburger — far right]
   The .bl-nav has flex:1 on desktop — hidden on mobile so we push
   .bl-hdr-icons to the right with margin-left:auto instead.       */

@media (max-width: 1024px) {
  #{{ section_id }} .bl-nav { display: none; }
  #{{ section_id }} .bl-gym-menu-btn { display: inline-flex; }

  #{{ section_id }} .bl-hdr-inner {
    height: {{ hdr_height_mob }}px;
    gap: {{ mob_icons_gap }}px;
    padding-inline: clamp(1.2rem, 4vw, 2rem);
  }

  /* Push everything after the logo to the right */
  #{{ section_id }} .bl-hdr-icons { margin-left: auto; }

  /* Logo sizing on mobile */
  #{{ section_id }} .bl-logo-img {
    height: {{ logo_size_mob }}px;
    max-width: 22rem;
  }

  /* Icon sizing */
  #{{ section_id }} .bl-icon-btn     { width: 3.4rem; height: 3.4rem; }
  #{{ section_id }} .bl-icon-btn svg { width: 1.6rem; height: 1.6rem; }
  #{{ section_id }} .bl-theme-toggle { width: 3.4rem; height: 3.4rem; }
  #{{ section_id }} .bl-toggle-icon svg { width: 1.6rem; height: 1.6rem; }
}

/* Mobile hamburger position */
{% if menu_side == 'right' %}
  @media (max-width: 1024px) {
    #{{ section_id }} .bl-gym-menu-btn { order: 99; }
  }
{% endif %}

/* Hide search on mobile if schema says so */
{% unless section.settings.mobile_show_search %}
  @media (max-width: 1024px) {
    #{{ section_id }} .bl-icon-btn--search { display: none; }
  }
{% endunless %}

/* Hide account on mobile if schema says so */
{% unless section.settings.mobile_show_account %}
  @media (max-width: 1024px) {
    #{{ section_id }} .bl-icon-btn--account { display: none; }
  }
{% endunless %}

/* Hide cart on mobile if schema says so */
{% unless section.settings.mobile_show_cart %}
  @media (max-width: 1024px) {
    #{{ section_id }} .bl-icon-btn--cart { display: none; }
  }
{% endunless %}

@media (max-width: 480px) {
  #{{ section_id }} .bl-hdr-inner { gap: {{ mob_icons_gap | minus: 2 | at_least: 4 }}px; }
  #{{ section_id }} .bl-icon-btn     { width: 3.2rem; height: 3.2rem; }
  #{{ section_id }} .bl-icon-btn svg { width: 1.5rem; height: 1.5rem; }
  #{{ section_id }} .bl-theme-toggle { width: 3.2rem; height: 3.2rem; }
  #{{ section_id }} .bl-gym-menu-btn { width: 3.6rem; height: 3.6rem; }
  #{{ section_id }} .bl-gym-menu-btn svg { width: 2.4rem; height: 2.4rem; }
}

@media (max-width: 300px) {
  #{{ section_id }} .bl-hdr-inner { padding-inline: 0.8rem; gap: 4px; }
}

/* Shopify editor */
.shopify-design-mode #{{ section_id }} .bl-nav-item { opacity: 1; animation: none; }

{% endstyle %}

{%- comment -%}Anti-FOUC — sets data-theme before first paint{%- endcomment -%}
<script>
(function(){
  var s=localStorage.getItem('bl-theme');
  var d='{{ default_theme }}';
  var t;
  if(s){t=s;}
  else if(d==='system'){t=window.matchMedia('(prefers-color-scheme:dark)').matches?'dark':'light';}
  else{t=d||'dark';}
  document.documentElement.setAttribute('data-theme',t);
}());
</script>

