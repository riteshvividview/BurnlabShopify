{% render 'menu-drawer', menu: section.settings.menu, section: section %}

<script>
document.addEventListener('DOMContentLoaded', function () {

  // ─── Drawer theming — robust JS injection ──────────────────────
  // Targets root element + all inner containers so theme-owned
  // background-color overrides on child panels cannot win.
  var DRAWER_BG_DARK   = '{{ drawer_bg_dark }}';
  var DRAWER_BG_LIGHT  = '{{ drawer_bg_light }}';
  var DRAWER_TXT_DARK  = '{{ drawer_txt_dark }}';
  var DRAWER_TXT_LIGHT = '{{ drawer_txt_light }}';
  var DRAWER_ACCENT    = '{{ drawer_accent }}';

  var BL_DRAWER_SEL = '#mobile_menu_drawer, .menu-drawer, [id*="MenuDrawer"]';

  function applyDrawerTheme() {
    var isDark  = document.documentElement.getAttribute('data-theme') !== 'light';
    var bg      = isDark ? DRAWER_BG_DARK  : DRAWER_BG_LIGHT;
    var txt     = isDark ? DRAWER_TXT_DARK : DRAWER_TXT_LIGHT;
    var border  = isDark ? 'rgba(51,104,112,0.22)' : 'rgba(0,26,46,0.1)';

    document.querySelectorAll(BL_DRAWER_SEL).forEach(function(drawer) {
      /* Root element */
      drawer.style.setProperty('background-color', bg, 'important');
      drawer.style.setProperty('background',       bg, 'important');
      drawer.style.setProperty('color',            txt, 'important');

      /* Inner containers — main culprit for white-background override */
      drawer.querySelectorAll(
        '[class*="inner"], [class*="container"], [class*="navigation"],' +
        '[class*="header"], [class*="content"], [class*="panel"],' +
        'nav, div, ul'
      ).forEach(function(el) {
        el.style.setProperty('background-color', bg, 'important');
        el.style.setProperty('background',       bg, 'important');
      });

      /* All text-bearing elements */
      drawer.querySelectorAll(
        'a, summary, button, span, p, h1, h2, h3, h4, h5, label'
      ).forEach(function(el) {
        if (!el.classList.contains('visually-hidden')) {
          el.style.setProperty('color', txt, 'important');
        }
      });

      /* Divider lines */
      drawer.querySelectorAll('li, [class*="item"]').forEach(function(el) {
        el.style.setProperty('border-bottom-color', border, 'important');
      });

      /* SVG icons — set both color + stroke so stroked icons are visible */
      drawer.querySelectorAll('svg').forEach(function(el) {
        el.style.setProperty('color',  txt, 'important');
        el.style.setProperty('stroke', txt, 'important');
      });
      drawer.querySelectorAll('svg path, svg line, svg polyline, svg circle, svg rect').forEach(function(el) {
        el.style.setProperty('stroke', txt, 'important');
      });

      /* Close button (X) — accent green so it's always findable */
      drawer.querySelectorAll(
        'button[aria-label*="lose"] svg, button[aria-label*="lose"] svg path,' +
        'button[aria-label*="lose"] svg line, [class*="close"] svg,' +
        '[class*="close"] svg path, [class*="close"] svg line,' +
        '.menu-drawer__close-button svg, .menu-drawer__close-button svg path,' +
        '.menu-drawer__close-button svg line'
      ).forEach(function(el) {
        el.style.setProperty('color',  DRAWER_ACCENT, 'important');
        el.style.setProperty('stroke', DRAWER_ACCENT, 'important');
        el.style.setProperty('fill',   'none', 'important');
      });

      /* Accordion chevrons — set color + stroke but NOT fill (chevrons may be fill-based) */
      drawer.querySelectorAll(
        'summary svg, summary svg path, summary svg polyline,' +
        '[class*="chevron"] svg, [class*="chevron"] svg path,' +
        '[class*="arrow"] svg, [class*="arrow"] svg path'
      ).forEach(function(el) {
        el.style.setProperty('stroke', txt, 'important');
        el.style.setProperty('color',  txt, 'important');
        el.style.setProperty('fill',   'currentColor', 'important');
      });
    });
  }

  /* 1. Apply immediately */
  applyDrawerTheme();

  /* 2. Re-apply when any drawer trigger is clicked — three passes:
        60ms catches renders that happen right after click;
        300ms catches themes that re-render the drawer after opening;
        700ms catches lazy-rendered or animation-delayed content. */
  document.addEventListener('click', function(e) {
    if (e.target.closest('[data-drawer]') || e.target.closest('.drawer_open_btn')) {
      setTimeout(applyDrawerTheme, 60);
      setTimeout(applyDrawerTheme, 300);
      setTimeout(applyDrawerTheme, 700);
      // Stagger animation: remove + re-add class so animation replays on every open
      document.body.classList.remove('bl-drawer-stagger');
      requestAnimationFrame(function () {
        requestAnimationFrame(function () {
          document.body.classList.add('bl-drawer-stagger');
        });
      });
    }
  });

  /* 3. Watch DOM for the drawer being lazily injected or revealed
        (open attribute, class changes, aria-hidden toggling) */
  var blDrawerWatcher = new MutationObserver(function(muts) {
    var hit = muts.some(function(m) {
      if (m.type === 'childList') {
        return Array.from(m.addedNodes).some(function(n) {
          if (n.nodeType !== 1) return false;
          var id  = n.id  || '';
          var cls = (typeof n.className === 'string' ? n.className : '') || '';
          return id.toLowerCase().includes('drawer') || id.toLowerCase().includes('menu') ||
                 cls.includes('menu-drawer');
        });
      }
      if (m.type === 'attributes') {
        var t  = m.target;
        var id = t.id  || '';
        var cl = (typeof t.className === 'string' ? t.className : '') || '';
        return (id.includes('drawer') || id.includes('menu') || cl.includes('menu-drawer')) &&
               (m.attributeName === 'open' || m.attributeName === 'class' ||
                m.attributeName === 'aria-hidden');
      }
      return false;
    });
    if (hit) setTimeout(applyDrawerTheme, 40);
  });
  blDrawerWatcher.observe(document.body, {
    childList: true, subtree: true,
    attributes: true, attributeFilter: ['open', 'class', 'aria-hidden']
  });

  /* 4. Re-apply whenever data-theme changes */
  var themeObserver = new MutationObserver(function(mutations) {
    mutations.forEach(function(m) {
      if (m.attributeName === 'data-theme') applyDrawerTheme();
    });
  });
  themeObserver.observe(document.documentElement, { attributes: true });

  // ─── Theme toggle ──────────────────────────────────────────────
  var toggleBtn = document.getElementById('bl-theme-toggle-{{ section.id }}');
  if (toggleBtn) {
    toggleBtn.addEventListener('click', function () {
      var html    = document.documentElement;
      var current = html.getAttribute('data-theme') || 'dark';
      var next    = current === 'dark' ? 'light' : 'dark';
      html.setAttribute('data-theme', next);
      localStorage.setItem('bl-theme', next);
    });
  }

  // ─── Scroll: overlay fade + scrolled class ─────────────────────
  var hdrOuter = document.getElementById('bl-hdr-main-{{ section.id }}');
  if (hdrOuter) {
    var ticking = false;
    var onScroll = function () {
      if (!ticking) {
        requestAnimationFrame(function () {
          hdrOuter.classList.toggle('bl-scrolled', window.scrollY > 10);
          ticking = false;
        });
        ticking = true;
      }
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  {% if section.settings.show_progress %}
  // ─── Progress bar ──────────────────────────────────────────────
  var progressBar = document.getElementById('bl-hdr-progress-{{ section.id }}');
  if (progressBar) {
    window.addEventListener('scroll', function () {
      var doc   = document.documentElement;
      var total = doc.scrollHeight - window.innerHeight;
      var pct   = total > 0 ? Math.min(window.scrollY / total, 1) * 100 : 0;
      progressBar.style.setProperty('--bl-scroll-pct', pct + '%');
    }, { passive: true });
  }
  {% endif %}

  // ─── Dropdown: close on outside click ──────────────────────────
  document.addEventListener('click', function (e) {
    if (!e.target.closest('#{{ section_id }} .bl-nav-item')) {
      document.querySelectorAll('#{{ section_id }} .bl-nav-link[aria-expanded="true"]')
        .forEach(function (el) { el.setAttribute('aria-expanded', 'false'); });
    }
  });

  // ─── Dropdown: keyboard aria-expanded ──────────────────────────
  document.querySelectorAll('#{{ section_id }} .bl-nav-link[aria-haspopup="true"]')
    .forEach(function (link) {
      link.addEventListener('click', function () {
        var expanded = this.getAttribute('aria-expanded') === 'true';
        this.setAttribute('aria-expanded', String(!expanded));
      });
    });

});
</script>

