  "blocks": [

    {
      "type": "subheading",
      "name": "Subheading",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Subheading",
          "default": "PREMIUM FITNESS"
        }
      ]
    },

    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Heading",
          "default": "Build Your Ultimate Home Gym"
        }
      ]
    },

    {
      "type": "description",
      "name": "Description",
      "limit": 1,
