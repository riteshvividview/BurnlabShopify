          "default": "Shop Collection"
        },
        {
          "type": "url",
          "id": "primary_link",
          "label": "Primary Button Link"
        },
        {
          "type": "text",
          "id": "secondary_label",
          "label": "Secondary Button Label",
          "default": "Explore More"
        },
        {
          "type": "url",
          "id": "secondary_link",
          "label": "Secondary Button Link"
        }
      ]
    }

  ],

  "presets": [
    {
      "name": "Burnlab Image Banner Pro",
      "blocks": [
        {"type":"subheading"},
        {"type":"heading"},
        {"type":"description"},
        {"type":"buttons"}
      ]
    }
  ]
}
{% endschema %}
