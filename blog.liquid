{% comment %}
  ============================================================
  BURNLAB — BLOG PRO V2
  - Proper boxed desktop layout
  - Better spacing between cards
  - Full landscape image visibility
  - Smaller premium cards
  - Clean hover animations
  - Theme toggle compatible
  - Responsive optimized
  - Schema verified
  ============================================================
{% endcomment %}

{%- liquid
  assign section_id = 'burnlab-blog-pro-' | append: section.id
-%}

<style>

#{{ section_id }},
#{{ section_id }} *{
  box-sizing:border-box;
}

/* =========================================================
   ROOT
========================================================= */

#{{ section_id }}{
  --bl-bg: {{ section.settings.bg_color }};
  --bl-card-bg: {{ section.settings.card_bg }};
  --bl-text: {{ section.settings.text_color }};
  --bl-muted: {{ section.settings.muted_text }};
  --bl-accent: {{ section.settings.accent_color }};
  --bl-border: {{ section.settings.border_color }};
  --bl-radius: {{ section.settings.card_radius }}px;

  position:relative;
  overflow:hidden;

  padding-top:{{ section.settings.top_spacing }}px;
  padding-bottom:{{ section.settings.bottom_spacing }}px;

  background:var(--bl-bg);

  transition:
    background .35s ease,
    color .35s ease;
}

/* =========================================================
   THEME SUPPORT
========================================================= */

[data-theme="dark"] #{{ section_id }}{
  --bl-mode-bg:#041523;
  --bl-mode-card:#08253f;
  --bl-mode-text:#edf7f7;
  --bl-mode-muted:#9db2bd;
  --bl-mode-border:rgba(255,255,255,.08);
}

[data-theme="light"] #{{ section_id }}{
  --bl-mode-bg:#f5f7fa;
  --bl-mode-card:#ffffff;
  --bl-mode-text:#081c2d;
  --bl-mode-muted:#5d7183;
  --bl-mode-border:rgba(0,0,0,.08);
}

#{{ section_id }},
#{{ section_id }} *{
  color:var(--bl-mode-text);
  transition:
    color .35s ease,
    background .35s ease,
    border-color .35s ease;
}

/* =========================================================
   BACKGROUND GRID
========================================================= */

#{{ section_id }}::before{
  content:'';
  position:absolute;
  inset:0;

  background:
    linear-gradient(rgba(255,255,255,.025) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,.025) 1px, transparent 1px);

  background-size:44px 44px;

  mask-image:radial-gradient(circle at center, black 25%, transparent 85%);
  pointer-events:none;
}

/* =========================================================
   CONTAINER
========================================================= */

#{{ section_id }} .bl-blog-container{
  position:relative;
  z-index:2;

  width:100%;
  max-width:1320px;

  margin-inline:auto;

  padding-inline:clamp(1rem,3vw,2rem);
}

/* =========================================================
   HEADER
========================================================= */

#{{ section_id }} .bl-blog-header{
  margin-bottom:3.5rem;
}

#{{ section_id }} .bl-blog-heading-wrap{
  max-width:820px;
}

#{{ section_id }} .bl-blog-eyebrow{
  display:inline-flex;
  align-items:center;
  gap:.7rem;

  margin-bottom:1rem;

  font-size:.82rem;
  letter-spacing:.24em;
  text-transform:uppercase;
  font-weight:700;

  color:var(--bl-accent);
}

#{{ section_id }} .bl-blog-eyebrow::before{
  content:'';
  width:28px;
  height:2px;
  border-radius:100px;
  background:var(--bl-accent);
}

#{{ section_id }} .bl-blog-heading{
  font-size:clamp(2.3rem,5vw,5rem);
  line-height:1;
  font-weight:800;
  letter-spacing:-0.04em;

  margin:0;

  max-width:11ch;
}

#{{ section_id }} .bl-blog-subtext{
  margin-top:1.4rem;

  font-size:1rem;
  line-height:1.8;

  color:var(--bl-mode-muted);

  max-width:62ch;
}

/* =========================================================
   GRID
========================================================= */

#{{ section_id }} .bl-blog-grid{
  display:grid;

  grid-template-columns:
    repeat({{ section.settings.columns }}, minmax(0,1fr));

  gap:2rem;
}

/* =========================================================
   FEATURED
========================================================= */

#{{ section_id }} .bl-blog-card.featured{
  grid-column:span 2;
}

/* =========================================================
   CARD
========================================================= */

#{{ section_id }} .bl-blog-card{
  position:relative;

  overflow:hidden;

  border-radius:var(--bl-radius);

  background:
    linear-gradient(
      180deg,
      rgba(255,255,255,.04),
      rgba(255,255,255,.015)
    ),
    var(--bl-mode-card);

  border:1px solid var(--bl-mode-border);

  backdrop-filter:blur(12px);

  display:flex;
  flex-direction:column;

  box-shadow:
    0 10px 30px rgba(0,0,0,.08);

  transition:
    transform .45s cubic-bezier(.16,1,.3,1),
    box-shadow .45s ease,
    border-color .35s ease;
}

#{{ section_id }} .bl-blog-card:hover{
  transform:translateY(-8px);

  border-color:rgba(7,209,110,.25);

  box-shadow:
    0 18px 50px rgba(0,0,0,.16);
}

/* =========================================================
   IMAGE
========================================================= */

#{{ section_id }} .bl-blog-media{
  position:relative;

  overflow:hidden;

  aspect-ratio:16/9;

  background:#0d2032;
}

#{{ section_id }} .bl-blog-media img{
  width:100%;
  height:100%;

  display:block;

  object-fit:cover;
  object-position:center;

  transition:
    transform 1s cubic-bezier(.16,1,.3,1),
    filter .5s ease;
}

#{{ section_id }} .bl-blog-card:hover .bl-blog-media img{
  transform:scale(1.05);
}

#{{ section_id }} .bl-blog-overlay{
  position:absolute;
  inset:0;

  background:
    linear-gradient(
      to top,
      rgba(0,0,0,.55),
      rgba(0,0,0,.12),
      transparent
    );

  pointer-events:none;
}

/* =========================================================
   CONTENT
========================================================= */

#{{ section_id }} .bl-blog-content{
  padding:1.2rem 1.2rem 1.4rem;

  display:flex;
  flex-direction:column;
  flex:1;
}

#{{ section_id }} .bl-blog-meta{
  display:flex;
  flex-wrap:wrap;
  gap:.8rem;

  margin-bottom:.8rem;

  font-size:.72rem;
  text-transform:uppercase;
  letter-spacing:.08em;

  color:var(--bl-accent);
}

#{{ section_id }} .bl-blog-title{
  margin:0 0 .8rem;

  font-size:1.18rem;
  line-height:1.4;
  font-weight:700;
}

#{{ section_id }} .bl-blog-title a{
  text-decoration:none;
  color:inherit;
}

#{{ section_id }} .bl-blog-excerpt{
  color:var(--bl-mode-muted);

  font-size:.92rem;
  line-height:1.7;

  display:-webkit-box;
  -webkit-line-clamp:3;
  -webkit-box-orient:vertical;

  overflow:hidden;
}

/* =========================================================
   BUTTON
========================================================= */

#{{ section_id }} .bl-blog-btn{
  margin-top:auto;

  padding-top:1rem;

  display:inline-flex;
  align-items:center;
  gap:.65rem;

  text-decoration:none;

  font-size:.9rem;
  font-weight:700;

  color:var(--bl-accent);
}

#{{ section_id }} .bl-blog-btn svg{
  transition:transform .35s ease;
}

#{{ section_id }} .bl-blog-card:hover .bl-blog-btn svg{
  transform:translateX(5px);
}

/* =========================================================
   REVEAL
========================================================= */

#{{ section_id }} .bl-reveal{
  opacity:0;
  transform:translateY(40px);

  transition:
    opacity .8s cubic-bezier(.16,1,.3,1),
    transform .8s cubic-bezier(.16,1,.3,1);
}

#{{ section_id }} .bl-reveal.is-visible{
  opacity:1;
  transform:none;
}

/* =========================================================
   PAGINATION
========================================================= */

#{{ section_id }} .pagination-wrapper{
  margin-top:4rem;
}

/* =========================================================
   TABLET
========================================================= */

@media (max-width:1100px){

  #{{ section_id }} .bl-blog-grid{
    grid-template-columns:repeat(2,minmax(0,1fr));
  }

}

/* =========================================================
   MOBILE
========================================================= */

@media (max-width:768px){

  #{{ section_id }}{
    padding-top:{{ section.settings.mob_top_spacing }}px;
    padding-bottom:{{ section.settings.mob_bottom_spacing }}px;
  }

  #{{ section_id }} .bl-blog-grid{
    grid-template-columns:
      repeat({{ section.settings.mob_columns }}, minmax(0,1fr));

    gap:1.2rem;
  }

  #{{ section_id }} .bl-blog-card.featured{
    grid-column:auto;
  }

  #{{ section_id }} .bl-blog-heading{
    max-width:100%;
  }

  #{{ section_id }} .bl-blog-content{
    padding:1rem;
  }

}

/* =========================================================
   SMALL MOBILE
========================================================= */

@media (max-width:540px){

  #{{ section_id }} .bl-blog-grid{
    grid-template-columns:1fr;
  }

}

/* =========================================================
   REDUCED MOTION
========================================================= */

@media (prefers-reduced-motion:reduce){

  #{{ section_id }} .bl-blog-card,
  #{{ section_id }} .bl-blog-media img,
  #{{ section_id }} .bl-reveal{
    transition:none !important;
    animation:none !important;
    transform:none !important;
  }

}

</style>

<section id="{{ section_id }}">

  <div class="bl-blog-container">

    <div class="bl-blog-header bl-reveal">

      <div class="bl-blog-heading-wrap">

        {% if section.settings.eyebrow != blank %}
          <div class="bl-blog-eyebrow">
            {{ section.settings.eyebrow }}
          </div>
        {% endif %}

        <h1 class="bl-blog-heading">
          {{ section.settings.heading | default: blog.title }}
        </h1>

        {% if section.settings.subtext != blank %}
          <div class="bl-blog-subtext">
            {{ section.settings.subtext }}
          </div>
        {% endif %}

      </div>

    </div>

    {% paginate blog.articles by section.settings.limit %}

      <div class="bl-blog-grid">

        {% for article in blog.articles %}

          <article class="bl-blog-card {% if forloop.first and section.settings.enable_featured %}featured{% endif %} bl-reveal">

            <div class="bl-blog-media">

              {% if article.image %}
                {{
                  article.image
                  | image_url: width: 1400
                  | image_tag:
                    loading: 'lazy',
                    alt: article.title
                }}
              {% endif %}

              <div class="bl-blog-overlay"></div>

            </div>

            <div class="bl-blog-content">

              <div class="bl-blog-meta">

                {% if section.settings.show_date %}
                  <span>
                    {{ article.published_at | time_tag: format: 'date' }}
                  </span>
                {% endif %}

                {% if section.settings.show_author %}
                  <span>
                    {{ article.author }}
                  </span>
                {% endif %}

              </div>

              <h2 class="bl-blog-title">
                <a href="{{ article.url }}">
                  {{ article.title }}
                </a>
              </h2>

              {% if section.settings.show_content %}
                <div class="bl-blog-excerpt">
                  {{ article.excerpt | strip_html | truncate: 110 }}
                </div>
              {% endif %}

              <a href="{{ article.url }}" class="bl-blog-btn">

                {{ section.settings.button_label }}

                <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                  <path d="M2 7H12M12 7L7 2M12 7L7 12"
                    stroke="currentColor"
                    stroke-width="1.7"
                    stroke-linecap="round"
                    stroke-linejoin="round"/>
                </svg>

              </a>

            </div>

          </article>

        {% endfor %}

      </div>

      {% render 'pagination', paginate: paginate %}

    {% endpaginate %}

  </div>

</section>

{% if section.settings.enable_animations %}
<script>

document.addEventListener('DOMContentLoaded', function(){

  const root = document.getElementById('{{ section_id }}');

  if(!root) return;

  const revealItems = root.querySelectorAll('.bl-reveal');

  revealItems.forEach((item, index) => {
    item.style.transitionDelay = `${index * 0.07}s`;
  });

  const observer = new IntersectionObserver((entries) => {

    entries.forEach(entry => {

      if(entry.isIntersecting){
        entry.target.classList.add('is-visible');
        observer.unobserve(entry.target);
      }

    });

  }, {
    threshold:0.12
  });

  revealItems.forEach(el => observer.observe(el));

});

</script>
{% endif %}

{% schema %}
{
  "name": "Burnlab Blog Pro",
  "tag": "section",
  "class": "burnlab-blog-pro",
  "settings": [

    {
      "type": "header",
      "content": "Header"
    },

    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "BURNLAB JOURNAL"
    },

    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Training. Recovery. Performance."
    },

    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Explore expert insights, recovery strategies, fitness guides, and equipment tips designed to elevate your training experience."
    },

    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Read Article"
    },

    {
      "type": "header",
      "content": "Layout"
    },

    {
      "type": "range",
      "id": "limit",
      "label": "Articles Per Page",
      "min": 2,
      "max": 24,
      "step": 1,
      "default": 9
    },

    {
      "type": "range",
      "id": "columns",
      "label": "Desktop Columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },

    {
      "type": "select",
      "id": "mob_columns",
      "label": "Mobile Columns",
      "options": [
        {
          "value": "1",
          "label": "One"
        },
        {
          "value": "2",
          "label": "Two"
        }
      ],
      "default": "1"
    },

    {
      "type": "checkbox",
      "id": "enable_featured",
      "label": "Enable Featured First Article",
      "default": true
    },

    {
      "type": "checkbox",
      "id": "show_author",
      "label": "Show Author",
      "default": true
    },

    {
      "type": "checkbox",
      "id": "show_date",
      "label": "Show Date",
      "default": true
    },

    {
      "type": "checkbox",
      "id": "show_content",
      "label": "Show Excerpt",
      "default": true
    },

    {
      "type": "range",
      "id": "card_radius",
      "label": "Card Radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 24,
      "unit": "px"
    },

    {
      "type": "header",
      "content": "Colors"
    },

    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#041523"
    },

    {
      "type": "color",
      "id": "card_bg",
      "label": "Card Background",
      "default": "#08253f"
    },

    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#edf7f7"
    },

    {
      "type": "color",
      "id": "muted_text",
      "label": "Muted Text",
      "default": "#9db2bd"
    },

    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent",
      "default": "#07d16e"
    },

    {
      "type": "color",
      "id": "border_color",
      "label": "Border",
      "default": "#1a3d57"
    },

    {
      "type": "checkbox",
      "id": "enable_animations",
      "label": "Enable Animations",
      "default": true
    },

    {
      "type": "header",
      "content": "Desktop Spacing"
    },

    {
      "type": "range",
      "id": "top_spacing",
      "label": "Top Spacing",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 96,
      "unit": "px"
    },

    {
      "type": "range",
      "id": "bottom_spacing",
      "label": "Bottom Spacing",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 96,
      "unit": "px"
    },

    {
      "type": "header",
      "content": "Mobile Spacing"
    },

    {
      "type": "range",
      "id": "mob_top_spacing",
      "label": "Top Spacing",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 64,
      "unit": "px"
    },

    {
      "type": "range",
      "id": "mob_bottom_spacing",
      "label": "Bottom Spacing",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 64,
      "unit": "px"
    }

  ],

  "presets": [
    {
      "name": "Burnlab Blog Pro"
    }
  ]
}
{% endschema %}