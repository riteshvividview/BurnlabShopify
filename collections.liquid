{% comment %}
============================================================
BURNLAB — COLLECTIONS PRO
- Premium boxed layout
- Glassmorphism cards
- Collection title below image
- Product count support
- Theme toggle compatible
- Hover tilt effects
- Green accent glow
- Fully schema editable
- Responsive
============================================================
{% endcomment %}

{%- liquid
  assign section_id = 'burnlab-collections-' | append: section.id
-%}

<style>

#{{ section_id }},
#{{ section_id }} *{
  box-sizing:border-box;
}

/* =========================================================
THEME VARIABLES
========================================================= */

#{{ section_id }}{
  --bl-bg: {{ section.settings.bg_color }};
  --bl-card-bg: {{ section.settings.card_bg_color }};
  --bl-text: {{ section.settings.text_color }};
  --bl-muted: {{ section.settings.muted_text }};
  --bl-accent: {{ section.settings.accent_color }};
  --bl-border: {{ section.settings.border_color }};
  --bl-radius: {{ section.settings.card_radius }}px;
  --bl-title-size: {{ section.settings.title_size }}px;
  --bl-count-size: {{ section.settings.count_size }}px;

  position:relative;
  overflow:hidden;

  padding-top:{{ section.settings.padding_top }}px;
  padding-bottom:{{ section.settings.padding_bottom }}px;

  background:var(--bl-bg);

  transition:
    background .35s ease,
    color .35s ease;
}

/* =========================================================
THEME TOGGLE SUPPORT
========================================================= */

#{{ section_id }},
#{{ section_id }} *{
  color:var(--bl-mode-text);
  transition:
    color .35s ease,
    background .35s ease,
    border-color .35s ease;
}

[data-theme="dark"] #{{ section_id }}{
  --bl-mode-text:#eaf4f5;
  --bl-mode-bg:#001a2e;
}

[data-theme="light"] #{{ section_id }}{
  --bl-mode-text:#001a2e;
  --bl-mode-bg:#ffffff;
}

#{{ section_id }}{
  background:var(--bl-mode-bg);
}

/* =========================================================
BACKGROUND EFFECT
========================================================= */

#{{ section_id }}::before{
  content:'';
  position:absolute;
  inset:0;

  background:
    radial-gradient(circle at top right,
    rgba(7,209,110,.12),
    transparent 30%);

  pointer-events:none;
}

/* =========================================================
CONTAINER
========================================================= */

#{{ section_id }} .bl-container{
  position:relative;
  z-index:2;

  max-width:1400px;
  margin-inline:auto;

  padding-inline:clamp(1.2rem,4vw,4rem);
}

/* =========================================================
HEADER
========================================================= */

#{{ section_id }} .bl-header{
  margin-bottom:4rem;
  text-align:{{ section.settings.heading_align }};
}

#{{ section_id }} .bl-heading{
  font-size:clamp(2.4rem,5vw,5rem);
  line-height:1;
  font-weight:800;
  letter-spacing:-0.04em;

  margin:0;

  color:var(--bl-mode-text);
}

#{{ section_id }} .bl-subtext{
  margin-top:1rem;

  color:var(--bl-muted);

  max-width:700px;

  {% if section.settings.heading_align == 'center' %}
    margin-inline:auto;
  {% endif %}
}

/* =========================================================
GRID
========================================================= */

#{{ section_id }} .bl-grid{
  display:grid;

  grid-template-columns:
    repeat({{ section.settings.columns }}, minmax(0,1fr));

  gap:{{ section.settings.grid_gap }}px;
}

/* =========================================================
CARD
========================================================= */

#{{ section_id }} .bl-card{
  position:relative;

  border-radius:var(--bl-radius);

  overflow:hidden;

  background:
    linear-gradient(
      180deg,
      rgba(255,255,255,.06),
      rgba(255,255,255,.02)
    ),
    var(--bl-card-bg);

  border:1px solid var(--bl-border);

  backdrop-filter:blur(18px);

  transition:
    transform .45s cubic-bezier(.16,1,.3,1),
    box-shadow .35s ease,
    border-color .35s ease;

  transform-style:preserve-3d;
}

#{{ section_id }} .bl-card:hover{
  transform:
    translateY(-10px)
    rotateX(2deg)
    rotateY(-2deg);

  border-color:rgba(7,209,110,.45);

  box-shadow:
    0 30px 60px rgba(0,0,0,.25),
    0 0 0 1px rgba(7,209,110,.12),
    0 0 40px rgba(7,209,110,.12);
}

/* =========================================================
IMAGE
========================================================= */

#{{ section_id }} .bl-image-wrap{
  position:relative;
  overflow:hidden;

  aspect-ratio:
  {% case section.settings.aspect_ratio %}
    {% when 'square' %}1/1
    {% when 'portrait' %}4/5
    {% when 'landscape' %}16/9
    {% else %}1/1
  {% endcase %};
}

#{{ section_id }} .bl-image-wrap img,
#{{ section_id }} .bl-image-wrap svg{
  width:100%;
  height:100%;

  object-fit:cover;

  display:block;

  transition:
    transform 1s cubic-bezier(.16,1,.3,1),
    filter .45s ease;
}

#{{ section_id }} .bl-card:hover img{
  transform:scale(1.08);
  filter:brightness(1.05);
}

#{{ section_id }} .bl-overlay{
  position:absolute;
  inset:0;

  background:
    linear-gradient(
      to top,
      rgba(0,0,0,.5),
      transparent
    );

  opacity:.8;
}

/* =========================================================
CONTENT BELOW CARD
========================================================= */

#{{ section_id }} .bl-content{
  padding:1.2rem .4rem .2rem;
  text-align:center;
}

#{{ section_id }} .bl-title{
  font-size:var(--bl-title-size);
  font-weight:700;
  line-height:1.2;

  margin:0;

  color:{{ section.settings.title_color }};
}

#{{ section_id }} .bl-title a{
  color:inherit;
  text-decoration:none;
}

#{{ section_id }} .bl-count{
  display:block;

  margin-top:.4rem;

  font-size:var(--bl-count-size);

  color:{{ section.settings.count_color }};
}

/* =========================================================
HOVER LINE
========================================================= */

#{{ section_id }} .bl-line{
  width:0;
  height:2px;

  margin:1rem auto 0;

  background:var(--bl-accent);

  transition:width .4s ease;
}

#{{ section_id }} .bl-card:hover .bl-line{
  width:70px;
}

/* =========================================================
REVEAL
========================================================= */

#{{ section_id }} .bl-reveal{
  opacity:0;
  transform:translateY(40px);

  transition:
    opacity .8s ease,
    transform .8s ease;
}

#{{ section_id }} .bl-reveal.is-visible{
  opacity:1;
  transform:none;
}

/* =========================================================
PAGINATION
========================================================= */

#{{ section_id }} .pagination-wrapper{
  margin-top:4rem;
}

/* =========================================================
MOBILE
========================================================= */

@media (max-width:990px){

  #{{ section_id }} .bl-grid{
    grid-template-columns:
      repeat({{ section.settings.mobile_columns }}, minmax(0,1fr));
  }

}

@media (max-width:768px){

  #{{ section_id }}{
    padding-top:{{ section.settings.padding_top_mobile }}px;
    padding-bottom:{{ section.settings.padding_bottom_mobile }}px;
  }

  #{{ section_id }} .bl-heading{
    font-size:2.5rem;
  }

}

@media (max-width:540px){

  #{{ section_id }} .bl-grid{
    grid-template-columns:1fr;
  }

}

/* =========================================================
REDUCED MOTION
========================================================= */

@media (prefers-reduced-motion:reduce){

  #{{ section_id }} *,
  #{{ section_id }} *::before,
  #{{ section_id }} *::after{
    animation:none !important;
    transition:none !important;
    transform:none !important;
  }

}

</style>

<section id="{{ section_id }}">

  <div class="bl-container">

    {% if section.settings.show_heading %}
      <div class="bl-header bl-reveal">

        <h1 class="bl-heading">
          {{ section.settings.heading }}
        </h1>

        {% if section.settings.subtext != blank %}
          <div class="bl-subtext">
            {{ section.settings.subtext }}
          </div>
        {% endif %}

      </div>
    {% endif %}

    {%- liquid
      case section.settings.sort
        when 'products_high', 'products_low'
          assign collections = collections | sort: 'all_products_count'
        when 'date', 'date_reversed'
          assign collections = collections | sort: 'published_at'
      endcase

      if section.settings.sort == 'products_high'
        assign collections = collections | reverse
      endif

      if section.settings.sort == 'date_reversed'
        assign collections = collections | reverse
      endif

      if section.settings.sort == 'alphabetical_reversed'
        assign collections = collections | reverse
      endif
    -%}

    {% paginate collections by section.settings.paginate %}

      <div class="bl-grid">

        {% for collection in collections %}

          <div class="bl-item bl-reveal">

            <div class="bl-card">

              <a href="{{ collection.url }}">

                <div class="bl-image-wrap">

                  {% if collection.featured_image != blank %}

                    {{
                      collection.featured_image
                      | image_url: width: 1200
                      | image_tag:
                        loading: 'lazy',
                        alt: collection.title
                    }}

                  {% else %}

                    {{ 'collection-1' | placeholder_svg_tag }}

                  {% endif %}

                  <div class="bl-overlay"></div>

                </div>

              </a>

            </div>

            <div class="bl-content">

              <h3 class="bl-title">
                <a href="{{ collection.url }}">
                  {{ collection.title }}
                </a>
              </h3>

              {% if section.settings.show_count %}
                <span class="bl-count">
                  ({{ collection.all_products_count }})
                </span>
              {% endif %}

              <div class="bl-line"></div>

            </div>

          </div>

        {% endfor %}

      </div>

      {% render 'pagination', paginate: paginate %}

    {% endpaginate %}

  </div>

</section>

{% if section.settings.enable_animations %}
<script>

document.addEventListener('DOMContentLoaded', function(){

  const root = document.getElementById('{{ section_id }}');

  if(!root) return;

  const items = root.querySelectorAll('.bl-reveal');

  items.forEach((item, index)=>{
    item.style.transitionDelay = `${index * 0.08}s`;
  });

  const observer = new IntersectionObserver((entries)=>{

    entries.forEach(entry=>{

      if(entry.isIntersecting){
        entry.target.classList.add('is-visible');
      }

    });

  }, {
    threshold:0.15
  });

  items.forEach(item=>{
    observer.observe(item);
  });

});

</script>
{% endif %}

{% schema %}
{
  "name": "Burnlab Collections Pro",
  "tag": "section",
  "class": "burnlab-collections-pro",
  "settings": [

    {
      "type": "checkbox",
      "id": "show_heading",
      "label": "Show Heading",
      "default": true
    },

    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop Collections"
    },

    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Explore premium fitness essentials crafted for performance and recovery."
    },

    {
      "type": "select",
      "id": "heading_align",
      "label": "Heading Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },

    {
      "type": "range",
      "id": "paginate",
      "label": "Collections Per Page",
      "min": 2,
      "max": 24,
      "step": 1,
      "default": 8
    },

    {
      "type": "range",
      "id": "columns",
      "label": "Desktop Columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4
    },

    {
      "type": "select",
      "id": "mobile_columns",
      "label": "Mobile Columns",
      "options": [
        { "value": "1", "label": "One" },
        { "value": "2", "label": "Two" }
      ],
      "default": "1"
    },

    {
      "type": "range",
      "id": "grid_gap",
      "label": "Grid Gap",
      "min": 10,
      "max": 50,
      "step": 2,
      "default": 24
    },

    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Image Ratio",
      "options": [
        { "value": "square", "label": "Square" },
        { "value": "portrait", "label": "Portrait" },
        { "value": "landscape", "label": "Landscape" }
      ],
      "default": "landscape"
    },

    {
      "type": "checkbox",
      "id": "show_count",
      "label": "Show Product Count",
      "default": true
    },

    {
      "type": "range",
      "id": "title_size",
      "label": "Collection Title Size",
      "min": 14,
      "max": 40,
      "step": 1,
      "default": 22
    },

    {
      "type": "range",
      "id": "count_size",
      "label": "Product Count Size",
      "min": 10,
      "max": 24,
      "step": 1,
      "default": 15
    },

    {
      "type": "color",
      "id": "title_color",
      "label": "Title Color",
      "default": "#eaf4f5"
    },

    {
      "type": "color",
      "id": "count_color",
      "label": "Count Color",
      "default": "#07d16e"
    },

    {
      "type": "range",
      "id": "card_radius",
      "label": "Card Radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 24
    },

    {
      "type": "select",
      "id": "sort",
      "label": "Sort Collections",
      "options": [
        { "value": "alphabetical", "label": "Alphabetical A-Z" },
        { "value": "alphabetical_reversed", "label": "Alphabetical Z-A" },
        { "value": "products_high", "label": "Products High-Low" },
        { "value": "products_low", "label": "Products Low-High" },
        { "value": "date", "label": "Old-New" },
        { "value": "date_reversed", "label": "New-Old" }
      ],
      "default": "alphabetical"
    },

    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#001a2e"
    },

    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card Background",
      "default": "#08253f"
    },

    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#eaf4f5"
    },

    {
      "type": "color",
      "id": "muted_text",
      "label": "Muted Text",
      "default": "#8ba3b0"
    },

    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent",
      "default": "#07d16e"
    },

    {
      "type": "color",
      "id": "border_color",
      "label": "Border",
      "default": "#1f3f54"
    },

    {
      "type": "checkbox",
      "id": "enable_animations",
      "label": "Enable Animations",
      "default": true
    },

    {
      "type": "range",
      "id": "padding_top",
      "label": "Desktop Top Padding",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 80
    },

    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Desktop Bottom Padding",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 80
    },

    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Mobile Top Padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 40
    },

    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Mobile Bottom Padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 40
    }

  ],

  "presets": [
    {
      "name": "Burnlab Collections Pro"
    }
  ]
}
{% endschema %}